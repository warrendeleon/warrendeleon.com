# Every legacy path lives here rather than in astro.config.mjs `redirects:`.
# Astro's static redirects emit a 200 HTML stub carrying a meta refresh and a
# noindex tag; Cloudflare Pages reads this file at the edge and answers with a
# real 301. Search Console counts the stubs as "Excluded by 'noindex'" and the
# chains as "Redirect error", so anything a crawler might still hold belongs
# here. _redirects wins over a matching static file, so both can coexist.

# Old /work/ and /work-xp/ paths → /work-experience/
/work/* /work-experience/:splat 301
/work-xp/* /work-experience/:splat 301
/es/work/* /es/work-experience/:splat 301
/ca/work/* /ca/work-experience/:splat 301
/tl/work/* /tl/work-experience/:splat 301
/sky /work-experience/sky/ 301
/sky/ /work-experience/sky/ 301

# Removed /hiring page → home
