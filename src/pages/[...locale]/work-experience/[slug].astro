---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TechBadge from '../../../components/TechBadge.astro';
import { t, slugify, formatDateRange, getLocalePath, locales, type Locale } from '../../../i18n/index';
import { renderSimpleMarkdown, stripSimpleMarkdown, truncateAtWord } from '../../../utils/text';
import BreadcrumbsJsonLd from '../../../components/BreadcrumbsJsonLd.astro';
import workxpEn from '../../../data/workxp-en.json';
import workxpEs from '../../../data/workxp-es.json';
import workxpCa from '../../../data/workxp-ca.json';
import workxpTl from '../../../data/workxp-tl.json';

const workxpByLocale: Record<Locale, unknown> = {
  en: workxpEn,
  es: workxpEs,
  ca: workxpCa,
  tl: workxpTl,
};

export function getStaticPaths() {
  // Astro extracts getStaticPaths into its own chunk, so it can't see the
  // module-level workxpByLocale const — rebuild the map from the imports here.
  const byLocale: Record<Locale, typeof workxpEn> = {
    en: workxpEn,
    es: workxpEs as typeof workxpEn,
    ca: workxpCa as typeof workxpEn,
    tl: workxpTl as typeof workxpEn,
  };
  const paths: Array<{ params: { locale: string | undefined; slug: string }; props: any }> = [];

  for (const locale of locales) {
    const localeParam = locale === 'en' ? undefined : locale;
    for (const company of byLocale[locale]) {
      // Company page
      paths.push({
        params: { locale: localeParam, slug: slugify(company.company) },
        props: { locale, company, position: null, isClientPage: false },
      });

      // Client pages
      for (const position of company.positions) {
        const client = (position as any).client;
        if (client) {
          paths.push({
            params: { locale: localeParam, slug: slugify(client.name) },
            props: {
              locale,
              company,
              position,
              isClientPage: true,
              clientName: client.name,
              clientLogo: client.logo,
            },
          });
        }
      }
    }
  }

  return paths;
}

const { locale, company, position: clientPosition, isClientPage, clientName, clientLogo } = Astro.props;
const i18n = t(locale);
const workxp = workxpByLocale[locale as Locale] as typeof workxpEn;

const displayName = isClientPage ? clientName : company.company;
const displayLogo = isClientPage ? clientLogo : company.logo;
const backLink = isClientPage
  ? getLocalePath(locale, `/work-experience/${slugify(company.company)}/`)
  : getLocalePath(locale, '/work-experience/');
const backLabel = isClientPage ? company.company : i18n.common.back;

// Contextual action bar (Design System §10B): detail pages carry
// Download CV + Book a call + back-to-top instead of the tab dock.
const pdfHref =
  locale === 'en'
    ? '/pdf/CV_WARRENDELEON_2026.pdf'
    : `/pdf/CV_WARRENDELEON_2026_${locale.toUpperCase()}.pdf`;

const positions = isClientPage ? [clientPosition] : company.positions;
const clientPositions = isClientPage ? [] : company.positions.filter((p: any) => p.client);
const nonClientPositions = isClientPage ? [clientPosition] : company.positions.filter((p: any) => !p.client);

const currentIndex = workxp.findIndex((c: any) => slugify(c.company) === slugify(company.company));
const prevCompany = currentIndex > 0 ? workxp[currentIndex - 1] : null;
const nextCompany = currentIndex < workxp.length - 1 ? workxp[currentIndex + 1] : null;

// Design: a green "Latest" badge on the header when this is the current role
// (same semantics as the home page: blank endDate = ongoing).
const isLatestRole = !isClientPage && currentIndex === 0 && !company.positions[0].endDate?.trim();
---

<BaseLayout
  title={`${displayName} | Warren de Leon`}
  description={truncateAtWord(stripSimpleMarkdown(positions[0].description || `${displayName} — Warren de Leon`), 160)}
  locale={locale}
  currentPath={getLocalePath(locale, `/work-experience/${slugify(displayName)}/`)}
  mobileBack={{ href: backLink, title: displayName, eyebrow: i18n.workExperience.title }}
>
  <BreadcrumbsJsonLd items={[
    { name: 'Warren de Leon', url: getLocalePath(locale, '/') },
    { name: i18n.workExperience.title, url: getLocalePath(locale, '/work-experience/') },
    ...(isClientPage ? [{ name: company.company, url: getLocalePath(locale, `/work-experience/${slugify(company.company)}/`) }] : []),
    { name: displayName },
  ]} />

  <!-- Hero header -->
  <section class="work-hero section-alt" aria-label={i18n.workExperience.companyHeader}>
    <div class="container">
      <a href={backLink} class="work-back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        {backLabel}
      </a>

      <div class="work-hero-content">
        <div class="work-hero-logo">
          {displayLogo ? (
            <img src={displayLogo} alt="" />
          ) : (
            <span class="work-hero-logo-fallback">{displayName.charAt(0)}</span>
          )}
        </div>
        <div class="work-hero-info">
          <h1>{displayName} {isLatestRole && <span class="work-latest-badge">{i18n.home.latestRole}</span>}</h1>
          {nonClientPositions.length === 1 && (
            <h2 class="work-hero-role">{nonClientPositions[0].title}</h2>
          )}
          {nonClientPositions.length === 1 && (
            <span class="work-hero-date">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
              {formatDateRange(nonClientPositions[0].startDate, nonClientPositions[0].endDate, locale)}
            </span>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <article class="section work-content-section">
    <div class="container">

      {/* Multiple positions: show each as a section */}
      {nonClientPositions.length > 1 ? (
        nonClientPositions.map((position: any, index: number) => (
          <section class={`work-position ${index > 0 ? 'work-position-subsequent' : ''}`}>
            <div class="work-position-header">
              <div>
                <h2>{position.title}</h2>
                <span class="work-position-date">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                  </svg>
                  {formatDateRange(position.startDate, position.endDate, locale)}
                </span>
              </div>
            </div>

            {position.description && (
              <div class="work-description-block"><h3 class="work-h2">{i18n.workExperience.description}</h3><div class="work-description dot-list" set:html={renderSimpleMarkdown(position.description)} /></div>
            )}

            {position.responsibilities && position.responsibilities.length > 0 && (
              <div class="work-responsibilities dot-list">
                <h3 class="work-h2">{i18n.workExperience.keyResponsibilities}</h3>
                <ul>
                  {position.responsibilities.map((r: string) => {
                    const colonIdx = r.indexOf(':');
                    if (colonIdx > 0 && colonIdx < 40) {
                      return <li><strong>{r.slice(0, colonIdx)}</strong>{r.slice(colonIdx)}</li>;
                    }
                    return <li>{r}</li>;
                  })}
                </ul>
              </div>
            )}

            {position.technologies && (
              <div class="work-tech-block"><h3 class="work-h2">{i18n.workExperience.techStack}</h3><div class="work-tech-grid">
                {position.technologies.languages && position.technologies.languages.length > 0 && (
                  <div class="work-tech-category">
                    <h3>{i18n.workExperience.programmingLanguages}</h3>
                    <div class="badge-group">
                      {position.technologies.languages.map((lang: string) => <TechBadge label={lang} />)}
                    </div>
                  </div>
                )}
                {position.technologies.frameworks && position.technologies.frameworks.length > 0 && (
                  <div class="work-tech-category">
                    <h3>{i18n.workExperience.technologyStack}</h3>
                    <div class="badge-group">
                      {position.technologies.frameworks.map((fw: string) => <TechBadge label={fw} />)}
                    </div>
                  </div>
                )}
                {position.technologies.testing?.unit && position.technologies.testing.unit.length > 0 && (
                  <div class="work-tech-category">
                    <h3>{i18n.workExperience.unitTesting}</h3>
                    <div class="badge-group">
                      {position.technologies.testing.unit.map((t: string) => <TechBadge label={t} />)}
                    </div>
                  </div>
                )}
                {position.technologies.testing?.e2e && position.technologies.testing.e2e.length > 0 && (
                  <div class="work-tech-category">
                    <h3>{i18n.workExperience.e2eTesting}</h3>
                    <div class="badge-group">
                      {position.technologies.testing.e2e.map((t: string) => <TechBadge label={t} />)}
                    </div>
                  </div>
                )}
                {position.technologies.tools && position.technologies.tools.length > 0 && (
                  <div class="work-tech-category">
                    <h3>{i18n.workExperience.developmentTools}</h3>
                    <div class="badge-group">
                      {position.technologies.tools.map((tool: string) => <TechBadge label={tool} />)}
                    </div>
                  </div>
                )}
                {position.technologies.ci && position.technologies.ci.length > 0 && (
                  <div class="work-tech-category">
                    <h3>{i18n.workExperience.ciCd}</h3>
                    <div class="badge-group">
                      {position.technologies.ci.map((ci: string) => <TechBadge label={ci} />)}
                    </div>
                  </div>
                )}
                {position.technologies.methodology && position.technologies.methodology.length > 0 && (
                  <div class="work-tech-category">
                    <h3>{i18n.workExperience.agileMethodology}</h3>
                    <div class="badge-group">
                      {position.technologies.methodology.map((m: string) => <TechBadge label={m} />)}
                    </div>
                  </div>
                )}
              </div></div>
            )}
          </section>
        ))
      ) : (
        /* Single position: no extra header needed, info is in the hero */
        nonClientPositions.map((position: any) => (
          <div class="work-position">
            {position.description && (
              <div class="work-description-block"><h3 class="work-h2">{i18n.workExperience.description}</h3><div class="work-description dot-list" set:html={renderSimpleMarkdown(position.description)} /></div>
            )}

            {position.responsibilities && position.responsibilities.length > 0 && (
              <div class="work-responsibilities dot-list">
                <h3 class="work-h2">{i18n.workExperience.keyResponsibilities}</h3>
                <ul>
                  {position.responsibilities.map((r: string) => {
                    const colonIdx = r.indexOf(':');
                    if (colonIdx > 0 && colonIdx < 40) {
                      return <li><strong>{r.slice(0, colonIdx)}</strong>{r.slice(colonIdx)}</li>;
                    }
                    return <li>{r}</li>;
                  })}
                </ul>
              </div>
            )}

            {position.technologies && (
              <div class="work-tech-block"><h3 class="work-h2">{i18n.workExperience.techStack}</h3><div class="work-tech-grid">
                {position.technologies.languages && position.technologies.languages.length > 0 && (
                  <div class="work-tech-category">
                    <h3>{i18n.workExperience.programmingLanguages}</h3>
                    <div class="badge-group">
                      {position.technologies.languages.map((lang: string) => <TechBadge label={lang} />)}
                    </div>
                  </div>
                )}
                {position.technologies.frameworks && position.technologies.frameworks.length > 0 && (
                  <div class="work-tech-category">
                    <h3>{i18n.workExperience.technologyStack}</h3>
                    <div class="badge-group">
                      {position.technologies.frameworks.map((fw: string) => <TechBadge label={fw} />)}
                    </div>
                  </div>
                )}
                {position.technologies.testing?.unit && position.technologies.testing.unit.length > 0 && (
                  <div class="work-tech-category">
                    <h3>{i18n.workExperience.unitTesting}</h3>
                    <div class="badge-group">
                      {position.technologies.testing.unit.map((t: string) => <TechBadge label={t} />)}
                    </div>
                  </div>
                )}
                {position.technologies.testing?.e2e && position.technologies.testing.e2e.length > 0 && (
                  <div class="work-tech-category">
                    <h3>{i18n.workExperience.e2eTesting}</h3>
                    <div class="badge-group">
                      {position.technologies.testing.e2e.map((t: string) => <TechBadge label={t} />)}
                    </div>
                  </div>
                )}
                {position.technologies.tools && position.technologies.tools.length > 0 && (
                  <div class="work-tech-category">
                    <h3>{i18n.workExperience.developmentTools}</h3>
                    <div class="badge-group">
                      {position.technologies.tools.map((tool: string) => <TechBadge label={tool} />)}
                    </div>
                  </div>
                )}
                {position.technologies.ci && position.technologies.ci.length > 0 && (
                  <div class="work-tech-category">
                    <h3>{i18n.workExperience.ciCd}</h3>
                    <div class="badge-group">
                      {position.technologies.ci.map((ci: string) => <TechBadge label={ci} />)}
                    </div>
                  </div>
                )}
                {position.technologies.methodology && position.technologies.methodology.length > 0 && (
                  <div class="work-tech-category">
                    <h3>{i18n.workExperience.agileMethodology}</h3>
                    <div class="badge-group">
                      {position.technologies.methodology.map((m: string) => <TechBadge label={m} />)}
                    </div>
                  </div>
                )}
              </div></div>
            )}
          </div>
        ))
      )}

      {/* Client navigation cards */}
      {clientPositions.length > 0 && (
        <section class="work-clients" aria-label={i18n.blog.clientProjects}>
          <h3 class="work-section-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="8.5" cy="7" r="4"></circle>
              <line x1="20" y1="8" x2="20" y2="14"></line>
              <line x1="23" y1="11" x2="17" y2="11"></line>
            </svg>
            {i18n.blog.clientProjects}
          </h3>
          <div class="work-client-grid">
            {clientPositions.map((position: any) => (
              <a href={getLocalePath(locale, `/work-experience/${slugify(position.client.name)}/`)} class="work-client-card">
                <div class="work-client-card-logo">
                  <img src={position.client.logo} alt="" />
                </div>
                <div class="work-client-card-body">
                  <span class="work-client-card-name">{position.client.name}</span>
                  <span class="work-client-card-title">{position.title}</span>
                  <span class="work-client-card-date">
                    {formatDateRange(position.startDate, position.endDate, locale)}
                  </span>
                </div>
                <svg class="work-client-card-arrow" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            ))}
          </div>
        </section>
      )}

      {/* Prev/Next navigation */}
      {!isClientPage && (prevCompany || nextCompany) && (
        <nav class="pn-nav" aria-label={i18n.workExperience.prevNextNav}>
          {prevCompany ? (
            <a href={getLocalePath(locale, `/work-experience/${slugify(prevCompany.company)}/`)} class="pn-link work-detail-nav-prev">
              <span class="pn-label">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="19" y1="12" x2="5" y2="12"></line>
                  <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                {i18n.blog.previous}
              </span>
              <span class="pn-title">{prevCompany.company}</span>
            </a>
          ) : <span />}
          {nextCompany ? (
            <a href={getLocalePath(locale, `/work-experience/${slugify(nextCompany.company)}/`)} class="pn-link pn-next">
              <span class="pn-label">
                {i18n.blog.next}
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </span>
              <span class="pn-title">{nextCompany.company}</span>
            </a>
          ) : <span />}
        </nav>
      )}
    </div>
  </article>

  <!-- Contextual action bar (DS §10B): replaces the tab dock on detail
       pages below the desktop band. -->
  <nav class="work-action-bar" aria-label={i18n.workExperience.title}>
    <a href={pdfHref} class="wab-cv" download>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
      {i18n.workExperience.downloadCV}
    </a>
    <a href={getLocalePath(locale, '/book-a-call/')} class="wab-call">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
      {i18n.nav.bookACall}
    </a>
    <button type="button" class="wab-top" data-wab-top aria-label={i18n.footer.backToTop}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="19" x2="12" y2="5"></line><polyline points="5 12 12 5 19 12"></polyline></svg>
    </button>
  </nav>
</BaseLayout>

<style is:global>
  .work-action-bar {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 430px;
    z-index: 60;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 12px calc(14px + var(--safe-bottom));
    background: var(--bg-nav);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-top: 1px solid var(--border-color);
  }

  /* It replaces the tab dock on these pages (same specificity trick as the
     article bar: out-rank TabBar's Astro-scoped selector). */
  @media (max-width: 1279px), (hover: none) and (pointer: coarse) {
    nav.tab-bar[aria-label] { display: none; }
  }

  .wab-cv,
  .wab-call {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 48px;
    border-radius: 24px;
    font-size: 13.5px;
    font-weight: 700;
    text-decoration: none;
  }

  .wab-cv { background: var(--color-green); color: #ffffff; }
  .wab-cv:hover { background: var(--color-green-dark); color: #ffffff; }
  .wab-call { border: 1.5px solid var(--color-green); background: var(--bg-secondary); color: var(--color-green-text); }

  .wab-top {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border: 1px solid var(--border-color);
    border-radius: 24px;
    background: var(--bg-secondary);
    color: var(--text-primary);
    cursor: pointer;
    flex-shrink: 0;
  }

  /* Tablet band: floating pill, same switch as the other bottom bars. */
  @media (min-width: 700px) and (max-width: 1279px), (min-width: 700px) and (hover: none) and (pointer: coarse) {
    .work-action-bar {
      bottom: calc(16px + var(--safe-bottom));
      width: auto;
      max-width: none;
      border: 1px solid var(--border-color);
      border-radius: 32px;
      box-shadow: var(--shadow-dock);
      padding: 7px 8px;
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
    }

    .wab-cv,
    .wab-call { flex: none; padding: 0 18px; height: 44px; border-radius: 22px; }
    .wab-top { width: 44px; height: 44px; border-radius: 22px; }
  }

  @media (min-width: 1280px) and (hover: hover) and (pointer: fine) {
    .work-action-bar { display: none; }
  }
</style>

<script>
  const topBtn = document.querySelector('[data-wab-top]');
  topBtn?.addEventListener('click', () => {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' });
  });
</script>

<style is:global>
  /* Hero */
  .work-hero {
    padding: 2rem 0 2.5rem;
    background: var(--bg-secondary);
  }

  .work-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    transition: color 0.2s ease, gap 0.2s ease;
  }

  .work-back-link:hover {
    color: var(--color-green-text);
    gap: 0.6rem;
  }

  /* Design: the in-body back link is desktop-only — mobile/tablet use the
     top bar chevron. */
  @media (max-width: 1279px), (hover: none) and (pointer: coarse) {
    .work-back-link { display: none; }
  }

  .work-hero-content {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .work-hero-logo {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 2px solid var(--color-green);
    flex-shrink: 0;
  }

  .work-hero-logo img {
    width: 60%;
    height: 60%;
    object-fit: contain;
