---
import DesignLayout from '../../../components/design/DesignLayout.astro';
import TokenTable from '../../../components/design/TokenTable.astro';
import { t, getLocalePath, localeStaticPaths, type Locale } from '../../../i18n/index';
import { getDesignData } from '../../../lib/design-data';
import { getDesignTokens } from '../../../lib/design-tokens.mjs';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.props as { locale: Locale };
const d = getDesignData(locale);
const ly = d.layout;
const currentPath = getLocalePath(locale, '/design/layout/');
const i18n = t(locale);
const spacing = getDesignTokens().spacing;

// Annotation labels straight from the parser: "--sp-section · 28 / 22 / 22px".
const bandLabel = (name: string) => {
  const t = spacing.find((s) => s.name === name)!;
  return `${name} · ${t.desktop.replace('px', '')} / ${t.tablet.replace('px', '')} / ${t.mobile}`;
};
---

<DesignLayout
  locale={locale}
  currentPath={currentPath}
  seoTitle={ly.seoTitle}
  seoDescription={ly.seoDescription}
  group="foundations"
  title={ly.title}
  intro={ly.intro}
  toc={ly.toc}
>
  <section id="columns">
    <h2>{ly.columnsHeading}</h2>
    <p>{ly.columnsBody}</p>
    <div class="ds-tablewrap">
      <table class="ds-mini">
        <thead>
          <tr>
            <th>{ly.columnsHeaders.band}</th>
            <th>{ly.columnsHeaders.column}</th>
            <th>{ly.columnsHeaders.gutter}</th>
            <th>{ly.columnsHeaders.bar}</th>
          </tr>
        </thead>
        <tbody>
          {ly.columnsRows.map((r) => (
            <tr>
              <td>{r.band}</td>
              <td class="ds-mono">{r.column}</td>
              <td class="ds-mono">{r.gutter}</td>
              <td class="ds-mono">{r.bar}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section id="breakpoints">
    <h2>{ly.breakpointsHeading}</h2>
    <p>{ly.breakpointsBody}</p>
    <div class="ds-tablewrap">
      <table class="ds-mini">
        <tbody>
          {ly.breakpointsRows.map((r) => (
            <tr>
              <td><strong>{r.band}</strong></td>
              <td class="ds-mono">{r.range}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section id="spacing">
    <h2>{ly.spacingHeading}</h2>
    <p>{ly.spacingBody}</p>
    <TokenTable rows={spacing} headers={ly.spacingHeaders} usage={ly.spacingUsage} />

    <h3>{ly.annotatedHeading}</h3>
    <p>{ly.annotatedBody}</p>

    <!-- 0. Every spacing token at every band, side by side: heights are the
         parsed literals from the stylesheet, so all three device sizes are
         visible at once whatever you are reading this on. -->
    <figure class="ds-annotated">
      <div class="ds-band-grid">
        {spacing.map((tok) => (
          <div class="ds-band-token">
            <span class="ds-gap-label ds-band-token-name">{tok.name}</span>
            <div class="ds-band-cells">
              {[
                { label: d.bandLabels.mobile, val: tok.mobile },
                { label: d.bandLabels.tablet, val: tok.tablet },
                { label: d.bandLabels.desktop, val: tok.desktop },
              ].map((cell) => (
                <div class="ds-band-cell">
                  <div class="ds-hatch" style={`height: ${cell.val};`}></div>
                  <span class="ds-gap-label">{cell.label} · {cell.val}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
      <figcaption>{ly.perBandCaption}</figcaption>
    </figure>

    <!-- 1. Section rhythm: two one-sided paddings stack, so adjacent
         sections sit 2× the token apart. Band heights ARE the live token. -->
    <figure class="ds-annotated">
      <div class="ds-content-bar"></div>
      <div class="ds-gap-row">
        <div class="ds-hatch" style="height: var(--sp-section);"></div>
        <span class="ds-gap-label">{bandLabel('--sp-section')}</span>
      </div>
      <div class="ds-gap-row">
        <div class="ds-hatch" style="height: var(--sp-section);"></div>
        <span class="ds-gap-label">{bandLabel('--sp-section')}</span>
      </div>
      <div class="ds-content-bar"></div>
      <figcaption>{ly.annotatedLabels.sections}</figcaption>
    </figure>

    <!-- 2. Heading → content gap. -->
    <figure class="ds-annotated">
      <p class="section-heading ds-heading-demo" aria-hidden="true">{ly.spacingHeading}</p>
      <div class="ds-gap-row">
        <div class="ds-hatch" style="height: var(--sp-heading);"></div>
        <span class="ds-gap-label">{bandLabel('--sp-heading')}</span>
      </div>
      <div class="ds-content-bar"></div>
      <figcaption>{ly.annotatedLabels.heading}</figcaption>
    </figure>

    <!-- 3. Card padding: the real .card with its 24px inset hatched. -->
    <figure class="ds-annotated">
      <div class="card ds-pad-demo">
        <span class="ds-hatch ds-pad-top" aria-hidden="true"></span>
        <span class="ds-hatch ds-pad-bottom" aria-hidden="true"></span>
        <span class="ds-hatch ds-pad-left" aria-hidden="true"></span>
        <span class="ds-hatch ds-pad-right" aria-hidden="true"></span>
        <span class="ds-gap-label ds-pad-label">24px</span>
        <div class="ds-content-bar"></div>
      </div>
      <figcaption>{ly.annotatedLabels.card}</figcaption>
    </figure>

    <!-- 4. CTA stack gap: the real .hero-ctas gap, annotated. -->
    <figure class="ds-annotated">
      <div class="ds-cta-stack">
        <a class="hero-cta hero-cta-outline" href="#spacing">{i18n.nav.bookACall}</a>
        <div class="ds-gap-row">
          <div class="ds-hatch" style="height: 10px;"></div>
          <span class="ds-gap-label">10px</span>
        </div>
        <a class="hero-cta hero-cta-solid" href="#spacing">{i18n.workExperience.downloadCV}</a>
      </div>
      <figcaption>{ly.annotatedLabels.buttons}</figcaption>
    </figure>

    <p>{ly.nestingBody}</p>
  </section>

  <section id="targets">
    <h2>{ly.targetsHeading}</h2>
    <p>{ly.targetsBody}</p>
    <figure class="ds-annotated">
      <div class="ds-target-row">
        {[
          { size: 38, label: ly.targetLabels.compact },
          { size: 44, label: ly.targetLabels.floor },
          { size: 48, label: ly.targetLabels.bar },
        ].map((t) => (
          <div class="ds-target">
            <span class="ds-target-ring" style={`width:${t.size}px;height:${t.size}px;`}>
              <span class="ds-hatch ds-target-pad" aria-hidden="true"></span>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            </span>
            <span class="ds-gap-label">{t.size}px · {t.label}</span>
          </div>
        ))}
      </div>
      <figcaption>{ly.targetsCaption}</figcaption>
    </figure>
  </section>

  <section id="logo">
    <h2>{ly.logoHeading}</h2>
    <p>{ly.logoBody}</p>
    <figure class="ds-annotated">
      <div class="ds-logo-row">
        {[48, 96, 120].map((size) => (
          <div class="ds-target">
            <span class="ds-logo-circle" style={`width:${size}px;height:${size}px;`}>
              <img src="/images/logos/hl.svg" alt="" loading="lazy" />
            </span>
            <span class="ds-gap-label">{size}px</span>
          </div>
        ))}
      </div>
      <figcaption>{ly.logoCaption}</figcaption>
    </figure>
  </section>
</DesignLayout>

<style>
  .ds-tablewrap {
    overflow-x: auto;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    margin: 0 0 1.5rem;
  }
  .ds-mini {
    width: 100%;
    min-width: 100%;
    border-collapse: collapse;
  }
  .ds-mini th {
    text-align: left;
    padding: 10px 14px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    color: var(--text-muted);
    background: var(--badge-bg);
    border-bottom: 1px solid var(--border-color);
    white-space: nowrap;
  }
  .ds-mini td {
    padding: 10px 14px;
    font-size: 0.85rem;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-secondary);
    vertical-align: middle;
  }
  .ds-mini tbody tr:last-child td { border-bottom: none; }
  .ds-mono {
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    font-size: 0.8rem;
    color: var(--text-primary);
    white-space: nowrap;
  }

  /* Annotated-rhythm demos. The heading specimen drops its own margin so the
     hatched band below it is the ONLY space in the figure. */
  .ds-heading-demo { margin-bottom: 0 !important; }

  /* Per-band comparison: each token three times, at its parsed mobile/tablet/
     desktop heights. Bands hang from a shared top edge so heights compare. */
  .ds-band-grid { display: flex; flex-direction: column; gap: 1.5rem; }
  .ds-band-token-name { display: block; margin-bottom: 0.5rem; color: var(--text-primary); }
  .ds-band-cells {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    align-items: start;
  }
  .ds-band-cell { display: flex; flex-direction: column; gap: 0.35rem; }
  .ds-band-cell .ds-gap-label { white-space: normal; }

  /* Card padding ring: four hatch strips sized by the card's real 1.5rem
     (24px) padding, drawn over the padding box. */
  .ds-pad-demo { position: relative; overflow: hidden; }
  .ds-pad-top, .ds-pad-bottom, .ds-pad-left, .ds-pad-right { position: absolute; }
  .ds-pad-top { top: 0; left: 0; right: 0; height: 1.5rem; }
  .ds-pad-bottom { bottom: 0; left: 0; right: 0; height: 1.5rem; }
  .ds-pad-left {
    top: 1.5rem;
    bottom: 1.5rem;
    left: 0;
    width: 1.5rem;
    border: none;
    border-left: 1px dashed rgba(229, 62, 62, 0.55);
    border-right: 1px dashed rgba(229, 62, 62, 0.55);
  }
  .ds-pad-right {
    top: 1.5rem;
    bottom: 1.5rem;
    right: 0;
    width: 1.5rem;
    border: none;
    border-left: 1px dashed rgba(229, 62, 62, 0.55);
    border-right: 1px dashed rgba(229, 62, 62, 0.55);
  }
  .ds-pad-label {
    position: absolute;
    top: 0.15rem;
    right: 2rem;
  }

  .ds-cta-stack {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    max-width: 300px;
  }
  .ds-cta-stack .hero-cta { justify-content: center; }

  /* Touch-target spectrum: real chrome sizes, 18px glyph centred, the hatch
     is the tappable padding around it. */
  .ds-target-row,
  .ds-logo-row {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 1.75rem;
  }
  .ds-target {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .ds-target-ring {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    outline: 1px dashed var(--text-muted);
    color: var(--text-primary);
    overflow: hidden;
  }
  .ds-target-ring svg {
    position: relative;
    z-index: 1;
    background: var(--bg-card);
    border-radius: 3px;
  }
  .ds-target-pad { position: absolute; inset: 0; border: none; }

  /* Logo circles at the three documented diameters: white disc, hairline
     green ring, the mark at ~two-thirds fill (the .timeline-logo spec). */
  .ds-logo-circle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #ffffff;
    border: 1.5px solid var(--color-green);
    overflow: hidden;
  }
  .ds-logo-circle img {
    width: 66%;
    height: 66%;
    object-fit: contain;
  }
</style>
