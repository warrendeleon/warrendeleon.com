---
import DesignLayout from '../../../components/design/DesignLayout.astro';
import TokenTable from '../../../components/design/TokenTable.astro';
import TypeSpecimen from '../../../components/design/TypeSpecimen.astro';
import { getLocalePath, localeStaticPaths, type Locale } from '../../../i18n/index';
import { getDesignData } from '../../../lib/design-data';
import { getDesignTokens } from '../../../lib/design-tokens.mjs';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.props as { locale: Locale };
const d = getDesignData(locale);
const ty = d.typography;
const currentPath = getLocalePath(locale, '/design/typography/');

const type = getDesignTokens().type;
const findType = (name: string) => type.find((t) => t.name === name)!;

const specimens = [
  { name: '--fs-h1', sample: ty.samples.h1, weight: 800, note: ty.specimenNotes.h1, green: false },
  { name: '--fs-h2', sample: ty.samples.h2, weight: 700, note: ty.specimenNotes.h2, green: false },
  { name: '--fs-prose-h2', sample: ty.samples.proseH2, weight: 700, note: ty.specimenNotes.proseH2, green: false },
  { name: '--fs-h3', sample: ty.samples.h3, weight: 700, note: ty.specimenNotes.h3, green: true },
  { name: '--fs-h4', sample: ty.samples.h4, weight: 700, note: ty.specimenNotes.h4, green: false },
  { name: '--fs-body', sample: ty.samples.body, weight: 400, note: ty.specimenNotes.body, green: false },
  { name: '--fs-prose', sample: ty.samples.prose, weight: 400, note: ty.specimenNotes.prose, green: false },
];
---

<DesignLayout
  locale={locale}
  currentPath={currentPath}
  seoTitle={ty.seoTitle}
  seoDescription={ty.seoDescription}
  group="foundations"
  title={ty.title}
  intro={ty.intro}
  toc={ty.toc}
>
  <section id="family">
    <h2>{ty.familyHeading}</h2>
    <p>{ty.familyBody}</p>
    <p>{ty.familyStackNote}</p>
  </section>

  <section id="scale">
    <h2>{ty.scaleHeading}</h2>
    <p>{ty.scaleBody}</p>
    <TokenTable rows={type} headers={ty.scaleHeaders} usage={ty.usage} />
  </section>

  <section id="specimens">
    <h2>{ty.specimensHeading}</h2>
    <p>{ty.specimensBody}</p>
    <div class="ds-specimens">
      {specimens.map((s) => (
        <TypeSpecimen
          token={findType(s.name)}
          sample={s.sample}
          weight={s.weight}
          note={s.note}
          green={s.green}
        />
      ))}
    </div>
  </section>

  <section id="headings">
    <h2>{ty.headingsHeading}</h2>
    <p>{ty.headingsBody}</p>

    <figure class="ds-headmark">
      <p class="section-title" aria-hidden="true">{ty.samples.h1}</p>
      <figcaption>{ty.headingsLabels.pageTitle}</figcaption>
    </figure>

    <figure class="ds-headmark">
      <p class="section-heading" aria-hidden="true">{ty.samples.h2}</p>
      <figcaption>{ty.headingsLabels.sectionHeading}</figcaption>
    </figure>

    <figure class="ds-headmark">
      <div class="prose ds-prose-inline" aria-hidden="true">
        <h2>{ty.samples.proseH2}</h2>
      </div>
      <figcaption>{ty.headingsLabels.articleHeading}</figcaption>
    </figure>

    <figure class="ds-headmark">
      <div class="prose ds-prose-inline" aria-hidden="true">
        <h3>{ty.samples.h3}</h3>
      </div>
      <figcaption>{ty.headingsLabels.browline}</figcaption>
    </figure>
  </section>

  <section id="mono">
    <h2>{ty.monoHeading}</h2>
    <p>{ty.monoBody}</p>
  </section>

  <section id="mapping">
    <h2>{ty.mappingHeading}</h2>
    <p>{ty.mappingBody}</p>
    <ul class="ds-list">
      {ty.mapping.map((m) => (
        <li><strong>{m.role}.</strong> {m.where}</li>
      ))}
    </ul>
  </section>
</DesignLayout>

<style>
  .ds-specimens {
    border: 1px solid var(--border-color);
    border-radius: 14px;
    padding: 0.5rem 1.25rem;
    background: var(--bg-card);
  }

  /* Heading-treatment specimens: each mark rendered by its REAL class
     (.section-title / .section-heading / .prose h2 / .prose h3), with the
     class named in the caption. */
  .ds-headmark {
    margin: 0 0 1rem;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    background: var(--bg-card);
  }
  .ds-headmark > :first-child,
  .ds-headmark .ds-prose-inline {
    padding: 1.25rem 1.25rem 1rem;
    margin: 0;
  }
  .ds-headmark .section-title { margin-bottom: 0; }
  .ds-prose-inline { max-width: none; }
  .ds-prose-inline h2,
  .ds-prose-inline h3 { margin: 0; }
  .ds-headmark figcaption {
    padding: 0.55rem 1.25rem;
    border-top: 1px solid var(--border-color);
    background: var(--badge-bg);
    font-size: 0.72rem;
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    color: var(--text-muted);
  }
</style>
