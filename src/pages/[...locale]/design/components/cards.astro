---
import DesignLayout from '../../../../components/design/DesignLayout.astro';
import { md } from '../../../../lib/inline-markup';
import SpecimenCard from '../../../../components/design/SpecimenCard.astro';
import GuidanceCard from '../../../../components/design/GuidanceCard.astro';
import ViewportFrame from '../../../../components/design/ViewportFrame.astro';
import Placeholder from '../../../../components/design/Placeholder.astro';
import AuthorCard from '../../../../components/blog/AuthorCard.astro';
import FeedPostCard from '../../../../components/blog/FeedPostCard.astro';
import RelatedCard from '../../../../components/blog/RelatedCard.astro';
import SeriesCard from '../../../../components/blog/SeriesCard.astro';
import SeriesHeroCard from '../../../../components/blog/SeriesHeroCard.astro';
import { t, getLocalePath, localeStaticPaths, type Locale } from '../../../../i18n/index';
import { getDesignData } from '../../../../lib/design-data';
import { getCurrentSeriesName } from '../../../../utils/blogHelpers';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.props as { locale: Locale };
const d = getDesignData(locale);
const c = d.cards;
const i18n = t(locale);
const currentPath = getLocalePath(locale, '/design/components/cards/');
const blogPath = getLocalePath(locale, '/blog/');
// The real current series, so the hero card renders exactly what Blog home shows.
const currentSeries = await getCurrentSeriesName(locale);

// Reuse the timeline page's localised placeholder role for the current-role
// specimen (same no-employer-brands rule).
const t2 = d.timeline;
const demoMeta = `8 Jun 2026 · 10 ${i18n.blog.minRead}`;
const demoTitle = 'One shared store across remotes';
const demoDesc =
  'How a single Redux store survives the seam between federated micro-frontends, and what breaks when it does not.';
---

<DesignLayout
  locale={locale}
  currentPath={currentPath}
  seoTitle={c.seoTitle}
  seoDescription={c.seoDescription}
  group="components"
  title={c.title}
  intro={c.intro}
  toc={c.toc}
>
  <section id="base">
    <h2>{c.baseHeading}</h2>
    <p set:html={md(c.baseBody)} />
    <SpecimenCard plain code={'<div class="card"> … </div>'}>
      <div class="card ds-card-demo">
        <strong>A base card</strong>
        <p>A rounded surface with a hairline border and a soft shadow. Hover it to see the lift.</p>
      </div>
    </SpecimenCard>
  </section>

  <section id="feed">
    <h2>{c.feedHeading}</h2>
    <p set:html={md(c.feedBody)} />
    <SpecimenCard plain>
      <div class="ds-feed-demo">
        <FeedPostCard
          href="#feed"
          metaText={demoMeta}
          series="Module Federation"
          title={demoTitle}
          desc={demoDesc}
        >
          <Placeholder slot="thumb" />
        </FeedPostCard>
      </div>
    </SpecimenCard>
    <p set:html={md(c.wholeLinkNote)} />
  </section>

  <section id="series-hero">
    <h2>{c.seriesHeroHeading}</h2>
    <p set:html={md(c.seriesHeroBody)} />
    {currentSeries && (
      <div class="ds-series-hero-demo">
        <SeriesHeroCard locale={locale} seriesName={currentSeries} />
      </div>
    )}
  </section>

  <section id="series-card">
    <h2>{c.seriesCardHeading}</h2>
    <p set:html={md(c.seriesCardBody)} />
    <SpecimenCard plain>
      <SeriesCard
        href="#series-card"
        kicker={`8 ${i18n.blog.parts}`}
        title="Module Federation in React Native"
        desc={demoDesc}
      >
        <Placeholder slot="art" />
      </SeriesCard>
    </SpecimenCard>
  </section>

  <section id="related">
    <h2>{c.relatedHeading}</h2>
    <p set:html={md(c.relatedBody)} />
    <SpecimenCard plain>
      <RelatedCard
        href="#related"
        dateISO="2026-06-08"
        dateLabel="8 Jun 2026"
        title={demoTitle}
      >
        <Placeholder slot="image" />
      </RelatedCard>
    </SpecimenCard>
  </section>

  <section id="author">
    <h2>{c.authorHeading}</h2>
    <p set:html={md(c.authorBody)} />
    <div class="ds-author-demo">
      <AuthorCard locale={locale} />
    </div>
  </section>

  <section id="role">
    <h2>{c.roleHeading}</h2>
    <p set:html={md(c.roleBody)} />
    <SpecimenCard plain>
      <!-- The .current-role classes live in global.css; placeholder content
           per the no-employer-brands rule (letter disc = the real fallback). -->
      <div class="card current-role ds-role-demo">
        <div class="current-role-inner">
          <div class="current-role-logo-col">
            <div class="current-role-logo"><span class="ds-role-letter" aria-hidden="true">A</span></div>
          </div>
          <div class="current-role-content">
            <h3>Acme Studios</h3>
            <p class="role-title">{t2.sample[0].title}</p>
            <p class="role-desc">{t2.sample[0].desc}</p>
          </div>
        </div>
      </div>
    </SpecimenCard>
  </section>

  <section id="lead">
    <h2>{c.leadHeading}</h2>
    <p set:html={md(c.leadBody)} />
    <p set:html={md(d.frameThemeNote)} />
    <div class="ds-frames">
      <ViewportFrame src={blogPath} width={390} height={840} scale={0.58} label={d.bandLabels.mobile} />
      <ViewportFrame src={blogPath} width={768} height={900} scale={0.42} label={d.bandLabels.tablet} />
      <ViewportFrame src={blogPath} width={1280} height={900} scale={0.42} label={d.bandLabels.desktop} />
    </div>
  </section>

  <section id="rules">
    <h2>{c.rulesHeading}</h2>
    <div class="dodont-grid">
      <GuidanceCard kind="do" label={d.doLabel} caption={c.dos[0]}>
        <div class="ds-feed-demo">
          <FeedPostCard href="#rules" metaText={demoMeta} title={demoTitle}>
            <Placeholder slot="thumb" />
          </FeedPostCard>
        </div>
      </GuidanceCard>
      <GuidanceCard kind="dont" label={d.dontLabel} caption={c.donts[0]}>
        <div class="card ds-card-demo">
          <strong>{demoTitle}</strong>
          <p set:html={md(demoDesc)} />
          <span class="ds-btn-row">
            <button type="button" class="btn btn-primary">{i18n.home.readPost}</button>
            <button type="button" class="btn btn-outline">{i18n.blog.copyLink}</button>
            <button type="button" class="btn btn-outline">{i18n.blog.viewSeries}</button>
          </span>
        </div>
      </GuidanceCard>

      <GuidanceCard kind="do" label={d.doLabel} caption={c.dos[1]}>
        <div class="ds-lead-mock" aria-hidden="true">
          <span class="ds-lead-big"></span>
          <span class="ds-lead-row"></span>
          <span class="ds-lead-row"></span>
        </div>
      </GuidanceCard>
      <GuidanceCard kind="dont" label={d.dontLabel} caption={c.donts[1]}>
        <div class="ds-lead-mock" aria-hidden="true">
          <span class="ds-lead-big"></span>
          <span class="ds-lead-big"></span>
        </div>
      </GuidanceCard>

      <GuidanceCard kind="do" label={d.doLabel} caption={c.dos[2]}>
        <div class="card ds-card-demo"><strong>Hover me</strong><p>Border and lift move together.</p></div>
      </GuidanceCard>
      <GuidanceCard kind="dont" label={d.dontLabel} caption={c.donts[2]}>
        <div class="card ds-card-demo" style="border: none;"><strong>No border</strong><p>On a tinted band this edge disappears.</p></div>
      </GuidanceCard>
    </div>
    <h3>{c.whereHeading}</h3>
    <p set:html={md(c.whereBody)} />
  </section>
</DesignLayout>

<style>
  .ds-card-demo { max-width: 360px; }
  .ds-card-demo strong { display: block; margin-bottom: 0.4rem; color: var(--text-primary); }
  .ds-card-demo p { margin: 0; font-size: 0.9rem; color: var(--text-secondary); line-height: 1.5; }
  .ds-btn-row { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.8rem; }
  .ds-feed-demo { width: 100%; max-width: 560px; }
  .ds-series-hero-demo { margin: 0 0 1rem; }
  .ds-author-demo { margin: 0 0 1rem; }
  /* AuthorCard carries a post-context top margin; the specimen doesn't need it. */
  .ds-author-demo :global(.author-card) { margin-top: 0; }
  .ds-role-demo { width: 100%; max-width: 560px; }
  .ds-role-letter {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-green-text);
  }
  .ds-frames {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    align-items: flex-start;
    margin: 0 0 1rem;
  }
  /* Lead-treatment mock: proportions only, deliberately abstract. */
  .ds-lead-mock {
    display: flex;
    flex-direction: column;
    gap: 6px;
    width: 100%;
    max-width: 220px;
  }
  .ds-lead-big {
    height: 64px;
    border-radius: 10px;
    border: 1px solid var(--border-color);
    background: var(--badge-bg);
  }
  .ds-lead-row {
    height: 26px;
    border-radius: 7px;
    border: 1px solid var(--border-color);
    background: var(--bg-card);
  }
</style>
