---
import SocialLinks from '../../../../components/SocialLinks.astro';
import ThemeToggle from '../../../../components/ThemeToggle.astro';
import DesignLayout from '../../../../components/design/DesignLayout.astro';
import { md } from '../../../../lib/inline-markup';
import SpecimenCard from '../../../../components/design/SpecimenCard.astro';
import GuidanceCard from '../../../../components/design/GuidanceCard.astro';
import { t, getLocalePath, localeStaticPaths, type Locale } from '../../../../i18n/index';
import { getDesignData } from '../../../../lib/design-data';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.props as { locale: Locale };
const d = getDesignData(locale);
const b = d.buttons;
const i18n = t(locale);
// Real site labels, in the page's own locale, so demos read like the site.
const CV = i18n.workExperience.downloadCV;
const CALL = i18n.nav.bookACall;
const currentPath = getLocalePath(locale, '/design/components/buttons/');
---

<DesignLayout
  locale={locale}
  currentPath={currentPath}
  seoTitle={b.seoTitle}
  seoDescription={b.seoDescription}
  group="components"
  title={b.title}
  intro={b.intro}
  toc={b.toc}
>
  <section id="tiers">
    <h2>{b.tiersHeading}</h2>
    <h3>{b.inlineHeading}</h3>
    <p set:html={md(b.inlineBody)} />
    <SpecimenCard code={'<button class="btn btn-primary">…</button>\n<button class="btn btn-outline">…</button>'}>
      <button type="button" class="btn btn-primary">{CV}</button>
      <button type="button" class="btn btn-outline">{CALL}</button>
    </SpecimenCard>

    <h3>{b.pillHeading}</h3>
    <p set:html={md(b.pillBody)} />
    <SpecimenCard code={'<div class="hero-ctas">\n  <a class="hero-cta hero-cta-solid">…</a>\n  <a class="hero-cta hero-cta-outline">…</a>\n</div>'}>
      <div class="hero-ctas">
        <a class="hero-cta hero-cta-solid" href="#tiers">{CV}</a>
        <a class="hero-cta hero-cta-outline" href="#tiers">{CALL}</a>
      </div>
    </SpecimenCard>
  </section>

  <section id="states">
    <h2>{b.statesHeading}</h2>
    <p set:html={md(b.statesBody)} />
    <div class="ds-states">
      <div class="ds-state">
        <span class="ds-state-label">{b.states.default}</span>
        <button type="button" class="btn btn-primary">{CV}</button>
        <button type="button" class="btn btn-outline">{CALL}</button>
      </div>
      <div class="ds-state">
        <span class="ds-state-label">{b.states.hover}</span>
        <button type="button" class="btn btn-primary ds-sim-hover-primary">{CV}</button>
        <button type="button" class="btn btn-outline ds-sim-hover-outline">{CALL}</button>
      </div>
      <div class="ds-state">
        <span class="ds-state-label">{b.states.focus}</span>
        <button type="button" class="btn btn-primary ds-sim-focus">{CV}</button>
        <button type="button" class="btn btn-outline ds-sim-focus">{CALL}</button>
      </div>
      <div class="ds-state">
        <span class="ds-state-label">{b.states.disabled}</span>
        <button type="button" class="btn btn-primary" disabled style="opacity: 0.35; cursor: default;">{CV}</button>
        <button type="button" class="ds-arrow-demo" disabled aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
      </div>
    </div>
    <p set:html={md(b.statesDisabledNote)} />
  </section>

  <section id="content">
    <h2>{b.contentHeading}</h2>
    <p set:html={md(b.contentBody)} />
  </section>


  <section id="icon">
    <h2>{b.iconHeading}</h2>
    <p set:html={md(b.iconBody)} />
    <SpecimenCard label={b.iconCaption}>
      <div class="ds-iconbtn-row">
        <SocialLinks locale={locale} />
        <ThemeToggle locale={locale} />
      </div>
    </SpecimenCard>
  </section>

  <section id="rules">
    <h2>{b.rulesHeading}</h2>
    <div class="dodont-grid">
      <GuidanceCard kind="do" label={d.doLabel} caption={b.dos[0]}>
        <button type="button" class="btn btn-primary">{CV}</button>
        <button type="button" class="btn btn-outline">{CALL}</button>
      </GuidanceCard>
      <GuidanceCard kind="dont" label={d.dontLabel} caption={b.donts[0]}>
        <button type="button" class="btn btn-primary">{CV}</button>
        <button type="button" class="btn btn-primary">{CALL}</button>
      </GuidanceCard>

      <GuidanceCard kind="do" label={d.doLabel} caption={b.dos[2]}>
        <button type="button" class="btn btn-primary">{CV}</button>
      </GuidanceCard>
      <GuidanceCard kind="dont" label={d.dontLabel} caption={b.donts[1]}>
        <button type="button" class="btn btn-primary">Click here</button>
      </GuidanceCard>

      <GuidanceCard kind="do" label={d.doLabel} caption={b.dos[1]}>
        <a class="hero-cta hero-cta-solid" href="#rules">{CV}</a>
        <button type="button" class="btn btn-outline">{CALL}</button>
      </GuidanceCard>
      <GuidanceCard kind="dont" label={d.dontLabel} caption={b.donts[2]}>
        <button type="button" class="btn btn-primary" disabled style="opacity: 0.08;">{CV}</button>
      </GuidanceCard>
    </div>
    <h3>{b.whereHeading}</h3>
    <p set:html={md(b.whereBody)} />
  </section>
</DesignLayout>

<style>
  /* States grid: each column renders the same real buttons with the state's
     own declarations applied — hover/pressed use the same tokens :hover does. */
  .ds-states {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
    margin: 0 0 1.25rem;
  }
  @media (min-width: 700px) {
    .ds-states { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1280px) {
    .ds-states { grid-template-columns: repeat(4, 1fr); }
  }
  .ds-state {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    /* Roomy: the focus ring draws 4px outside the button box (2px outline +
       2px offset), so a tight gap makes adjacent rings touch. */
    gap: 1.25rem;
    padding: 1.25rem 1rem;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--bg-secondary);
  }
  .ds-state-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
  }
  /* The same declarations the real :hover rules apply. */
  .ds-sim-hover-primary { background: var(--color-green-dark); }
  .ds-sim-hover-outline { background: var(--color-green); color: var(--color-white); }
  /* The site-wide :focus-visible ring. */
  .ds-sim-focus { outline: 2px solid var(--color-green); outline-offset: 2px; }
  /* The live disabled convention (the series/shelf arrows): opacity 0.35. */
  .ds-arrow-demo {
    width: 38px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--border-color);
    background: var(--bg-card);
    color: var(--text-secondary);
    opacity: 0.35;
    cursor: default;
  }
  .ds-iconbtn-row { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
</style>
