---
import DesignLayout from '../../../../components/design/DesignLayout.astro';
import { md } from '../../../../lib/inline-markup';
import SpecimenCard from '../../../../components/design/SpecimenCard.astro';
import GuidanceCard from '../../../../components/design/GuidanceCard.astro';
import TechBadge from '../../../../components/TechBadge.astro';
import { getLocalePath, localeStaticPaths, type Locale } from '../../../../i18n/index';
import { getDesignData } from '../../../../lib/design-data';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.props as { locale: Locale };
const d = getDesignData(locale);
const c = d.tagsChips;
const currentPath = getLocalePath(locale, '/design/components/tags-chips/');
---

<DesignLayout
  locale={locale}
  currentPath={currentPath}
  seoTitle={c.seoTitle}
  seoDescription={c.seoDescription}
  group="components"
  title={c.title}
  intro={c.intro}
  toc={c.toc}
>
  <section id="badge">
    <h2>{c.badgeHeading}</h2>
    <p set:html={md(c.badgeBody)} />
    <SpecimenCard code={'<span class="badge">React Native</span>'}>
      <div class="badge-group">
        <TechBadge label="React Native" />
        <TechBadge label="TypeScript" />
        <TechBadge label="Astro" />
      </div>
    </SpecimenCard>
  </section>

  <section id="tag">
    <h2>{c.tagHeading}</h2>
    <p set:html={md(c.tagBody)} />
    <SpecimenCard code={'<a class="post-tag" href="/blog/tags/testing/">Testing</a>'}>
      <div class="post-tags">
        <a class="post-tag" href="#tag">Testing</a>
        <a class="post-tag" href="#tag">Module Federation</a>
        <a class="post-tag" href="#tag">Leadership</a>
      </div>
    </SpecimenCard>
  </section>

  <section id="rules">
    <h2>{c.rulesHeading}</h2>
    <div class="dodont-grid">
      <GuidanceCard kind="do" label={d.doLabel} caption={c.dos[0]}>
        <TechBadge label="React Native" />
      </GuidanceCard>
      <GuidanceCard kind="dont" label={d.dontLabel} caption={c.donts[0]}>
        <span class="badge" style="text-decoration: underline; cursor: pointer; color: var(--color-green-text);">React Native</span>
      </GuidanceCard>

      <GuidanceCard kind="do" label={d.doLabel} caption={c.dos[1]}>
        <a class="post-tag" href="#rules">Testing</a>
      </GuidanceCard>
      <GuidanceCard kind="dont" label={d.dontLabel} caption={c.donts[1]}>
        <span class="post-tag" style="background: var(--color-green); color: var(--color-white); border-color: var(--color-green);">Testing</span>
      </GuidanceCard>

      <GuidanceCard kind="do" label={d.doLabel} caption={c.dos[2]}>
        <div class="post-tags">
          <a class="post-tag" href="#rules">Testing</a>
          <a class="post-tag" href="#rules">Leadership</a>
          <a class="post-tag" href="#rules">Hiring</a>
        </div>
      </GuidanceCard>
      <GuidanceCard kind="dont" label={d.dontLabel} caption={c.donts[2]}>
        <div class="post-tags" style="gap: 1px; max-width: 240px;">
          {['Testing', 'Leadership', 'Hiring', 'React Native', 'Detox', 'MSW', 'Zod', 'RTK', 'i18n'].map((x) => (
            <a class="post-tag" href="#rules">{x}</a>
          ))}
        </div>
      </GuidanceCard>
    </div>
    <h3>{c.whereHeading}</h3>
    <p set:html={md(c.whereBody)} />
    <p set:html={md(c.familyNote)} />
  </section>
</DesignLayout>
