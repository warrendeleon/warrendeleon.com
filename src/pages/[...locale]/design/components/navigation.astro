---
import DesignLayout from '../../../../components/design/DesignLayout.astro';
import DoDont from '../../../../components/design/DoDont.astro';
import { getLocalePath, localeStaticPaths, type Locale } from '../../../../i18n/index';
import { getDesignData } from '../../../../lib/design-data';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.props as { locale: Locale };
const d = getDesignData(locale);
const n = d.navigation;
const currentPath = getLocalePath(locale, '/design/components/navigation/');
---

<DesignLayout
  locale={locale}
  currentPath={currentPath}
  seoTitle={n.seoTitle}
  seoDescription={n.seoDescription}
  group="components"
  title={n.title}
  intro={n.intro}
  toc={n.toc}
>
  <section id="bar">
    <h2>{n.barHeading}</h2>
    <p>{n.barBody}</p>
  </section>

  <section id="dock">
    <h2>{n.dockHeading}</h2>
    <p>{n.dockBody}</p>
  </section>

  <section id="action">
    <h2>{n.actionHeading}</h2>
    <p>{n.actionBody}</p>
  </section>

  <section id="footer">
    <h2>{n.footerHeading}</h2>
    <p>{n.footerBody}</p>
  </section>

  <section id="rules">
    <h2>{n.rulesHeading}</h2>
    <DoDont doLabel={d.doLabel} dontLabel={d.dontLabel}>
      <ul slot="do" class="ds-dodont-list">{n.dos.map((x) => <li>{x}</li>)}</ul>
      <ul slot="dont" class="ds-dodont-list">{n.donts.map((x) => <li>{x}</li>)}</ul>
    </DoDont>
    <h3>{n.whereHeading}</h3>
    <p>{n.whereBody}</p>
  </section>
</DesignLayout>
