---
import DesignLayout from '../../../../components/design/DesignLayout.astro';
import SpecimenCard from '../../../../components/design/SpecimenCard.astro';
import GuidanceCard from '../../../../components/design/GuidanceCard.astro';
import { getLocalePath, localeStaticPaths, type Locale } from '../../../../i18n/index';
import { getDesignData } from '../../../../lib/design-data';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.props as { locale: Locale };
const d = getDesignData(locale);
const s = d.sheetsOverlays;
const currentPath = getLocalePath(locale, '/design/components/sheets-overlays/');
const sample = s.sheetSample;
---

<DesignLayout
  locale={locale}
  currentPath={currentPath}
  seoTitle={s.seoTitle}
  seoDescription={s.seoDescription}
  group="components"
  title={s.title}
  intro={s.intro}
  toc={s.toc}
>
  <section id="anatomy">
    <h2>{s.anatomyHeading}</h2>
    <p>{s.anatomyBody}</p>
    <SpecimenCard label={s.anatomyCaption}>
      <div class="ds-sheet">
        <div class="post-sheet-grabber"></div>
        <div class="post-sheet-head">
          <span class="post-sheet-title">{sample.title}</span>
          <span class="post-sheet-meta">{sample.meta}</span>
        </div>
        <div class="post-sheet-list">
          {sample.rows.map((row, i) => (
            <div class:list={['ds-sheet-item', { 'sheet-active': i === sample.activeIndex }]}>
              <a href="#anatomy"><span class="sheet-num">{i + 1}</span>{row}</a>
            </div>
          ))}
        </div>
      </div>
    </SpecimenCard>
  </section>

  <section id="desktop">
    <h2>{s.desktopHeading}</h2>
    <p>{s.desktopBody}</p>
  </section>

  <section id="rules">
    <h2>{s.rulesHeading}</h2>
    <div class="ds-guidance-grid">
      <GuidanceCard kind="do" label={d.doLabel} caption={s.dos[0]}>
        <div class="ds-sheet ds-sheet-mini">
          <div class="post-sheet-grabber"></div>
          <div class="post-sheet-list">
            {sample.rows.slice(0, 3).map((row, i) => (
              <div class:list={['ds-sheet-item', { 'sheet-active': i === 1 }]}>
                <a href="#rules"><span class="sheet-num">{i + 1}</span>{row}</a>
              </div>
            ))}
          </div>
        </div>
      </GuidanceCard>
      <GuidanceCard kind="dont" label={d.dontLabel} caption={s.donts[0]}>
        <div class="ds-sheet ds-sheet-mini">
          <div class="post-sheet-grabber"></div>
          <div class="post-sheet-list">
            <div class="ds-sheet-item"><a href="#rules"><span class="sheet-num">1</span>OK</a></div>
            <div class="ds-sheet-item"><a href="#rules"><span class="sheet-num">2</span>Cancel</a></div>
          </div>
        </div>
      </GuidanceCard>

      <GuidanceCard kind="do" label={d.doLabel} caption={s.dos[1]}>
        <div class="ds-sheet ds-sheet-mini">
          <div class="post-sheet-list">
            <div class="ds-sheet-item"><a href="#rules"><span class="sheet-num">1</span>{sample.rows[0]}</a></div>
          </div>
        </div>
      </GuidanceCard>
      <GuidanceCard kind="dont" label={d.dontLabel} caption={s.donts[1]}>
        <div class="ds-sheet ds-sheet-mini">
          <div class="post-sheet-list">
            <div class="ds-sheet-item ds-cramped"><a href="#rules"><span class="sheet-num">1</span>{sample.rows[0]}</a></div>
            <div class="ds-sheet-item ds-cramped"><a href="#rules"><span class="sheet-num">2</span>{sample.rows[1]}</a></div>
          </div>
        </div>
      </GuidanceCard>

      <GuidanceCard kind="do" label={d.doLabel} caption={s.dos[2]}>
        <div class="ds-backdrop-mock">
          <div class="ds-sheet ds-sheet-mini ds-sheet-low">
            <div class="post-sheet-grabber"></div>
          </div>
        </div>
      </GuidanceCard>
      <GuidanceCard kind="dont" label={d.dontLabel} caption={s.donts[2]}>
        <div class="ds-backdrop-mock ds-backdrop-locked">
          <div class="ds-sheet ds-sheet-mini ds-sheet-low">
            <div class="post-sheet-grabber"></div>
          </div>
        </div>
      </GuidanceCard>
    </div>
    <h3>{s.whereHeading}</h3>
    <p>{s.whereBody}</p>
  </section>
</DesignLayout>

<style>
  /* The sheet PANEL is position:fixed and spring-animated in the app; here it
     sits still so its contents can be read. The row/grabber/head classes are
     the real ones from global.css. */
  .ds-sheet {
    width: 100%;
    max-width: 380px;
    margin: 0 auto;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 20px 20px 12px 12px;
    box-shadow: var(--sheet-shadow);
  }
  .ds-sheet-mini { max-width: 260px; }
  .ds-sheet-low { min-height: 44px; }
  /* The DON'T: rows squeezed under the 48px floor. */
  .ds-cramped a { min-height: 30px; padding-top: 3px; padding-bottom: 3px; }
  /* Backdrop mock: the real backdrop dim (rgba 0,0,0,.45) with the panel at
     the bottom. There is no visible close control on the site — tapping the
     backdrop itself dismisses, which is what the caption states. */
  .ds-backdrop-mock {
    position: relative;
    width: 100%;
    max-width: 260px;
    height: 120px;
    border-radius: 10px;
    background: rgba(0, 0, 0, 0.45);
    display: flex;
    align-items: flex-end;
    padding: 8px;
  }
  .ds-backdrop-locked { outline: 2px dashed #e53e3e; outline-offset: 2px; }
</style>
