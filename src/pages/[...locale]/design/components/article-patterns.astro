---
import { readFileSync } from 'node:fs';
import { md } from '../../../../lib/inline-markup';
import { resolve } from 'node:path';
import { Code } from 'astro:components';
import SpecimenCard from '../../../../components/design/SpecimenCard.astro';
import DesignLayout from '../../../../components/design/DesignLayout.astro';
import MediaZoom from '../../../../components/MediaZoom.astro';
import SubscribeForm from '../../../../components/SubscribeForm.astro';
import Toc from '../../../../components/blog/Toc.astro';
import { t, getLocalePath, localeStaticPaths, type Locale } from '../../../../i18n/index';
import { getDesignData } from '../../../../lib/design-data';

export const getStaticPaths = localeStaticPaths;

// A real pre-rendered diagram from a published article, inlined with the
// exact markup the rehype plugin emits on post pages — so the global.css
// theming and MediaZoom's fullscreen control apply unchanged.
const diagramSvg = readFileSync(
  resolve(process.cwd(), 'src/generated/mermaid/9f5da757f9a0.svg'),
  'utf8',
);

const { locale } = Astro.props as { locale: Locale };
const d = getDesignData(locale);
const a = d.articlePatterns;
const i18n = t(locale);
const currentPath = getLocalePath(locale, '/design/components/article-patterns/');
const cs = a.calloutSamples;

// The Toc specimen's headings point back at this page's own Contents section,
// so a tap goes somewhere real.
const tocHeadings = a.contentsRows.map((text) => ({ slug: 'contents', text, depth: 2 }));
---

<DesignLayout
  locale={locale}
  currentPath={currentPath}
  seoTitle={a.seoTitle}
  seoDescription={a.seoDescription}
  group="components"
  title={a.title}
  intro={a.intro}
  toc={a.toc}
>
  <section id="callouts">
    <h2>{a.calloutsHeading}</h2>
    <p set:html={md(a.calloutsBody)} />
    <div class="prose ds-prose-demo">
      <blockquote class="callout callout-danger"><p set:html={md(cs.danger)} /></blockquote>
      <blockquote class="callout callout-tip"><p set:html={md(cs.tip)} /></blockquote>
      <blockquote class="callout callout-warning"><p set:html={md(cs.warning)} /></blockquote>
      <blockquote class="callout callout-info"><p set:html={md(cs.info)} /></blockquote>
    </div>
  </section>

  <section id="quote">
    <h2>{a.quoteHeading}</h2>
    <p set:html={md(a.quoteBody)} />
    <div class="prose ds-prose-demo">
      <blockquote><p set:html={md(a.quoteSample)} /></blockquote>
    </div>
  </section>

  <section id="code">
    <h2>{a.codeHeading}</h2>
    <p set:html={md(a.codeBody)} />
    <div class="prose ds-prose-demo">
      <p>{a.codeInlineNote} <code>getDesignTokens()</code>.</p>
      <div class="code-block-wrapper">
        <div class="code-block-header">
          <span class="code-block-lang">{a.codeSampleLang}</span>
        </div>
        <!-- Shiki-highlighted like a real article block, line numbers included. -->
        <Code code={a.codeSample} lang="tsx" themes={{ light: 'github-light', dark: 'github-dark' }} />
      </div>
    </div>
    <p set:html={md(a.codeFilenameNote)} />
  </section>

  <section id="tables">
    <h2>{a.tablesHeading}</h2>
    <p set:html={md(a.tablesBody)} />
    <div class="prose ds-prose-demo">
      <!-- 1. Classic table card: sticky first column, mono header strip. -->
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>{a.tableClassic.headers.map((h) => <th>{h}</th>)}</tr>
          </thead>
          <tbody>
            {a.tableClassic.rows.map((row) => (
              <tr>{row.map((cell) => <td>{cell}</td>)}</tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- 2. Score rows. -->
      <div class="dt-card">
        <div class="dt-head dt-head-between">
          <span class="dt-kicker dt-kicker-green">{a.tableScore.kicker}</span>
          <span class="dt-title">{a.tableScore.title}</span>
        </div>
        <div class="dt-rows">
          {a.tableScore.rows.map((r) => (
            <div class="dt-score-row">
              <span class="dt-score-num">{r.num}</span>
              <span class="dt-score-desc">{r.desc}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- 3. Observable checklist. -->
      <div class="dt-card">
        <div class="dt-head dt-head-between">
          <span class="dt-kicker dt-kicker-green">{a.tableChecklist.kicker}</span>
          <span class="dt-title">{a.tableChecklist.title}</span>
        </div>
        <div class="dt-checklist">
          {a.tableChecklist.items.map((item) => (
            <div class:list={['dt-check-row', { 'dt-check-unchecked': !item.checked }]}>
              {item.checked ? (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-green)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              ) : (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle></svg>
              )}
              <span>{item.text}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- 4. Range bands. -->
      <div class="dt-card">
        <div class="dt-head dt-head-between">
          <span class="dt-kicker dt-kicker-green">{a.tableSample.kicker}</span>
          <span class="dt-title">{a.tableSample.title}</span>
        </div>
        <div class="dt-rows">
          {a.tableSample.rows.map((r) => (
            <div class="dt-range-row">
              <div class="dt-range-top">
                <span class="dt-range-name">{r.name}</span>
                <span class="dt-range-val">{r.val}</span>
              </div>
              <div class="dt-range-track"><div class="dt-range-fill" style={`width:${r.fill}%`}></div></div>
            </div>
          ))}
        </div>
      </div>

      <!-- 5. Criterion rows with WCAG chips. -->
      <div class="dt-card">
        <div class="dt-head dt-head-between">
          <span class="dt-kicker dt-kicker-green">{a.tableCrit.kicker}</span>
          <span class="dt-title">{a.tableCrit.title}</span>
        </div>
        <div class="dt-rows">
          {a.tableCrit.rows.map((r) => (
            <div class="dt-crit-row">
              <div class="dt-crit-top">
                <span class="dt-crit-name">{r.name}</span>
                <span class="dt-wcag">{r.chip}</span>
              </div>
              <span class="dt-crit-desc">{r.desc}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <section id="minitable">
    <h2>{a.minitableHeading}</h2>
    <p set:html={md(a.minitableBody)} />
    <div class="table-mini-wrap">
      <table class="table-mini">
        <thead><tr><th>Token</th><th>Light</th><th>Dark</th></tr></thead>
        <tbody>
          <tr><td class="mono-cell">--color-green</td><td>#6dc402</td><td>#6dc402</td></tr>
          <tr><td class="mono-cell">--bg-primary</td><td>#ffffff</td><td>#111111</td></tr>
        </tbody>
      </table>
    </div>
    <p set:html={md(a.stackBody)} />
    <div class="table-mini-wrap">
      <table class="table-mini table-stack">
        <thead><tr><th>Token</th><th>Desktop</th><th>Tablet</th><th>Mobile</th></tr></thead>
        <tbody>
          <tr>
            <td class="stack-lead"><code class="ds-code">--fs-h1</code></td>
            <td data-label="Desktop">34px</td>
            <td data-label="Tablet">32px</td>
            <td data-label="Mobile">30px</td>
          </tr>
          <tr>
            <td class="stack-lead"><code class="ds-code">--fs-body</code></td>
            <td data-label="Desktop">17px</td>
            <td data-label="Tablet">15px</td>
            <td data-label="Mobile">14px</td>
          </tr>
        </tbody>
      </table>
    </div>
    <SpecimenCard code={a.stackCode} lang="html" />
  </section>

  <section id="advice">
    <h2>{a.adviceHeading}</h2>
    <p set:html={md(a.adviceBody)} />
    <div class="dodont-grid">
      <figure class="dodont dodont-do">
        <p class="dodont-head">{d.doLabel}</p>
        <div class="dodont-stage"><span class="ds-plain-text">{a.adviceDemoDo}</span></div>
        <figcaption class="dodont-caption">{a.adviceDemoDo}</figcaption>
      </figure>
      <figure class="dodont dodont-dont">
        <p class="dodont-head">{d.dontLabel}</p>
        <div class="dodont-stage"><span class="ds-plain-text">{a.adviceDemoDont}</span></div>
        <figcaption class="dodont-caption">{a.adviceDemoDont}</figcaption>
      </figure>
    </div>
    <SpecimenCard code={a.adviceCode} lang="html" />
  </section>

  <section id="compare">
    <h2>{a.compareHeading}</h2>
    <p set:html={md(a.compareBody)} />
    <ul class="compare-grid">
      <li class="compare-col compare-yes">
        <p class="compare-head">{d.doLabel}</p>
        <ul><li>compare-yes</li></ul>
      </li>
      <li class="compare-col compare-no">
        <p class="compare-head">{d.dontLabel}</p>
        <ul><li>compare-no</li></ul>
      </li>
    </ul>
  </section>

  <section id="lists">
    <h2>{a.listsHeading}</h2>
    <p set:html={md(a.listsBody)} />
    <div class="prose ds-prose-demo">
      <hr />
    </div>
    <ul class="dot-list">
      <li>{a.listsHeading}</li>
      <li>{a.compareHeading}</li>
    </ul>
  </section>

  <section id="diagrams">
    <h2>{a.diagramsHeading}</h2>
    <p set:html={md(a.diagramsBody)} />
    <div class="prose ds-prose-demo">
      <pre class="mermaid" data-processed="true" data-prerendered="true" set:html={diagramSvg}></pre>
    </div>
  </section>

  <section id="contents">
    <h2>{a.contentsHeading}</h2>
    <p set:html={md(a.contentsBody)} />
    <div class="ds-static-demo ds-toc-demo">
      <Toc label={i18n.blog.contents} headings={tocHeadings} />
    </div>
  </section>

  <section id="series-nav">
    <h2>{a.seriesNavHeading}</h2>
    <p set:html={md(a.seriesNavBody)} />
    <aside class="series-nav" aria-label={a.seriesNavSeries}>
      <div class="series-nav-head">
        <p class="series-nav-heading">
          <strong>{a.seriesNavSeries}</strong>
          <span class="series-nav-part">{a.seriesNavPart}</span>
        </p>
        <!-- Desktop arrow controls (≥1280); the site's JS reveals them when
             the shelf scrolls, so the specimen shows them revealed. -->
        <div class="series-nav-arrows">
          <button type="button" class="series-nav-arrow" aria-label={i18n.blog.previous}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <button type="button" class="series-nav-arrow" aria-label={i18n.blog.next}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>
        </div>
      </div>
      <ol class="series-nav-list">
        {a.seriesNavTitles.map((title, i) => {
          const isCurrent = i === 2;
          const num = String(i + 1).padStart(2, '0');
          return (
            <li class={isCurrent ? 'series-current' : ''} aria-current={isCurrent ? 'step' : undefined}>
              {isCurrent ? (
                <span class="series-card-inner">
                  <span class="series-card-num" aria-hidden="true">{num}</span>
                  <span class="series-card-title">{title}</span>
                </span>
              ) : (
                <a class="series-card-inner" href="#series-nav">
                  <span class="series-card-num" aria-hidden="true">{num}</span>
                  <span class="series-card-title">{title}</span>
                </a>
              )}
            </li>
          );
        })}
      </ol>
    </aside>
  </section>

  <section id="subscribe">
    <h2>{a.subscribeHeading}</h2>
    <p set:html={md(a.subscribeBody)} />
    <div class="ds-subscribe-demo">
      <SubscribeForm locale={locale} variant="design" />
    </div>
    <h3>{a.whereHeading}</h3>
    <p set:html={md(a.whereBody)} />
  </section>

  <MediaZoom locale={locale} />
</DesignLayout>

<style>
  /* Let the demo prose blocks size to the content column, not the 720px reading
     measure (that only applies inside .post-layout). */
  .ds-prose-demo { max-width: none; }
  /* On phones the site's code blocks bleed -1rem (full-bleed to the screen
     edge) and dt-cards bleed -6px. The site's column carries 1rem of side
     padding for that; give the demo the same, so the bleeds land exactly at
     the container edge as designed instead of escaping the docs column. */
  @media (max-width: 699px) {
    .ds-prose-demo { padding-inline: 1rem; }
  }
  .ds-toc-demo { max-width: 320px; margin: 0 0 1rem; }
  /* Round off the subscribe band's full-bleed edges inside the docs column. */
  .ds-subscribe-demo {
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }
  .ds-subscribe-demo :global(.subscribe.section) {
    padding-block: 2rem;
  }
</style>
