---
import DesignLayout from '../../../../components/design/DesignLayout.astro';
import { md } from '../../../../lib/inline-markup';
import { getLocalePath, localeStaticPaths, localeNames, type Locale } from '../../../../i18n/index';
import { getDesignData } from '../../../../lib/design-data';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.props as { locale: Locale };
const d = getDesignData(locale);
const tr = d.translation;
const currentPath = getLocalePath(locale, '/design/content/translation/');

// Locale/path/language are structural facts (codes and prefixes), not prose.
const localeRows: { code: string; path: string }[] = [
  { code: 'en', path: tr.localesRoot },
  { code: 'es', path: '/es/' },
  { code: 'ca', path: '/ca/' },
  { code: 'tl', path: '/tl/' },
];
---

<DesignLayout
  locale={locale}
  currentPath={currentPath}
  seoTitle={tr.seoTitle}
  seoDescription={tr.seoDescription}
  group="content"
  title={tr.title}
  intro={tr.intro}
  toc={tr.toc}
>
  <section id="locales">
    <h2>{tr.localesHeading}</h2>
    <p set:html={md(tr.localesBody)} />
    <div class="table-mini-wrap">
      <table class="table-mini">
        <thead>
          <tr>
            <th>{tr.localesTableHeaders.locale}</th>
            <th>{tr.localesTableHeaders.prefix}</th>
            <th>{tr.localesTableHeaders.language}</th>
          </tr>
        </thead>
        <tbody>
          {localeRows.map((r) => (
            <tr>
              <td class="mono-cell">{r.code}</td>
              <td class="mono-cell">{r.path}</td>
              <td>{localeNames[r.code as Locale]}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section id="scope">
    <h2>{tr.scopeHeading}</h2>
    <p set:html={md(tr.scopeBody)} />
    <div class="compare-grid">
      <div class="compare-col compare-yes">
        <p class="compare-head">{tr.scopeTableHeaders.translated}</p>
        <ul>{tr.scopeTranslated.map((x) => <li set:html={md(x)} />)}</ul>
      </div>
      <div class="compare-col compare-no">
        <p class="compare-head">{tr.scopeTableHeaders.kept}</p>
        <ul>{tr.scopeKept.map((x) => <li set:html={md(x)} />)}</ul>
      </div>
    </div>
    <p set:html={md(tr.scopeNote)} />
  </section>

  <section id="voice">
    <h2>{tr.voiceHeading}</h2>
    <p set:html={md(tr.voiceBody)} />
    <h3>{tr.angliHeading}</h3>
    <p set:html={md(tr.angliBody)} />
    <h3>{tr.taglishHeading}</h3>
    <p set:html={md(tr.taglishBody)} />
    <h3>{tr.fillerHeading}</h3>
    <p set:html={md(tr.fillerBody)} />
  </section>

</DesignLayout>

<style>

    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 0 0 1.5rem;
  }
  @media (min-width: 700px) {
  }
</style>
