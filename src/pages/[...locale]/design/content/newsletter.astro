---
import DesignLayout from '../../../../components/design/DesignLayout.astro';
import { md } from '../../../../lib/inline-markup';
import SpecimenCard from '../../../../components/design/SpecimenCard.astro';
import { getLocalePath, localeStaticPaths, type Locale } from '../../../../i18n/index';
import { getDesignData } from '../../../../lib/design-data';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.props as { locale: Locale };
const d = getDesignData(locale);
const n = d.newsletter;
const currentPath = getLocalePath(locale, '/design/content/newsletter/');
---

<DesignLayout
  locale={locale}
  currentPath={currentPath}
  seoTitle={n.seoTitle}
  seoDescription={n.seoDescription}
  group="content"
  title={n.title}
  intro={n.intro}
  toc={n.toc}
>
  <section id="design">
    <h2>{n.designHeading}</h2>
    <p set:html={md(n.designBody1)} />
    <p set:html={md(n.designBody2)} />
    <SpecimenCard label={n.mockLabel}>
      <!-- A static reconstruction of the email (the real thing is HTML mail,
           not a site component). Literal light-theme colours on purpose. -->
      <div class="ds-mail-stage" aria-hidden="true">
        <p class="ds-mail-subject"><span>{n.mockSubjectLabel}</span> {n.mockSubject}</p>
        <div class="ds-mail-card">
          <div class="ds-mail-accent"></div>
          <div class="ds-mail-brand">warrendeleon<span>.</span>com</div>
          <div class="ds-mail-content">
            <p class="ds-mail-eyebrow">{n.mockEyebrow}</p>
            <p class="ds-mail-title">{n.mockTitle}</p>
            <p class="ds-mail-desc">{n.mockDesc}</p>
            <p class="ds-mail-btn">{n.mockButton}</p>
            <p class="ds-mail-nav">{n.mockNav}</p>
          </div>
        </div>
      </div>
    </SpecimenCard>
  </section>

  <section id="copy">
    <h2>{n.copyHeading}</h2>
    <p set:html={md(n.copyBody1)} />
    <ul class="ds-list">
      {n.copyRules.map((r) => <li set:html={md(r)} />)}
    </ul>
  </section>
</DesignLayout>

<style>
  /* The email mock: the template's own literal values (600px card scaled to
     the column, #f5f5f7 ground, 4px lime accent, 14px corners, #5aa302 links,
     #4a8601 button). Light-fixed, as the prose explains. */
  .ds-mail-stage {
    width: 100%;
    max-width: 480px;
    background: #f5f5f7;
    border-radius: 10px;
    padding: 20px;
  }
  .ds-mail-subject {
    margin: 0 0 12px;
    font-size: 0.85rem;
    color: #0e0c19;
    font-weight: 600;
  }
  .ds-mail-subject span {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #666666;
    margin-right: 6px;
  }
  .ds-mail-card {
    background: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 14px;
    overflow: hidden;
  }
  .ds-mail-accent { height: 4px; background: #6dc402; }
  .ds-mail-brand {
    padding: 14px 20px 12px;
    border-bottom: 1px solid #e0e0e0;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #0e0c19;
    font-size: 1rem;
  }
  .ds-mail-brand span { color: #6dc402; }
  .ds-mail-content { padding: 18px 20px; }
  .ds-mail-eyebrow {
    margin: 0 0 8px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #5aa302;
  }
  .ds-mail-title {
    margin: 0 0 8px;
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.3;
    color: #0e0c19;
  }
  .ds-mail-desc {
    margin: 0 0 14px;
    font-size: 0.88rem;
    line-height: 1.65;
    color: #0e0c19;
  }
  .ds-mail-btn {
    display: inline-block;
    margin: 0 0 14px;
    background: #4a8601;
    color: #ffffff;
    font-weight: 700;
    font-size: 0.88rem;
    padding: 11px 18px;
    border-radius: 10px;
  }
  .ds-mail-nav {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.6;
    color: #0e0c19;
  }
</style>
