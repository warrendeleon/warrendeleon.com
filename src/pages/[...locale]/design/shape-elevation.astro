---
import DesignLayout from '../../../components/design/DesignLayout.astro';
import { md } from '../../../lib/inline-markup';
import SwatchTable from '../../../components/design/SwatchTable.astro';
import { getLocalePath, localeStaticPaths, type Locale } from '../../../i18n/index';
import { getDesignData } from '../../../lib/design-data';
import { getDesignTokens } from '../../../lib/design-tokens.mjs';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.props as { locale: Locale };
const d = getDesignData(locale);
const se = d.shapeElevation;
const currentPath = getLocalePath(locale, '/design/shape-elevation/');
const shadows = getDesignTokens().shadows;

// A visual sample of the radius scale (values are literals from the CSS).
const radiusChips = [5, 8, 12, 16, 20];
---

<DesignLayout
  locale={locale}
  currentPath={currentPath}
  seoTitle={se.seoTitle}
  seoDescription={se.seoDescription}
  group="foundations"
  title={se.title}
  intro={se.intro}
  toc={se.toc}
>
  <section id="radius">
    <h2>{se.radiusHeading}</h2>
    <p set:html={md(se.radiusBody)} />
    <div class="ds-radius-chips">
      {radiusChips.map((r) => (
        <div class="ds-radius-chip">
          <span class="ds-radius-box" style={`border-radius:${r}px`}></span>
          <span class="ds-radius-val">{r}px</span>
        </div>
      ))}
    </div>
    <div class="table-mini-wrap">
      <table class="table-mini">
        <thead>
          <tr>
            <th>{se.radiusHeaders.radius}</th>
            <th>{se.radiusHeaders.where}</th>
          </tr>
        </thead>
        <tbody>
          {se.radiusRows.map((r) => (
            <tr>
              <td class="mono-cell">{r.radius}</td>
              <td>{r.where}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p set:html={md(se.radiusNote)} />
  </section>

  <section id="shadows">
    <h2>{se.shadowsHeading}</h2>
    <p set:html={md(se.shadowsBody)} />
    <SwatchTable rows={shadows} kind="shadow" usage={se.shadowsUsage} headers={se.shadowsHeaders} copyLabel={d.copyLabel} />
  </section>

  <section id="borders">
    <h2>{se.bordersHeading}</h2>
    <p set:html={md(se.bordersBody)} />
  </section>
</DesignLayout>

<style>
  .ds-radius-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin: 0 0 1.5rem;
  }
  .ds-radius-chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }
  .ds-radius-box {
    display: block;
    width: 60px;
    height: 60px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    box-shadow: var(--shadow-card);
  }
  .ds-radius-val {
    font-size: 0.72rem;
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    color: var(--text-muted);
  }
</style>
