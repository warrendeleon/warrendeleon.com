---
import DesignLayout from '../../../components/design/DesignLayout.astro';
import SwatchTable from '../../../components/design/SwatchTable.astro';
import { getLocalePath, localeStaticPaths, type Locale } from '../../../i18n/index';
import { getDesignData } from '../../../lib/design-data';
import { getDesignTokens } from '../../../lib/design-tokens.mjs';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.props as { locale: Locale };
const d = getDesignData(locale);
const se = d.shapeElevation;
const currentPath = getLocalePath(locale, '/design/shape-elevation/');
const shadows = getDesignTokens().shadows;

// A visual sample of the radius scale (values are literals from the CSS).
const radiusChips = [5, 8, 12, 16, 20];
---

<DesignLayout
  locale={locale}
  currentPath={currentPath}
  seoTitle={se.seoTitle}
  seoDescription={se.seoDescription}
  group="foundations"
  title={se.title}
  intro={se.intro}
  toc={se.toc}
>
  <section id="radius">
    <h2>{se.radiusHeading}</h2>
    <p>{se.radiusBody}</p>
    <div class="ds-radius-chips">
      {radiusChips.map((r) => (
        <div class="ds-radius-chip">
          <span class="ds-radius-box" style={`border-radius:${r}px`}></span>
          <span class="ds-radius-val">{r}px</span>
        </div>
      ))}
    </div>
    <div class="ds-tablewrap">
      <table class="ds-mini">
        <thead>
          <tr>
            <th>{se.radiusHeaders.radius}</th>
            <th>{se.radiusHeaders.where}</th>
          </tr>
        </thead>
        <tbody>
          {se.radiusRows.map((r) => (
            <tr>
              <td class="ds-mono">{r.radius}</td>
              <td>{r.where}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p>{se.radiusNote}</p>
  </section>

  <section id="shadows">
    <h2>{se.shadowsHeading}</h2>
    <p>{se.shadowsBody}</p>
    <SwatchTable rows={shadows} kind="shadow" usage={se.shadowsUsage} headers={se.shadowsHeaders} copyLabel={d.copyLabel} />
  </section>

  <section id="borders">
    <h2>{se.bordersHeading}</h2>
    <p>{se.bordersBody}</p>
  </section>
</DesignLayout>

<style>
  .ds-radius-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin: 0 0 1.5rem;
  }
  .ds-radius-chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }
  .ds-radius-box {
    display: block;
    width: 60px;
    height: 60px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    box-shadow: var(--shadow-card);
  }
  .ds-radius-val {
    font-size: 0.72rem;
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    color: var(--text-muted);
  }
  .ds-tablewrap {
    overflow-x: auto;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    margin: 0 0 1.5rem;
  }
  .ds-mini {
    width: 100%;
    min-width: 100%;
    border-collapse: collapse;
  }
  .ds-mini th {
    text-align: left;
    padding: 10px 14px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    color: var(--text-muted);
    background: var(--badge-bg);
    border-bottom: 1px solid var(--border-color);
    white-space: nowrap;
  }
  .ds-mini td {
    padding: 10px 14px;
    font-size: 0.85rem;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-secondary);
    vertical-align: middle;
  }
  .ds-mini tbody tr:last-child td { border-bottom: none; }
  .ds-mono {
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    font-size: 0.8rem;
    color: var(--text-primary);
    white-space: nowrap;
  }
</style>
