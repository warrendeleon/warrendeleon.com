---
import DesignLayout from '../../../components/design/DesignLayout.astro';
import { md } from '../../../lib/inline-markup';
import Shelf from '../../../components/blog/Shelf.astro';
import { t, getLocalePath, localeStaticPaths, type Locale } from '../../../i18n/index';
import { getDesignData } from '../../../lib/design-data';
import { DESIGN_GROUPS } from '../../../lib/design-ia';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.props as { locale: Locale };
const d = getDesignData(locale);
const i18n = t(locale);
const L = d.landing;
const currentPath = getLocalePath(locale, '/design/');

// One card list per IA group, blurbs pulled from the matching landing map.
const blurbMaps: Record<string, Record<string, string>> = {
  foundations: L.cardBlurbs,
  components: L.componentBlurbs,
  content: L.contentBlurbs,
  accessibility: L.accessibilityBlurbs,
};
const groupCards = (key: string) => {
  const g = DESIGN_GROUPS.find((x) => x.key === key)!;
  const blurbs = blurbMaps[key] ?? {};
  return g.pages
    .filter((p) => p.built)
    .map((p) => ({
      slug: p.slug,
      label: d.nav[p.slug as keyof typeof d.nav],
      blurb: blurbs[p.slug],
      href: getLocalePath(locale, p.path),
    }));
};

const sections = [
  { id: 'foundations', heading: L.foundationsHeading, cards: groupCards('foundations') },
  { id: 'components', heading: L.componentsHeading, cards: groupCards('components') },
  { id: 'content', heading: L.contentHeading, cards: groupCards('content') },
  { id: 'accessibility', heading: L.accessibilityHeading, cards: groupCards('accessibility') },
].filter((s) => s.cards.length > 0);

// Feather-style line icons (24 grid, 2px stroke, currentColor — the site's
// own icon language) for the principles and for foundations, content and
// accessibility cards.
const PRINCIPLE_ICONS = [
  '<path d="M11 5L6 9H2v6h4l5 4zM23 9l-6 6M17 9l6 6"></path>',
  '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>',
  '<polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline>',
];

const ICONS: Record<string, string> = {
  colour: '<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path>',
  typography: '<polyline points="4 7 4 4 20 4 20 7"></polyline><line x1="9" y1="20" x2="15" y2="20"></line><line x1="12" y1="4" x2="12" y2="20"></line>',
  layout: '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line>',
  'shape-elevation': '<polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline>',
  iconography: '<path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"></path><line x1="16" y1="8" x2="2" y2="22"></line><line x1="17.5" y1="15" x2="9" y2="15"></line>',
  motion: '<path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"></path>',
  writing: '<path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>',
  translation: '<circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>',
  newsletter: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline>',
  accessibility: '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>',
};

// Component cards carry miniature token-drawn vignettes instead of icons —
// the same abstract-mock language the guidance cards use. Decorative only.
const VIGNETTES: Record<string, string> = {
  buttons: '<span class="vg-pill vg-solid"></span><span class="vg-pill vg-outline"></span>',
  'tags-chips': '<span class="vg-chip"></span><span class="vg-chip vg-chip-wide"></span><span class="vg-chip"></span>',
  cards: '<span class="vg-minicard"><span class="vg-thumb"></span><span class="vg-lines"><span class="vg-line"></span><span class="vg-line vg-line-short"></span></span></span>',
  navigation: '<span class="vg-dock">' + '<span class="vg-tab"><span class="vg-dot"></span><span class="vg-line"></span></span>'.repeat(4) + '</span>',
  'sheets-overlays': '<span class="vg-backdrop"><span class="vg-sheet"><span class="vg-grabber"></span></span></span>',
  'article-patterns': '<span class="vg-article"><span class="vg-line"></span><span class="vg-callout"></span><span class="vg-line vg-line-short"></span></span>',
  timeline: '<span class="vg-rail"><span class="vg-ring"></span><span class="vg-ring"></span></span>',
  media: '<span class="vg-frame"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg></span>',
};
---

<DesignLayout
  locale={locale}
  currentPath={currentPath}
  seoTitle={L.seoTitle}
  seoDescription={L.seoDescription}
  title={L.title}
  intro={L.intro}
>
  <section id="principles">
    <h2>{L.principlesHeading}</h2>
    <div class="ds-principles">
      {L.principles.map((p, i) => (
        <div class="ds-principle">
          <div class="ds-principle-head">
            <svg class="ds-principle-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={PRINCIPLE_ICONS[i]} />
            <h3>{p.title}</h3>
          </div>
          <p set:html={md(p.body)} />
        </div>
      ))}
    </div>
  </section>

  <!-- Each group rides the site's real Shelf carousel (the blog's More-series
       shell): horizontal scroll with arrows, so the hub stays short on a phone. -->
  {sections.map((s) => (
    <section id={s.id} class="ds-group-shelf">
      <Shelf heading={s.heading} labelPrev={i18n.blog.previous} labelNext={i18n.blog.next}>
        {s.cards.map((c) => (
          <a href={c.href} class="card icon-card ds-card-link">
            {VIGNETTES[c.slug] && (
              <span class="ds-card-vig" aria-hidden="true" set:html={VIGNETTES[c.slug]} />
            )}
            <span class="icon-card-head">
              {ICONS[c.slug] && (
                <svg class="icon-card-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ICONS[c.slug]} />
              )}
              <span class="icon-card-title">{c.label}</span>
            </span>
            <span class="ds-card-blurb">{c.blurb}</span>
          </a>
        ))}
      </Shelf>
    </section>
  ))}

  <section id="living">
    <h2>{L.livingHeading}</h2>
    <p set:html={md(L.livingBody)} />
  </section>
</DesignLayout>

<style>
  /* The hub is a listing page, so its headings follow Blog home's pattern
     (the shelf heading: 1.6rem, no underline) — the underlined article
     heading belongs to the content pages. */
  :global(.ds-body > section > h2) {
    font-size: 1.6rem;
    letter-spacing: -0.015em;
    line-height: 1.2;
    border-bottom: none;
    padding-bottom: 0;
    display: block;
  }

  .ds-principles {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 700px) {
    .ds-principles { grid-template-columns: repeat(3, 1fr); }
  }
  .ds-principle {
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--bg-card);
    padding: 1.25rem;
  }
  .ds-principle-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
  }
  .ds-principle-icon { flex-shrink: 0; color: var(--color-green-text); }
  .ds-principle h3 {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-green-text);
  }
  .ds-principle p {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  /* Shelf cards: fixed width in the scroll track (the series-card pattern),
     equal heights via the track's default stretch. No margin override here:
     the shared 3rem section rhythm applies, same as every other section
     (a scoped 0.5rem out-specified it and crushed the hub's breathing room). */
  /* The real .card carries the surface (border, radius, shadow, padding);
     this modifier only adds the link layout and the whole-card hover the
     feed cards use (lift + green title). */
  .ds-card-link { width: 280px; flex: none; }
  @media (max-width: 760px) {
    .ds-card-link { width: 230px; }
  }

  /* Component-card vignettes: miniature token drawings on a specimen stage —
     the same abstract-mock language the guidance cards use. */
  .ds-card-vig {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 72px;
    margin-bottom: 0.85rem;
    border-radius: 10px;
    background: var(--bg-secondary);
    color: var(--text-muted);
  }
  .ds-card-vig :global(.vg-pill) { width: 58px; height: 20px; border-radius: 10px; }
  .ds-card-vig :global(.vg-solid) { background: var(--color-green); }
  .ds-card-vig :global(.vg-outline) { border: 2px solid var(--color-green); }
  .ds-card-vig :global(.vg-chip) { width: 30px; height: 14px; border-radius: 5px; background: var(--badge-bg); border: 1px solid var(--border-color); }
  .ds-card-vig :global(.vg-chip-wide) { width: 44px; }
  .ds-card-vig :global(.vg-minicard) { display: flex; align-items: center; gap: 8px; padding: 8px 10px; border: 1px solid var(--border-color); border-radius: 9px; background: var(--bg-card); }
  .ds-card-vig :global(.vg-thumb) { width: 26px; height: 22px; border-radius: 5px; background: var(--badge-bg); }
  .ds-card-vig :global(.vg-lines) { display: flex; flex-direction: column; gap: 4px; }
  .ds-card-vig :global(.vg-line) { width: 56px; height: 6px; border-radius: 3px; background: var(--badge-bg); }
  .ds-card-vig :global(.vg-line-short) { width: 36px; }
  .ds-card-vig :global(.vg-dock) { display: flex; gap: 12px; padding: 8px 12px; border: 1px solid var(--border-color); border-radius: 12px; background: var(--bg-card); }
  .ds-card-vig :global(.vg-tab) { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .ds-card-vig :global(.vg-dot) { width: 12px; height: 12px; border-radius: 4px; border: 1.5px solid var(--text-muted); }
  .ds-card-vig :global(.vg-tab .vg-line) { width: 16px; height: 4px; }
  .ds-card-vig :global(.vg-tab:first-child .vg-dot) { border-color: var(--color-green); }
  .ds-card-vig :global(.vg-backdrop) { display: flex; align-items: flex-end; width: 100px; height: 48px; padding: 4px; border-radius: 8px; background: rgba(0, 0, 0, 0.4); }
  .ds-card-vig :global(.vg-sheet) { display: flex; justify-content: center; width: 100%; height: 26px; border-radius: 8px 8px 4px 4px; background: var(--bg-card); }
  .ds-card-vig :global(.vg-grabber) { width: 18px; height: 3px; margin-top: 4px; border-radius: 2px; background: var(--border-color); }
  .ds-card-vig :global(.vg-article) { display: flex; flex-direction: column; gap: 5px; }
  .ds-card-vig :global(.vg-callout) { width: 56px; height: 10px; border-radius: 3px; background: var(--badge-bg); border-left: 3px solid var(--color-green); }
  .ds-card-vig :global(.vg-rail) { position: relative; display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 2px 0; }
  .ds-card-vig :global(.vg-rail)::before { content: ''; position: absolute; top: 0; bottom: 0; left: 50%; width: 2px; background: var(--timeline-line); }
  .ds-card-vig :global(.vg-ring) { position: relative; z-index: 1; width: 20px; height: 20px; border-radius: 50%; background: var(--bg-card); border: 1.5px solid var(--color-green); }
  .ds-card-vig :global(.vg-frame) { display: flex; align-items: center; justify-content: center; width: 64px; height: 44px; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-card); }
  .ds-card-blurb {
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--text-secondary);
  }

  .ds-more {
    font-size: 0.95rem !important;
    color: var(--text-secondary);
  }
</style>
