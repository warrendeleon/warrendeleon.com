---
import DesignLayout from '../../../components/design/DesignLayout.astro';
import { getLocalePath, localeStaticPaths, type Locale } from '../../../i18n/index';
import { getDesignData } from '../../../lib/design-data';
import { DESIGN_GROUPS } from '../../../lib/design-ia';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.props as { locale: Locale };
const d = getDesignData(locale);
const L = d.landing;
const currentPath = getLocalePath(locale, '/design/');

const foundations = DESIGN_GROUPS.find((g) => g.key === 'foundations')!;
const cards = foundations.pages
  .filter((p) => p.built)
  .map((p) => ({
    label: d.nav[p.slug as keyof typeof d.nav],
    blurb: L.cardBlurbs[p.slug as keyof typeof L.cardBlurbs],
    href: getLocalePath(locale, p.path),
  }));

const components = DESIGN_GROUPS.find((g) => g.key === 'components')!;
const componentCards = components.pages
  .filter((p) => p.built)
  .map((p) => ({
    label: d.nav[p.slug as keyof typeof d.nav],
    blurb: L.componentBlurbs[p.slug as keyof typeof L.componentBlurbs],
    href: getLocalePath(locale, p.path),
  }));

const toc = [
  { id: 'principles', label: L.principlesHeading },
  { id: 'foundations', label: L.foundationsHeading },
  { id: 'components', label: L.componentsHeading },
  { id: 'living', label: L.livingHeading },
];
---

<DesignLayout
  locale={locale}
  currentPath={currentPath}
  seoTitle={L.seoTitle}
  seoDescription={L.seoDescription}
  title={L.title}
  intro={L.intro}
  toc={toc}
>
  <section id="principles">
    <h2>{L.principlesHeading}</h2>
    <div class="ds-principles">
      {L.principles.map((p) => (
        <div class="ds-principle">
          <h3>{p.title}</h3>
          <p>{p.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section id="foundations">
    <h2>{L.foundationsHeading}</h2>
    <div class="ds-cards">
      {cards.map((c) => (
        <a href={c.href} class="card ds-card-link">
          <span class="ds-card-title">{c.label}</span>
          <span class="ds-card-blurb">{c.blurb}</span>
        </a>
      ))}
    </div>
  </section>

  <section id="components">
    <h2>{L.componentsHeading}</h2>
    <div class="ds-cards">
      {componentCards.map((c) => (
        <a href={c.href} class="card ds-card-link">
          <span class="ds-card-title">{c.label}</span>
          <span class="ds-card-blurb">{c.blurb}</span>
        </a>
      ))}
    </div>
    <p class="ds-more"><strong>{L.moreHeading}.</strong> {L.moreBody}</p>
  </section>

  <section id="living">
    <h2>{L.livingHeading}</h2>
    <p>{L.livingBody}</p>
  </section>
</DesignLayout>

<style>
  .ds-principles {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 700px) {
    .ds-principles { grid-template-columns: repeat(3, 1fr); }
  }
  .ds-principle {
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--bg-card);
    padding: 1.25rem;
  }
  .ds-principle h3 {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-green-text);
  }
  .ds-principle p {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .ds-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 700px) {
    .ds-cards { grid-template-columns: 1fr 1fr; }
  }
  /* The real .card carries the surface (border, radius, shadow, padding);
     this modifier only adds the link layout and the whole-card hover the
     feed cards use (lift + green title). */
  .ds-card-link {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .ds-card-link:hover {
    transform: translateY(-2px);
    border-color: var(--color-green);
  }
  .ds-card-title {
    font-size: 1.02rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .ds-card-link:hover .ds-card-title { color: var(--color-green-text); }
  .ds-card-blurb {
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--text-secondary);
  }

  .ds-more {
    font-size: 0.95rem !important;
    color: var(--text-secondary);
  }
</style>
