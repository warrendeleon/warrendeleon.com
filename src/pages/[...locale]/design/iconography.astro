---
import DesignLayout from '../../../components/design/DesignLayout.astro';
import { md } from '../../../lib/inline-markup';
import SpecimenCard from '../../../components/design/SpecimenCard.astro';
import GuidanceCard from '../../../components/design/GuidanceCard.astro';
import SocialLinks from '../../../components/SocialLinks.astro';
import { getLocalePath, localeStaticPaths, type Locale } from '../../../i18n/index';
import { getDesignData } from '../../../lib/design-data';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.props as { locale: Locale };
const d = getDesignData(locale);
const ic = d.iconography;
const currentPath = getLocalePath(locale, '/design/iconography/');
const lbl = ic.iconLabels;
---

<DesignLayout
  locale={locale}
  currentPath={currentPath}
  seoTitle={ic.seoTitle}
  seoDescription={ic.seoDescription}
  group="foundations"
  title={ic.title}
  intro={ic.intro}
  toc={ic.toc}
>
  <section id="line">
    <h2>{ic.lineHeading}</h2>
    <p set:html={md(ic.lineBody)} />
    <SpecimenCard label={ic.lineCaption}>
      <div class="ds-icons">
        <figure class="ds-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          <figcaption>{lbl.search}</figcaption>
        </figure>
        <figure class="ds-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
          <figcaption>{lbl.back}</figcaption>
        </figure>
        <figure class="ds-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
          <figcaption>{lbl.chevron}</figcaption>
        </figure>
        <figure class="ds-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
          <figcaption>{lbl.download}</figcaption>
        </figure>
        <figure class="ds-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>
          <figcaption>{lbl.rss}</figcaption>
        </figure>
        <figure class="ds-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          <figcaption>{lbl.check}</figcaption>
        </figure>
        <figure class="ds-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          <figcaption>{lbl.close}</figcaption>
        </figure>
      </div>
    </SpecimenCard>

    <!-- Hit area, annotated: the hatched ring is the tappable padding
         between the glyph and the 44px floor. -->
    <figure class="ds-annotated">
      <div class="ds-hitring-row">
        <span class="ds-hitring">
          <span class="ds-hatch ds-hitring-pad" aria-hidden="true"></span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </span>
        <span class="ds-hitring-labels">
          <span class="ds-gap-label">{ic.hitLabels.area} · 44 × 44px</span>
          <span class="ds-gap-label">{ic.hitLabels.glyph} · 20px</span>
          <span class="ds-gap-label">{ic.hitLabels.pad} · 12px</span>
        </span>
      </div>
      <figcaption>{ic.hitCaption}</figcaption>
    </figure>
  </section>

  <section id="brand">
    <h2>{ic.brandHeading}</h2>
    <p set:html={md(ic.brandBody)} />
    <SpecimenCard label={ic.brandCaption}>
      <div class="ds-social-demo">
        <SocialLinks size={24} locale={locale} />
      </div>
    </SpecimenCard>
  </section>

  <section id="rules">
    <h2>{ic.rulesHeading}</h2>
    <div class="dodont-grid">
      <GuidanceCard kind="do" label={ic.doLabel} caption={ic.dos[0]}>
        <span class="ds-ico-row">
          <span class="ds-ico" style="color: var(--text-secondary);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </span>
          <span class="ds-ico" style="color: var(--color-green-text);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </span>
        </span>
      </GuidanceCard>
      <GuidanceCard kind="dont" label={ic.dontLabel} caption={ic.donts[0]}>
        <span class="ds-ico" style="color: #e8590c;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#e8590c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </span>
      </GuidanceCard>

      <GuidanceCard kind="do" label={ic.doLabel} caption={ic.dos[1]}>
        <span class="ds-hit ds-hit-44">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </span>
      </GuidanceCard>
      <GuidanceCard kind="dont" label={ic.dontLabel} caption={ic.donts[2]}>
        <span class="ds-hit ds-hit-16">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </span>
      </GuidanceCard>

      <GuidanceCard kind="do" label={ic.doLabel} caption={ic.dos[2]}>
        <span class="ds-ico-row">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </span>
      </GuidanceCard>
      <GuidanceCard kind="dont" label={ic.dontLabel} caption={ic.donts[1]}>
        <span class="ds-ico-row">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><circle cx="11" cy="11" r="8"></circle></svg>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </span>
      </GuidanceCard>
    </div>
  </section>
</DesignLayout>

<style>
  .ds-ico-row { display: inline-flex; align-items: center; gap: 1.1rem; color: var(--text-primary); }
  /* SocialLinks doesn't wrap by itself (the footer overrides it); let the
     seven 44px hits wrap inside the specimen instead of overflowing at 390.
     The wrapper is page-owned so the scoped selector actually reaches in. */
  .ds-social-demo { max-width: 100%; }
  .ds-social-demo :global(.social-links) {
    flex-wrap: wrap;
    justify-content: center;
  }
  .ds-ico { display: inline-flex; }
  /* Hit-area demos: the dashed outline is the tappable area. */
  .ds-hit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    outline: 2px dashed var(--text-muted);
    outline-offset: 0;
    color: var(--text-primary);
  }
  .ds-hit-44 { width: 44px; height: 44px; }
  .ds-hit-16 { width: 16px; height: 16px; outline-color: #e53e3e; }

  /* Annotated hit area: 44px square, 20px glyph centred, the hatch ring is
     the 12px of tappable padding around it. */
  .ds-hitring-row { display: flex; align-items: center; gap: 1rem; }
  .ds-hitring {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    color: var(--text-primary);
    outline: 1px dashed var(--text-muted);
  }
  .ds-hitring svg { position: relative; z-index: 1; background: var(--bg-card); }
  .ds-hitring-pad { position: absolute; inset: 0; border: none; }
  .ds-hitring-labels { display: flex; flex-direction: column; gap: 2px; }
</style>

<style>
  .ds-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2rem;
    justify-content: center;
  }
  .ds-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    color: var(--text-primary);
  }
  .ds-icon figcaption {
    font-size: 0.68rem;
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    color: var(--text-muted);
  }
  .ds-dodont-list {
    margin: 0;
    padding-left: 1.1rem;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--text-secondary);
  }
  .ds-dodont-list li { margin-bottom: 0.45rem; }
  .ds-dodont-list li:last-child { margin-bottom: 0; }
</style>
