---
import DesignLayout from '../../../components/design/DesignLayout.astro';
import { md } from '../../../lib/inline-markup';
import SwatchTable from '../../../components/design/SwatchTable.astro';
import GuidanceCard from '../../../components/design/GuidanceCard.astro';
import { getLocalePath, localeStaticPaths, type Locale } from '../../../i18n/index';
import { getDesignData } from '../../../lib/design-data';
import { pickColors } from '../../../lib/design-tokens.mjs';
import { getPostsForLocale, shortenSeriesName } from '../../../utils/blogHelpers';
import CopyHex from '../../../components/design/CopyHex.astro';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.props as { locale: Locale };
const d = getDesignData(locale);
const c = d.colour;
const currentPath = getLocalePath(locale, '/design/colour/');
const accessibilityHref = getLocalePath(locale, '/design/accessibility/');
const mediaHref = getLocalePath(locale, '/design/components/media/');

// Illustration colour: the shared hero palette and the per-series grounds,
// read from the published posts so the docs cannot drift and unannounced
// series never leak. getPostsForLocale enforces one ground per series.
const posts = await getPostsForLocale('en', false);
const heroPalette = posts.find(p => p.data.heroPalette)?.data.heroPalette ?? [];
const seriesPastels = new Map<string, string>();
for (const post of posts) {
  if (post.data.series && post.data.heroBgColor && !seriesPastels.has(post.data.series)) {
    seriesPastels.set(post.data.series, post.data.heroBgColor);
  }
}

const greens = pickColors([
  '--color-green',
  '--color-green-dark',
  '--color-green-light',
  '--color-green-text',
  '--color-green-text-hover',
  '--color-white',
]);

const neutrals = pickColors([
  '--bg-primary',
  '--bg-secondary',
  '--bg-card',
  '--bg-nav',
  '--text-primary',
  '--text-secondary',
  '--text-muted',
  '--border-color',
  '--badge-bg',
  '--badge-text',
  '--code-bg',
  '--timeline-line',
  '--device-edge',
  '--device-button',
]);

// Interaction palette — the states are constants in the CSS, so the token
// references live here, not in the translated data.
const interactionRows = [
  { state: c.interactionStates.default, link: '--color-green-text', button: '--color-green' },
  { state: c.interactionStates.hover, link: '--color-green-text-hover', button: '--color-green-dark' },
];

// Callout colours are hard-coded hexes in global.css (prose only), so they are
// documented here as literals rather than parsed tokens.
const calloutRows = [
  { key: 'danger', hex: '#e53e3e' },
  { key: 'tip', hex: '#f59e0b' },
  { key: 'warning', hex: '#d69e2e' },
  { key: 'info', hex: '#3182ce' },
] as const;
---

<DesignLayout
  locale={locale}
  currentPath={currentPath}
  seoTitle={c.seoTitle}
  seoDescription={c.seoDescription}
  group="foundations"
  title={c.title}
  intro={c.intro}
  toc={c.toc}
>
  <section id="brand">
    <h2>{c.brandHeading}</h2>
    <p set:html={md(c.brandBody)} />
    <SwatchTable rows={greens} usage={c.usage} headers={c.swatchHeaders} copyLabel={d.copyLabel} />
    <p>{c.brandTextNote} <a href={accessibilityHref}>{d.groups.accessibility}</a>.</p>
  </section>

  <section id="neutrals">
    <h2>{c.neutralsHeading}</h2>
    <p set:html={md(c.neutralsBody)} />
    <SwatchTable rows={neutrals} usage={c.usage} headers={c.swatchHeaders} copyLabel={d.copyLabel} />
    <p set:html={md(c.elevationNote)} />
  </section>

  <section id="interaction">
    <h2>{c.interactionHeading}</h2>
    <p set:html={md(c.interactionBody)} />
    <div class="table-mini-wrap">
      <table class="table-mini">
        <thead>
          <tr>
            <th>{c.interactionHeaders.state}</th>
            <th>{c.interactionHeaders.link}</th>
            <th>{c.interactionHeaders.button}</th>
          </tr>
        </thead>
        <tbody>
          {interactionRows.map((r) => (
            <tr>
              <td>{r.state}</td>
              <td><code>{r.link}</code></td>
              <td><code>{r.button}</code></td>
            </tr>
          ))}
          <tr>
            <td>{c.interactionStates.disabled}</td>
            <td colspan="2" class="ds-mini-note">{c.interactionDisabledNote}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section id="callouts">
    <h2>{c.calloutsHeading}</h2>
    <p set:html={md(c.calloutsBody)} />
    <div class="table-mini-wrap">
      <table class="table-mini">
        <thead>
          <tr>
            <th colspan="2">{c.calloutsHeaders.type}</th>
            <th>{c.calloutsHeaders.colour}</th>
            <th>{c.calloutsHeaders.use}</th>
          </tr>
        </thead>
        <tbody>
          {calloutRows.map((r) => (
            <tr>
              <td class="ds-mini-swatch"><span style={`background:${r.hex}`}></span></td>
              <td>{c.calloutsTypes[r.key]}</td>
              <td><CopyHex value={r.hex} label={d.copyLabel} /></td>
              <td>{c.calloutsUses[r.key]}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p set:html={md(c.calloutsScoping)} />
    <p set:html={md(c.calloutsException)} />
  </section>

  <section id="illustration">
    <h2>{c.illosHeading}</h2>
    <p><Fragment set:html={md(c.illosBody)} /> {c.illosMore} <a href={mediaHref}>{c.illosMoreLink}</a>.</p>
    <h3>{c.heroPaletteHeading}</h3>
    <p set:html={md(c.heroPaletteBody)} />
    <ul class="ds-palette-strip">
      {heroPalette.map((hex, i) => (
        <li class="ds-palette-item">
          <span class="ds-palette-chip" style={`background: ${hex}`}></span>
          <span class="ds-palette-name">{c.heroPaletteNames[i] ?? ''}</span>
          <CopyHex value={hex} label={d.copyLabel} />
        </li>
      ))}
    </ul>
    <h3>{c.heroSwatchHeading}</h3>
    <p set:html={md(c.heroSwatchBody)} />
    <ul class="ds-harmony-grid">
      {[...seriesPastels.entries()].map(([series, hex]) => (
        <li class="ds-harmony-card" style={`background: ${hex}`}>
          <span class="ds-harmony-name">{shortenSeriesName(series)}</span>
          <CopyHex value={hex} label={d.copyLabel} />
          <span class="ds-harmony-dots">
            {heroPalette.map((chipHex) => <span class="ds-harmony-dot" style={`background: ${chipHex}`}></span>)}
          </span>
        </li>
      ))}
    </ul>
  </section>

  <section id="using">
    <h2>{c.usingHeading}</h2>
    <div class="dodont-grid">
      <GuidanceCard kind="do" label={c.doLabel} caption={c.dos[0]}>
        <button type="button" class="btn btn-primary">Download CV</button>
        <span class="ds-plain-text">Body copy stays neutral.</span>
      </GuidanceCard>
      <GuidanceCard kind="dont" label={c.dontLabel} caption={c.donts[0]}>
        <button type="button" class="btn btn-primary">Download CV</button>
        <button type="button" class="btn" style="background: #3182ce; color: #ffffff;">Book a call</button>
      </GuidanceCard>

      <GuidanceCard kind="do" label={c.doLabel} caption={c.dos[2]}>
        <span class="ds-contrast-stage">
          <span style="color: var(--color-green-text); font-weight: 600;">A readable green link</span>
        </span>
      </GuidanceCard>
      <GuidanceCard kind="dont" label={c.dontLabel} caption={c.donts[1]}>
        <span class="ds-contrast-stage">
          <span style="color: #6dc402; font-size: 0.85rem;">Small lime text on white fails the bar</span>
        </span>
      </GuidanceCard>

      <GuidanceCard kind="do" label={c.doLabel} caption={c.dos[1]}>
        <span class="ds-theme-pair" aria-hidden="true">
          <span class="ds-theme-chip" style="background: #ffffff; color: #0e0c19; border: 1px solid #e0e0e0;">Aa</span>
          <span class="ds-theme-chip" style="background: #111111; color: #f0f0f0; border: 1px solid #333333;">Aa</span>
        </span>
      </GuidanceCard>
      <GuidanceCard kind="dont" label={c.dontLabel} caption={c.donts[2]}>
        <button type="button" class="btn" style="background: transparent; border: 2px solid #e53e3e; color: #e53e3e;">Download CV</button>
      </GuidanceCard>
    </div>
  </section>
</DesignLayout>

<style>
  /* Guidance stages: fixed backgrounds so the contrast examples stay truthful
     in either theme. */
  .ds-contrast-stage {
    display: inline-flex;
    align-items: center;
    padding: 0.8rem 1.1rem;
    border-radius: 8px;
    background: #ffffff;
    border: 1px solid #e0e0e0;
  }
  .ds-plain-text { font-size: 0.9rem; color: var(--text-secondary); }
  .ds-theme-pair { display: inline-flex; gap: 0.6rem; }
  .ds-theme-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 10px;
    font-weight: 700;
  }
</style>

<style>
  .ds-mini-note { font-style: italic; color: var(--text-muted); }
  .ds-mini-swatch { width: 44px; }
  .ds-mini-swatch span {
    display: block;
    width: 26px;
    height: 26px;
    border-radius: 6px;
    border: 1px solid rgba(128, 128, 128, 0.3);
  }
  .ds-dodont-list {
    margin: 0;
    padding-left: 1.1rem;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--text-secondary);
  }
  .ds-dodont-list li { margin-bottom: 0.45rem; }
  .ds-dodont-list li:last-child { margin-bottom: 0; }

  /* Illustration colour: the shared hero pool and the harmony check (the
     whole pool on each series ground). Literal colours on both themes. */
  .ds-palette-strip {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .ds-palette-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: flex-start;
  }
  .ds-palette-chip {
    width: 64px;
    height: 44px;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    flex-shrink: 0;
  }
  .ds-palette-name {
    color: var(--text-secondary);
    font-size: 0.8rem;
    font-weight: 600;
  }
  .ds-harmony-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  @media (min-width: 700px) {
    .ds-harmony-grid { grid-template-columns: 1fr 1fr; }
  }
  .ds-harmony-card {
    border-radius: 12px;
    border: 1px solid var(--border-color);
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-start;
  }
  .ds-harmony-name {
    color: #1a1a1a;
    font-weight: 700;
    font-size: 0.95rem;
  }
  .ds-harmony-dots {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }
  .ds-harmony-dot {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.08);
  }
</style>
