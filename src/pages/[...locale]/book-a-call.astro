---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLocalePath, localeStaticPaths, type Locale } from '../../i18n/index';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.props as { locale: Locale };
const i18n = t(locale);

const CALENDLY_BASE = 'https://calendly.com/warrendeleon/30min?hide_event_type_details=1&hide_gdpr_banner=1';
---

<BaseLayout
  title={i18n.seo.bookACallTitle}
  description={i18n.seo.bookACallDescription}
  locale={locale}
  currentPath={getLocalePath(locale, '/book-a-call/')}
>
  <section class="section">
    <div class="container">
      <h1 class="section-title">{i18n.bookACall.title}</h1>
      <p class="bac-subtitle text-muted">{i18n.bookACall.description}</p>
      <p class="bac-intro">{i18n.bookACall.intro}</p>

      <h2 class="bac-expect-title">{i18n.bookACall.expectTitle}</h2>
      <ul class="bac-expect dot-list">
        {i18n.bookACall.expect.map((item: string) => <li>{item}</li>)}
      </ul>

      <div class="calendly-embed" data-calendly-base={CALENDLY_BASE}>
        <p class="calendly-loading" aria-hidden="true">{i18n.bookACall.loading}</p>
        <iframe
          src={CALENDLY_BASE}
          width="100%"
          height="700"
          frameborder="0"
          title={i18n.bookACall.iframeTitle}
          loading="lazy"
        ></iframe>
      </div>

      <p class="bac-fallback">
        {i18n.bookACall.fallbackPrefix}
        <a href="https://calendly.com/warrendeleon/30min" target="_blank" rel="noopener">{i18n.bookACall.fallbackCalendly}</a>
        {i18n.bookACall.fallbackOr}
        <a href="mailto:hi@warrendeleon.com">hi@warrendeleon.com</a>.
      </p>
      <p class="bac-privacy text-muted">
        {i18n.bookACall.privacyNote}
        <a href={getLocalePath(locale, '/privacy/')}>{i18n.bookACall.privacyLink}</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .bac-subtitle {
    margin-bottom: 1.5rem;
  }

  .bac-intro {
    max-width: 46rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .bac-expect-title {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }




  .calendly-embed {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border-color);
    background: var(--bg-secondary);
    min-height: 700px;
  }

  .calendly-loading {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    z-index: 0;
  }

  .calendly-embed iframe {
    display: block;
    position: relative;
    z-index: 1;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .calendly-embed.loaded iframe {
    opacity: 1;
  }

  @media (max-width: 640px) {
    .calendly-embed iframe {
      height: 980px;
    }

    .calendly-embed {
      min-height: 980px;
    }
  }

  .bac-fallback {
    margin-top: 1.25rem;
    color: var(--text-secondary);
  }

  .bac-privacy {
    margin-top: 0.5rem;
    font-size: 0.9rem;
  }
</style>

<script>
  // Match the Calendly embed to the active theme. Calendly reads its colours
  // from query params, so the iframe src is rebuilt when the theme changes.
  const embed = document.querySelector('.calendly-embed') as HTMLElement | null;
  const iframe = embed?.querySelector('iframe');
  const base = embed?.dataset.calendlyBase;

  function themedSrc(): string {
    const dark = document.documentElement.getAttribute('data-theme') === 'dark';
    const colours = dark
      ? 'background_color=222222&text_color=f0f0f0&primary_color=6dc402'
      : 'background_color=ffffff&text_color=0e0c19&primary_color=5aa302';
    return `${base}&${colours}`;
  }

  if (embed && iframe && base) {
    iframe.addEventListener('load', () => embed.classList.add('loaded'));
    iframe.src = themedSrc();

    new MutationObserver(() => {
      embed.classList.remove('loaded');
      iframe.src = themedSrc();
    }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  }
</script>
