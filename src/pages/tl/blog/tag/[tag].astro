---
import BlogTagPage from '../../../../components/blog/BlogTagPage.astro';
import { getPostsForLocale } from '../../../../utils/blogHelpers';

export async function getStaticPaths() {
  const posts = await getPostsForLocale('tl');
  const tags = [...new Set(posts.flatMap(post => post.data.tags))];
  return tags.map(tag => {
    const tagPosts = posts
      .filter(post => post.data.tags.includes(tag))
      .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
    return { params: { tag }, props: { posts: tagPosts, tag } };
  });
}

const { posts, tag } = Astro.props;
---

<BlogTagPage locale="tl" posts={posts} tag={tag} />
