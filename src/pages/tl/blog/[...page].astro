---
import BlogListing from '../../../components/blog/BlogListing.astro';
import { getFeedPostsForLocale } from '../../../utils/blogHelpers';

export async function getStaticPaths({ paginate }: any) {
  // All posts in strict newest-to-oldest order. The current series is also
  // featured in its own hero card above the feed, but the design lists All
  // posts by date, so its parts stay inline here rather than demoted.
  const posts = await getFeedPostsForLocale('tl');
  return paginate(posts, { pageSize: 12 });
}

const { page } = Astro.props;
---

<BlogListing locale="tl" page={page} />
