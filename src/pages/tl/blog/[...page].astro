---
import BlogListing from '../../../components/blog/BlogListing.astro';
import { getFeedPostsForLocale, getPostsForLocale } from '../../../utils/blogHelpers';

export async function getStaticPaths({ paginate }: any) {
  const posts = await getFeedPostsForLocale('tl');
  // Match the hero card's series (newest own-locale post) and keep its parts
  // out of the feed - the hero already lists them.
  const own = await getPostsForLocale('tl');
  const currentSeries = own[0]?.data.series ?? null;
  const feed = currentSeries ? posts.filter(p => p.data.series !== currentSeries) : posts;
  return paginate(feed, { pageSize: 12 });
}

const { page } = Astro.props;
---

<BlogListing locale="tl" page={page} />
