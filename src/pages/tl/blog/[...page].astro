---
import BlogListing from '../../../components/blog/BlogListing.astro';
import { getFeedPostsForLocale, getCurrentSeriesName } from '../../../utils/blogHelpers';

export async function getStaticPaths({ paginate }: any) {
  const posts = await getFeedPostsForLocale('tl');
  // Demote the current-series hero's parts to the end of the feed (never remove:
  // that shrank pagination and 404'd indexed page URLs). getCurrentSeriesName
  // matches the hero (most recent series with 2+ parts); the newest post's series
  // alone would drop that post from the feed during a mini-series break.
  const currentSeries = await getCurrentSeriesName('tl');
  const feed = currentSeries
    ? [...posts.filter(p => p.data.series !== currentSeries), ...posts.filter(p => p.data.series === currentSeries)]
    : posts;
  return paginate(feed, { pageSize: 12 });
}

const { page } = Astro.props;
---

<BlogListing locale="tl" page={page} />
