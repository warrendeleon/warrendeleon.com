---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TechBadge from '../../components/TechBadge.astro';
import { t, slugify, formatDateRange, getLocalePath } from '../../i18n/index';
import workxp from '../../data/workxp-en.json';

const locale = 'en' as const;
const i18n = t(locale);

export function getStaticPaths() {
  const paths: Array<{ params: { slug: string }; props: any }> = [];

  for (const company of workxp) {
    // Company page
    paths.push({
      params: { slug: slugify(company.company) },
      props: { company, position: null, isClientPage: false },
    });

    // Client pages
    for (const position of company.positions) {
      const client = (position as any).client;
      if (client) {
        paths.push({
          params: { slug: slugify(client.name) },
          props: {
            company,
            position,
            isClientPage: true,
            clientName: client.name,
            clientLogo: client.logo,
          },
        });
      }
    }
  }

  return paths;
}

const { company, position: clientPosition, isClientPage, clientName, clientLogo } = Astro.props;

const displayName = isClientPage ? clientName : company.company;
const displayLogo = isClientPage ? clientLogo : company.logo;
const backLink = isClientPage
  ? getLocalePath(locale, `/work/${slugify(company.company)}/`)
  : getLocalePath(locale, '/work-experience/');
const backLabel = isClientPage ? company.company : i18n.common.back;

const positions = isClientPage ? [clientPosition] : company.positions;
const clientPositions = isClientPage ? [] : company.positions.filter((p: any) => p.client);
const nonClientPositions = isClientPage ? [clientPosition] : company.positions.filter((p: any) => !p.client);

const currentIndex = workxp.findIndex((c: any) => slugify(c.company) === slugify(company.company));
const prevCompany = currentIndex > 0 ? workxp[currentIndex - 1] : null;
const nextCompany = currentIndex < workxp.length - 1 ? workxp[currentIndex + 1] : null;
---

<BaseLayout
  title={`${displayName} | Warren de Leon`}
  description={(positions[0].description || `${displayName} — Warren de Leon`).substring(0, 160)}
  locale={locale}
  currentPath={`/work/${slugify(displayName)}/`}
>
  <section class="section">
    <div class="container">
      <a href={backLink} class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        {backLabel}
      </a>

      <div class="company-header mt-3">
        <div class="company-logo-circle">
          {displayLogo ? (
            <img src={displayLogo} alt={displayName} />
          ) : (
            <span class="company-logo-fallback">{displayName.charAt(0)}</span>
          )}
        </div>
        <h1>{displayName}</h1>
      </div>

      {/* Non-client positions: render full details */}
      {nonClientPositions.map((position: any) => (
        <div class="position card mt-3">
          <div class="position-header">
            <h2>{position.title}</h2>
            <span class="position-date">
              {formatDateRange(position.startDate, position.endDate, locale)}
            </span>
          </div>

          {position.description && (
            <>
              <h3 class="mt-2">{i18n.workExperience.description}</h3>
              <p class="position-desc mt-1">{position.description}</p>
            </>
          )}

          {position.responsibilities && position.responsibilities.length > 0 && (
            <div class="mt-3">
              <h3>{i18n.workExperience.keyResponsibilities}</h3>
              <ul class="responsibilities mt-1">
                {position.responsibilities.map((r: string) => <li>{r}</li>)}
              </ul>
            </div>
          )}

          {position.technologies && (
            <div class="tech-section mt-3">
              {position.technologies.languages && position.technologies.languages.length > 0 && (
                <div class="tech-group">
                  <h4>{i18n.workExperience.programmingLanguages}</h4>
                  <div class="badge-group mt-1">
                    {position.technologies.languages.map((lang: string) => <TechBadge label={lang} />)}
                  </div>
                </div>
              )}
              {position.technologies.frameworks && position.technologies.frameworks.length > 0 && (
                <div class="tech-group">
                  <h4>{i18n.workExperience.technologyStack}</h4>
                  <div class="badge-group mt-1">
                    {position.technologies.frameworks.map((fw: string) => <TechBadge label={fw} />)}
                  </div>
                </div>
              )}
              {position.technologies.testing?.unit && position.technologies.testing.unit.length > 0 && (
                <div class="tech-group">
                  <h4>{i18n.workExperience.unitTesting}</h4>
                  <div class="badge-group mt-1">
                    {position.technologies.testing.unit.map((t: string) => <TechBadge label={t} />)}
                  </div>
                </div>
              )}
              {position.technologies.testing?.e2e && position.technologies.testing.e2e.length > 0 && (
                <div class="tech-group">
                  <h4>{i18n.workExperience.e2eTesting}</h4>
                  <div class="badge-group mt-1">
                    {position.technologies.testing.e2e.map((t: string) => <TechBadge label={t} />)}
                  </div>
                </div>
              )}
              {position.technologies.tools && position.technologies.tools.length > 0 && (
                <div class="tech-group">
                  <h4>{i18n.workExperience.developmentTools}</h4>
                  <div class="badge-group mt-1">
                    {position.technologies.tools.map((tool: string) => <TechBadge label={tool} />)}
                  </div>
                </div>
              )}
              {position.technologies.ci && position.technologies.ci.length > 0 && (
                <div class="tech-group">
                  <h4>{i18n.workExperience.ciCd}</h4>
                  <div class="badge-group mt-1">
                    {position.technologies.ci.map((ci: string) => <TechBadge label={ci} />)}
                  </div>
                </div>
              )}
              {position.technologies.methodology && position.technologies.methodology.length > 0 && (
                <div class="tech-group">
                  <h4>{i18n.workExperience.agileMethodology}</h4>
                  <div class="badge-group mt-1">
                    {position.technologies.methodology.map((m: string) => <TechBadge label={m} />)}
                  </div>
                </div>
              )}
            </div>
          )}
        </div>
      ))}

      {/* Client positions: render as navigation cards */}
      {clientPositions.length > 0 && (
        <div class="client-nav mt-3">
          {clientPositions.map((position: any) => (
            <a href={getLocalePath(locale, `/work/${slugify(position.client.name)}/`)} class="client-nav-card card">
              <div class="client-nav-logo">
                <img src={position.client.logo} alt={position.client.name} />
              </div>
              <div class="client-nav-info">
                <span class="client-nav-name">{position.client.name}</span>
                <span class="client-nav-title">{position.title}</span>
              </div>
              <span class="client-nav-date">
                {formatDateRange(position.startDate, position.endDate, locale)}
              </span>
              <svg class="client-nav-chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </a>
          ))}
        </div>
      )}

      {!isClientPage && (prevCompany || nextCompany) && (
        <div class="work-nav">
          {prevCompany ? (
            <a href={getLocalePath(locale, `/work/${slugify(prevCompany.company)}/`)}>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
              {prevCompany.company}
            </a>
          ) : <span />}
          {nextCompany ? (
            <a href={getLocalePath(locale, `/work/${slugify(nextCompany.company)}/`)} class="work-nav-next">
              {nextCompany.company}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6" /></svg>
            </a>
          ) : <span />}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style is:global>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 500;
    font-size: 0.9rem;
  }

  .company-header {
    display: grid;
    grid-template-columns: 15% 1fr;
    gap: 1.5rem;
    align-items: center;
  }

  .company-logo-circle {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: #f5f5f7;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 2px solid var(--border-color);
  }

  .company-logo-circle img {
    width: 60%;
    height: 60%;
    object-fit: contain;
  }

  .company-logo-fallback {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-green);
  }

  .position-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
  }

  .position-header h2 {
    font-size: 1.4rem;
    color: var(--color-green);
  }

  .position-date {
    font-size: 0.85rem;
    color: var(--text-muted);
    white-space: nowrap;
    background: var(--badge-bg);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
  }

  .position-desc {
    color: var(--text-secondary);
    line-height: 1.8;
    white-space: pre-line;
    font-size: 1.05rem;
  }

  .responsibilities {
    list-style: none;
    padding: 0;
  }

  .responsibilities li {
    padding: 0.5rem 0;
    padding-left: 1.5rem;
    position: relative;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .responsibilities li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 1rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-green);
  }

  .tech-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 1.5rem;
    background: var(--bg-secondary);
    border-radius: 12px;
  }

  .tech-group h4 {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  /* Client navigation cards */
  .client-nav {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .client-nav-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    text-decoration: none;
    color: var(--text-primary);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .client-nav-card:hover {
    transform: translateX(4px);
    box-shadow: var(--shadow-hover);
    color: var(--text-primary);
  }

  .client-nav-logo {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #f5f5f7;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 2px solid var(--border-color);
    flex-shrink: 0;
  }

  .client-nav-logo img {
    width: 60%;
    height: 60%;
    object-fit: contain;
  }

  .client-nav-info {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .client-nav-name {
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--color-green);
  }

  .client-nav-title {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-top: 0.15rem;
  }

  .client-nav-date {
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
    background: var(--badge-bg);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    flex-shrink: 0;
  }

  .client-nav-chevron {
    color: var(--text-muted);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .company-header {
      grid-template-columns: 60px 1fr;
    }

    .client-nav-card {
      flex-wrap: wrap;
    }

    .client-nav-date {
      order: 3;
    }

    .client-nav-chevron {
      display: none;
    }
  }
</style>
