---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found | Warren de Leon"
  description="The page you're looking for doesn't exist."
  locale="en"
  currentPath="/404"
>
  <section class="section">
    <div class="container text-center">
      <h1>404</h1>
      <p class="mt-2" style="font-size: 1.2rem; color: var(--text-secondary);">The page you're looking for doesn't exist.</p>
      <a href="/" class="btn btn-outline mt-3">Go home</a>
    </div>
  </section>
</BaseLayout>
