---
import BlogListing from '../../../components/blog/BlogListing.astro';
import { getFeedPostsForLocale, getPostsForLocale } from '../../../utils/blogHelpers';

export async function getStaticPaths({ paginate }: any) {
  const posts = await getFeedPostsForLocale('es');
  // Match the hero card's series (newest own-locale post) and demote (never
  // remove) its parts to the end of the feed - the hero already lists them,
  // and removing them would shrink pagination and 404 indexed page URLs.
  const own = await getPostsForLocale('es');
  const currentSeries = own[0]?.data.series ?? null;
  const feed = currentSeries
    ? [...posts.filter(p => p.data.series !== currentSeries), ...posts.filter(p => p.data.series === currentSeries)]
    : posts;
  return paginate(feed, { pageSize: 12 });
}

const { page } = Astro.props;
---

<BlogListing locale="es" page={page} />
