---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TechBadge from '../../../components/TechBadge.astro';
import { t, slugify, formatDateRange, getLocalePath } from '../../../i18n/index';
import workxp from '../../../data/workxp-es.json';

const locale = 'es' as const;
const i18n = t(locale);

export function getStaticPaths() {
  const paths: Array<{ params: { slug: string }; props: any }> = [];

  for (const company of workxp) {
    // Company page
    paths.push({
      params: { slug: slugify(company.company) },
      props: { company, position: null, isClientPage: false },
    });

    // Client pages
    for (const position of company.positions) {
      const client = (position as any).client;
      if (client) {
        paths.push({
          params: { slug: slugify(client.name) },
          props: {
            company,
            position,
            isClientPage: true,
            clientName: client.name,
            clientLogo: client.logo,
          },
        });
      }
    }
  }

  return paths;
}

const { company, position: clientPosition, isClientPage, clientName, clientLogo } = Astro.props;

const displayName = isClientPage ? clientName : company.company;
const displayLogo = isClientPage ? clientLogo : company.logo;
const backLink = isClientPage
  ? getLocalePath(locale, `/work/${slugify(company.company)}/`)
  : getLocalePath(locale, '/work-experience/');
const backLabel = isClientPage ? company.company : i18n.common.back;

const positions = isClientPage ? [clientPosition] : company.positions;
const clientPositions = isClientPage ? [] : company.positions.filter((p: any) => p.client);
const nonClientPositions = isClientPage ? [clientPosition] : company.positions.filter((p: any) => !p.client);

const currentIndex = workxp.findIndex((c: any) => slugify(c.company) === slugify(company.company));
const prevCompany = currentIndex > 0 ? workxp[currentIndex - 1] : null;
const nextCompany = currentIndex < workxp.length - 1 ? workxp[currentIndex + 1] : null;
---

<BaseLayout
  title={`${displayName} | Warren de Leon`}
  description={(positions[0].description || `${displayName} — Warren de Leon`).substring(0, 160)}
  locale={locale}
  currentPath={`/es/work/${slugify(displayName)}/`}
>
  <!-- Hero header -->
  <section class="work-hero section-alt" aria-label="Company header">
    <div class="container">
      <a href={backLink} class="work-back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        {backLabel}
      </a>

      <div class="work-hero-content">
        <div class="work-hero-logo">
          {displayLogo ? (
            <img src={displayLogo} alt="" />
          ) : (
            <span class="work-hero-logo-fallback">{displayName.charAt(0)}</span>
          )}
        </div>
        <div class="work-hero-info">
          <h1>{displayName}</h1>
          {nonClientPositions.length === 1 && (
            <p class="work-hero-role">{nonClientPositions[0].title}</p>
          )}
          {nonClientPositions.length === 1 && (
            <span class="work-hero-date">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
              {formatDateRange(nonClientPositions[0].startDate, nonClientPositions[0].endDate, locale)}
            </span>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <article class="section work-content-section">
    <div class="container">

      {/* Multiple positions: show each as a section */}
      {nonClientPositions.length > 1 ? (
        nonClientPositions.map((position: any, index: number) => (
          <section class={`work-position ${index > 0 ? 'work-position-subsequent' : ''}`}>
            <div class="work-position-header">
              <div>
                <h2>{position.title}</h2>
                <span class="work-position-date">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                  </svg>
                  {formatDateRange(position.startDate, position.endDate, locale)}
                </span>
              </div>
            </div>

            {position.description && (
              <div class="work-description">
                <p>{position.description}</p>
              </div>
            )}

            {position.responsibilities && position.responsibilities.length > 0 && (
              <div class="work-responsibilities">
                <h3>
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="9 11 12 14 22 4"></polyline>
                    <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                  </svg>
                  {i18n.workExperience.keyResponsibilities}
                </h3>
                <ul>
                  {position.responsibilities.map((r: string) => {
                    const colonIdx = r.indexOf(':');
                    if (colonIdx > 0 && colonIdx < 40) {
                      return <li><strong>{r.slice(0, colonIdx)}</strong>{r.slice(colonIdx)}</li>;
                    }
                    return <li>{r}</li>;
                  })}
                </ul>
              </div>
            )}

            {position.technologies && (
              <div class="work-tech-grid">
                {position.technologies.languages && position.technologies.languages.length > 0 && (
                  <div class="work-tech-category">
                    <h4>{i18n.workExperience.programmingLanguages}</h4>
                    <div class="badge-group">
                      {position.technologies.languages.map((lang: string) => <TechBadge label={lang} />)}
                    </div>
                  </div>
                )}
                {position.technologies.frameworks && position.technologies.frameworks.length > 0 && (
                  <div class="work-tech-category">
                    <h4>{i18n.workExperience.technologyStack}</h4>
                    <div class="badge-group">
                      {position.technologies.frameworks.map((fw: string) => <TechBadge label={fw} />)}
                    </div>
                  </div>
                )}
                {position.technologies.testing?.unit && position.technologies.testing.unit.length > 0 && (
                  <div class="work-tech-category">
                    <h4>{i18n.workExperience.unitTesting}</h4>
                    <div class="badge-group">
                      {position.technologies.testing.unit.map((t: string) => <TechBadge label={t} />)}
                    </div>
                  </div>
                )}
                {position.technologies.testing?.e2e && position.technologies.testing.e2e.length > 0 && (
                  <div class="work-tech-category">
                    <h4>{i18n.workExperience.e2eTesting}</h4>
                    <div class="badge-group">
                      {position.technologies.testing.e2e.map((t: string) => <TechBadge label={t} />)}
                    </div>
                  </div>
                )}
                {position.technologies.tools && position.technologies.tools.length > 0 && (
                  <div class="work-tech-category">
                    <h4>{i18n.workExperience.developmentTools}</h4>
                    <div class="badge-group">
                      {position.technologies.tools.map((tool: string) => <TechBadge label={tool} />)}
                    </div>
                  </div>
                )}
                {position.technologies.ci && position.technologies.ci.length > 0 && (
                  <div class="work-tech-category">
                    <h4>{i18n.workExperience.ciCd}</h4>
                    <div class="badge-group">
                      {position.technologies.ci.map((ci: string) => <TechBadge label={ci} />)}
                    </div>
                  </div>
                )}
                {position.technologies.methodology && position.technologies.methodology.length > 0 && (
                  <div class="work-tech-category">
                    <h4>{i18n.workExperience.agileMethodology}</h4>
                    <div class="badge-group">
                      {position.technologies.methodology.map((m: string) => <TechBadge label={m} />)}
                    </div>
                  </div>
                )}
              </div>
            )}
          </section>
        ))
      ) : (
        /* Single position: no extra header needed, info is in the hero */
        nonClientPositions.map((position: any) => (
          <div class="work-position">
            {position.description && (
              <div class="work-description">
                <p>{position.description}</p>
              </div>
            )}

            {position.responsibilities && position.responsibilities.length > 0 && (
              <div class="work-responsibilities">
                <h3>
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="9 11 12 14 22 4"></polyline>
                    <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                  </svg>
                  {i18n.workExperience.keyResponsibilities}
                </h3>
                <ul>
                  {position.responsibilities.map((r: string) => {
                    const colonIdx = r.indexOf(':');
                    if (colonIdx > 0 && colonIdx < 40) {
                      return <li><strong>{r.slice(0, colonIdx)}</strong>{r.slice(colonIdx)}</li>;
                    }
                    return <li>{r}</li>;
                  })}
                </ul>
              </div>
            )}

            {position.technologies && (
              <div class="work-tech-grid">
                {position.technologies.languages && position.technologies.languages.length > 0 && (
                  <div class="work-tech-category">
                    <h4>{i18n.workExperience.programmingLanguages}</h4>
                    <div class="badge-group">
                      {position.technologies.languages.map((lang: string) => <TechBadge label={lang} />)}
                    </div>
                  </div>
                )}
                {position.technologies.frameworks && position.technologies.frameworks.length > 0 && (
                  <div class="work-tech-category">
                    <h4>{i18n.workExperience.technologyStack}</h4>
                    <div class="badge-group">
                      {position.technologies.frameworks.map((fw: string) => <TechBadge label={fw} />)}
                    </div>
                  </div>
                )}
                {position.technologies.testing?.unit && position.technologies.testing.unit.length > 0 && (
                  <div class="work-tech-category">
                    <h4>{i18n.workExperience.unitTesting}</h4>
                    <div class="badge-group">
                      {position.technologies.testing.unit.map((t: string) => <TechBadge label={t} />)}
                    </div>
                  </div>
                )}
                {position.technologies.testing?.e2e && position.technologies.testing.e2e.length > 0 && (
                  <div class="work-tech-category">
                    <h4>{i18n.workExperience.e2eTesting}</h4>
                    <div class="badge-group">
                      {position.technologies.testing.e2e.map((t: string) => <TechBadge label={t} />)}
                    </div>
                  </div>
                )}
                {position.technologies.tools && position.technologies.tools.length > 0 && (
                  <div class="work-tech-category">
                    <h4>{i18n.workExperience.developmentTools}</h4>
                    <div class="badge-group">
                      {position.technologies.tools.map((tool: string) => <TechBadge label={tool} />)}
                    </div>
                  </div>
                )}
                {position.technologies.ci && position.technologies.ci.length > 0 && (
                  <div class="work-tech-category">
                    <h4>{i18n.workExperience.ciCd}</h4>
                    <div class="badge-group">
                      {position.technologies.ci.map((ci: string) => <TechBadge label={ci} />)}
                    </div>
                  </div>
                )}
                {position.technologies.methodology && position.technologies.methodology.length > 0 && (
                  <div class="work-tech-category">
                    <h4>{i18n.workExperience.agileMethodology}</h4>
                    <div class="badge-group">
                      {position.technologies.methodology.map((m: string) => <TechBadge label={m} />)}
                    </div>
                  </div>
                )}
              </div>
            )}
          </div>
        ))
      )}

      {/* Client navigation cards */}
      {clientPositions.length > 0 && (
        <section class="work-clients" aria-label="Proyectos para clientes">
          <h3 class="work-section-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="8.5" cy="7" r="4"></circle>
              <line x1="20" y1="8" x2="20" y2="14"></line>
              <line x1="23" y1="11" x2="17" y2="11"></line>
            </svg>
            Proyectos para clientes
          </h3>
          <div class="work-client-grid">
            {clientPositions.map((position: any) => (
              <a href={getLocalePath(locale, `/work/${slugify(position.client.name)}/`)} class="work-client-card">
                <div class="work-client-card-logo">
                  <img src={position.client.logo} alt="" />
                </div>
                <div class="work-client-card-body">
                  <span class="work-client-card-name">{position.client.name}</span>
                  <span class="work-client-card-title">{position.title}</span>
                  <span class="work-client-card-date">
                    {formatDateRange(position.startDate, position.endDate, locale)}
                  </span>
                </div>
                <svg class="work-client-card-arrow" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            ))}
          </div>
        </section>
      )}

      {/* Prev/Next navigation */}
      {!isClientPage && (prevCompany || nextCompany) && (
        <nav class="work-detail-nav" aria-label="Previous and next companies">
          {prevCompany ? (
            <a href={getLocalePath(locale, `/work/${slugify(prevCompany.company)}/`)} class="work-detail-nav-link work-detail-nav-prev">
              <span class="work-detail-nav-label">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="19" y1="12" x2="5" y2="12"></line>
                  <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Previous
              </span>
              <span class="work-detail-nav-title">{prevCompany.company}</span>
            </a>
          ) : <span />}
          {nextCompany ? (
            <a href={getLocalePath(locale, `/work/${slugify(nextCompany.company)}/`)} class="work-detail-nav-link work-detail-nav-next">
              <span class="work-detail-nav-label">
                Next
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </span>
              <span class="work-detail-nav-title">{nextCompany.company}</span>
            </a>
          ) : <span />}
        </nav>
      )}
    </div>
  </article>
</BaseLayout>

<style is:global>
  /* Hero */
  .work-hero {
    padding: 2rem 0 2.5rem;
    background: var(--bg-secondary);
  }

  .work-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    transition: color 0.2s ease, gap 0.2s ease;
  }

  .work-back-link:hover {
    color: var(--color-green);
    gap: 0.6rem;
  }

  .work-hero-content {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .work-hero-logo {
    width: 90px;
    height: 90px;
    border-radius: 20px;
    background: #f5f5f7;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 2px solid var(--border-color);
    flex-shrink: 0;
  }

  .work-hero-logo img {
    width: 60%;
    height: 60%;
    object-fit: contain;
  }

  .work-hero-logo-fallback {
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--color-green);
  }

  .work-hero-info h1 {
    font-size: 2rem;
    line-height: 1.2;
    margin-bottom: 0.35rem;
    letter-spacing: -0.02em;
  }

  .work-hero-role {
    font-size: 1.1rem;
    color: var(--text-secondary);
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .work-hero-date {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .work-hero-date svg {
    opacity: 0.6;
  }

  /* Content section */
  .work-content-section {
    padding-top: 2rem;
  }

  /* Position sections */
  .work-position-subsequent {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid var(--border-color);
  }

  .work-position-header {
    margin-bottom: 1.5rem;
  }

  .work-position-header h2 {
    font-size: 1.5rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .work-position-date {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .work-position-date svg {
    opacity: 0.6;
  }

  /* Description */
  .work-description {
    margin-bottom: 2rem;
  }

  .work-description p {
    color: var(--text-secondary);
    line-height: 1.8;
    white-space: pre-line;
    font-size: 1.05rem;
  }

  /* Responsibilities */
  .work-responsibilities {
    margin-bottom: 2rem;
    background: var(--bg-secondary);
    border-radius: 12px;
    padding: 1.75rem;
    border: 1px solid var(--border-color);
  }

  .work-responsibilities h3 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.1rem;
    color: var(--text-primary);
    margin-bottom: 1.25rem;
  }

  .work-responsibilities h3 svg {
    color: var(--color-green);
  }

  .work-responsibilities ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .work-responsibilities li {
    padding-left: 1.5rem;
    position: relative;
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .work-responsibilities li strong {
    color: var(--text-primary);
    font-weight: 700;
  }

  .work-responsibilities li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-green);
  }

  /* Tech grid */
  .work-tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .work-tech-category {
    padding: 1.25rem;
    background: var(--bg-secondary);
    border-radius: 12px;
    border: 1px solid var(--border-color);
  }

  .work-tech-category h4 {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  /* Section titles */
  .work-section-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.15rem;
    color: var(--text-primary);
    margin-bottom: 1.25rem;
  }

  .work-section-title svg {
    color: var(--color-green);
  }

  /* Client project cards */
  .work-clients {
    margin-top: 2.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border-color);
  }

  .work-client-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }

  .work-client-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    text-decoration: none;
    color: var(--text-primary);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .work-client-card:hover {
    border-color: var(--color-green);
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
    color: var(--text-primary);
  }

  .work-client-card-logo {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: #f5f5f7;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 1px solid var(--border-color);
    flex-shrink: 0;
  }

  .work-client-card-logo img {
    width: 60%;
    height: 60%;
    object-fit: contain;
  }

  .work-client-card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .work-client-card-name {
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--color-green);
  }

  .work-client-card-title {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-top: 0.15rem;
  }

  .work-client-card-date {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  .work-client-card-arrow {
    color: var(--text-muted);
    flex-shrink: 0;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .work-client-card:hover .work-client-card-arrow {
    color: var(--color-green);
    transform: translateX(3px);
  }

  /* Prev/Next navigation */
  .work-detail-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 3rem;
  }

  .work-detail-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--bg-secondary);
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease;
