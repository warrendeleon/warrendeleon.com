---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TechBadge from '../../../components/TechBadge.astro';
import { t, slugify, formatDateRange, getLocalePath } from '../../../i18n/index';
import workxp from '../../../data/workxp-es.json';

const locale = 'es' as const;
const i18n = t(locale);

export function getStaticPaths() {
  return workxp.map(company => ({
    params: { slug: slugify(company.company) },
    props: { company },
  }));
}

interface Props {
  company: typeof workxp[number];
}

const { company } = Astro.props;
---

<BaseLayout
  title={`${company.company} | Warren de Leon`}
  description={company.positions[0].description.substring(0, 160)}
  locale={locale}
  currentPath={`/es/work/${slugify(company.company)}/`}
>
  <section class="section">
    <div class="container">
      <a href={getLocalePath(locale, '/work-experience/')} class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        {i18n.common.back}
      </a>

      <div class="company-header mt-3">
        <img src={company.logo} alt={company.company} width="56" height="56" class="company-logo" />
        <h1>{company.company}</h1>
      </div>

      {company.positions.map(position => (
        <div class="position card mt-3">
          <div class="position-header">
            <h2>{position.title}</h2>
            <span class="position-date">
              {formatDateRange(position.startDate, position.endDate, locale)}
            </span>
          </div>

          <h3 class="mt-2">{i18n.workExperience.description}</h3>
          <p class="position-desc mt-1">{position.description}</p>

          {position.responsibilities && position.responsibilities.length > 0 && (
            <div class="mt-3">
              <h3>{i18n.workExperience.keyResponsibilities}</h3>
              <ul class="responsibilities mt-1">
                {position.responsibilities.map(r => <li>{r}</li>)}
              </ul>
            </div>
          )}

          {position.technologies && (
            <div class="tech-section mt-3">
              {position.technologies.languages && position.technologies.languages.length > 0 && (
                <div class="tech-group">
                  <h4>{i18n.workExperience.programmingLanguages}</h4>
                  <div class="badge-group mt-1">
                    {position.technologies.languages.map(lang => <TechBadge label={lang} />)}
                  </div>
                </div>
              )}
              {position.technologies.frameworks && position.technologies.frameworks.length > 0 && (
                <div class="tech-group">
                  <h4>{i18n.workExperience.technologyStack}</h4>
                  <div class="badge-group mt-1">
                    {position.technologies.frameworks.map(fw => <TechBadge label={fw} />)}
                  </div>
                </div>
              )}
              {position.technologies.testing?.unit && position.technologies.testing.unit.length > 0 && (
                <div class="tech-group">
                  <h4>{i18n.workExperience.unitTesting}</h4>
                  <div class="badge-group mt-1">
                    {position.technologies.testing.unit.map(t => <TechBadge label={t} />)}
                  </div>
                </div>
              )}
              {position.technologies.testing?.e2e && position.technologies.testing.e2e.length > 0 && (
                <div class="tech-group">
                  <h4>{i18n.workExperience.e2eTesting}</h4>
                  <div class="badge-group mt-1">
                    {position.technologies.testing.e2e.map(t => <TechBadge label={t} />)}
                  </div>
                </div>
              )}
              {position.technologies.tools && position.technologies.tools.length > 0 && (
                <div class="tech-group">
                  <h4>{i18n.workExperience.developmentTools}</h4>
                  <div class="badge-group mt-1">
                    {position.technologies.tools.map(tool => <TechBadge label={tool} />)}
                  </div>
                </div>
              )}
              {position.technologies.ci && position.technologies.ci.length > 0 && (
                <div class="tech-group">
                  <h4>{i18n.workExperience.ciCd}</h4>
                  <div class="badge-group mt-1">
                    {position.technologies.ci.map(ci => <TechBadge label={ci} />)}
                  </div>
                </div>
              )}
              {position.technologies.methodology && position.technologies.methodology.length > 0 && (
                <div class="tech-group">
                  <h4>{i18n.workExperience.agileMethodology}</h4>
                  <div class="badge-group mt-1">
                    {position.technologies.methodology.map(m => <TechBadge label={m} />)}
                  </div>
                </div>
              )}
            </div>
          )}

          {(position as any).client && (
            <div class="client-section mt-3">
              <h3>{i18n.workExperience.clients}</h3>
              <div class="client mt-1">
                <img src={(position as any).client.logo} alt={(position as any).client.name} width="32" height="32" class="client-logo" />
                <span>{(position as any).client.name}</span>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 500;
    font-size: 0.9rem;
  }

  .company-header {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .company-logo {
    border-radius: 10px;
    background: var(--bg-secondary);
    padding: 6px;
  }

  .position-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .position-header h2 {
    font-size: 1.3rem;
  }

  .position-date {
    font-size: 0.85rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .position-desc {
    color: var(--text-secondary);
    line-height: 1.7;
    white-space: pre-line;
  }

  .responsibilities {
    list-style: none;
    padding: 0;
  }

  .responsibilities li {
    padding: 0.4rem 0;
    padding-left: 1.25rem;
    position: relative;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .responsibilities li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.85rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-green);
  }

  .tech-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tech-group h4 {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  .client {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .client-logo {
    border-radius: 6px;
    background: var(--bg-secondary);
    padding: 2px;
  }
</style>
