---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CV from '../../components/CV.astro';
import { t } from '../../i18n/index';
import cv from '../../data/cv-ca.json';

const locale = 'ca' as const;
const i18n = t(locale);
---

<BaseLayout
  title={i18n.seo.cvTitle}
  description={i18n.seo.cvDescription}
  locale={locale}
  currentPath="/ca/cv/"
>
  <CV locale={locale} cv={cv} />
</BaseLayout>
