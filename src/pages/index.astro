---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { t, getLocalePath, slugify, formatDateRange } from '../i18n/index';
import workxp from '../data/workxp-en.json';

const locale = 'en' as const;
const i18n = t(locale);
const currentRole = workxp[0];
const latestPosition = currentRole.positions[0];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Warren de Leon",
  "jobTitle": "Software Engineering Manager",
  "url": "https://warrendeleon.com",
  "image": "https://warrendeleon.com/images/avatar.png",
  "sameAs": [
    "https://linkedin.com/in/warrendeleonofalla",
    "https://x.com/warren_deleon",
    "https://instagram.com/warrendeleon",
    "https://facebook.com/warren.deleon",
    "https://github.com/warrendeleon"
  ]
};
---

<BaseLayout
  title={i18n.seo.homeTitle}
  description={i18n.seo.homeDescription}
  locale={locale}
  currentPath="/"
  jsonLd={jsonLd}
>
  <section class="hero section">
    <div class="container hero-grid">
      <div class="hero-text">
        <h1>{i18n.home.title}</h1>
        <p class="hero-subtitle">{i18n.home.subtitle}</p>
        <div class="hero-social mt-3">
          <SocialLinks />
        </div>
      </div>
      <div class="hero-carousel">
        <HeroCarousel />
      </div>
    </div>
  </section>

  <section class="section" id="about">
    <div class="container">
      <h2 class="section-heading">{i18n.home.aboutHeading}</h2>
      <div class="about-content">
        <div class="about-text">
          {i18n.home.aboutText.split('\n\n').map((paragraph: string) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background: var(--bg-secondary);">
    <div class="container">
      <h2 class="section-heading">{i18n.home.currentRole}</h2>
      <div class="card current-role">
        <div class="current-role-inner">
          <div class="current-role-logo-col">
            <div class="current-role-logo">
              {currentRole.logo && (
                <img src={currentRole.logo} alt={currentRole.company} />
              )}
            </div>
          </div>
          <div class="current-role-content">
            <h3>{currentRole.company}</h3>
            <p class="role-title">{latestPosition.title}</p>
            <p class="role-date text-muted">
              {formatDateRange(latestPosition.startDate, latestPosition.endDate, locale)}
            </p>
            {latestPosition.description && (
              <p class="role-desc mt-2">{latestPosition.description}</p>
            )}
            <a href={getLocalePath(locale, '/work-experience/')} class="btn btn-outline mt-3">
              {i18n.home.viewWorkExperience}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .hero-grid {
    display: grid;
    grid-template-columns: 3fr 7fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-text h1 {
    text-align: left;
    white-space: nowrap;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }

  .hero-social {
    display: flex;
  }

  .hero-carousel {
    display: flex;
    justify-content: center;
  }

  .about-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .about-text {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  .about-text p {
    margin-bottom: 1.25rem;
  }

  .about-text p:first-child {
    font-size: 1.15rem;
    color: var(--text-primary);
    font-weight: 500;
  }

  .about-text p:last-child {
    margin-bottom: 0;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border-color);
    font-style: italic;
    color: var(--text-muted);
  }

  .current-role-inner {
    display: grid;
    grid-template-columns: 15% 1fr;
    gap: 1.5rem;
    align-items: center;
  }

  .current-role-logo-col {
    display: flex;
    justify-content: center;
  }

  .current-role-logo {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: #f5f5f7;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 2px solid var(--border-color);
  }

  .current-role-logo img {
    width: 60%;
    height: 60%;
    object-fit: contain;
  }

  .current-role-content h3 {
    color: var(--color-green);
    font-size: 1.25rem;
  }

  .role-title {
    font-weight: 600;
  }

  .role-date {
    font-size: 0.85rem;
  }

  .role-desc {
    color: var(--text-secondary);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .current-role-inner {
      grid-template-columns: 60px 1fr;
    }
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-text h1 {
      text-align: center;
    }

    .hero-social {
      justify-content: center;
    }

    .hero-carousel {
      order: -1;
    }

    .about-content {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
