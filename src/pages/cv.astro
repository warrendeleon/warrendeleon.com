---
import BaseLayout from '../layouts/BaseLayout.astro';
import CV from '../components/CV.astro';
import { t } from '../i18n/index';
import cv from '../data/cv-en.json';

const locale = 'en' as const;
const i18n = t(locale);
---

<BaseLayout
  title={i18n.seo.cvTitle}
  description={i18n.seo.cvDescription}
  locale={locale}
  currentPath="/cv/"
>
  <CV locale={locale} cv={cv} />
</BaseLayout>
