---
import BaseLayout from '../layouts/BaseLayout.astro';

const locale = 'en' as const;

interface Role {
  title: string;
  location: string;
  url: string;
  closingDate: string;
  team: string;
}

// Roles are synced from the Workday API via the blog-publisher on the minipc.
// If a roles.json exists in src/data, use it. Otherwise fall back to hardcoded.
let myTeamRoles: Role[] = [];
let otherRoles: Role[] = [];

try {
  const rolesFile = await import('../data/hl-roles.json');
  const roles: Role[] = rolesFile.default || rolesFile;
  myTeamRoles = roles.filter(r => r.team === 'my-team');
  otherRoles = roles.filter(r => r.team !== 'my-team');
} catch {
  // Fallback: hardcoded roles
  myTeamRoles = [
    {
      title: 'Software Engineer (React Native) - UCX',
      location: 'London',
      url: 'https://hargreaveslansdown.wd3.myworkdayjobs.com/HargreavesLansdown/job/London/Software-Engineer--React-Native----UCX_R8922',
      closingDate: '2026-04-26',
      team: 'Mobile Platform, UCX-Core',
    },
    {
      title: 'Software Engineer (React Native - Platform) - UCX',
      location: 'London',
      url: 'https://hargreaveslansdown.wd3.myworkdayjobs.com/HargreavesLansdown/job/London/Software-Engineer--React-Native---Platform----UCX_R9031',
      closingDate: '2026-04-26',
      team: 'Mobile Platform, UCX-Core',
    },
  ];
  otherRoles = [
    {
      title: 'Cloud Platform Architect',
      location: 'Bristol (Harbourside), Home Based',
      url: 'https://hargreaveslansdown.wd3.myworkdayjobs.com/HargreavesLansdown/job/Bristol-Harbourside/Cloud-Platform-Architect_R8992-1',
      closingDate: '2026-04-20',
      team: 'Engineering',
    },
    {
      title: 'Cloud Security Engineer',
      location: 'Home Based',
      url: 'https://hargreaveslansdown.wd3.myworkdayjobs.com/HargreavesLansdown/job/Home-Based/Cloud-Security-Engineer_R8969',
      closingDate: '2026-04-20',
      team: 'Engineering',
    },
    {
      title: 'Software Engineer - Core Wealth',
      location: 'London',
      url: 'https://hargreaveslansdown.wd3.myworkdayjobs.com/HargreavesLansdown/job/London/Software-Engineer---Core-Wealth_R8145',
      closingDate: '2026-04-30',
      team: 'Engineering',
    },
    {
      title: 'Software Engineering Manager',
      location: 'Bristol (Harbourside), Home Based',
      url: 'https://hargreaveslansdown.wd3.myworkdayjobs.com/HargreavesLansdown/job/Bristol-Harbourside/Software-Engineering-Manager_R8512-1',
      closingDate: '2026-05-01',
      team: 'Engineering',
    },
  ];
}

const allRolesUrl = 'https://hargreaveslansdown.wd3.myworkdayjobs.com/en-US/HargreavesLansdown?locationCountry=29247e57dbaf46fb855b224e03170bc7&jobFamilyGroup=32c04e37b469014cf1d02d4fcd2301b1';
---

<BaseLayout
  title="Join the team | Warren de Leon"
  description="Current engineering openings on the Mobile Platform team at Hargreaves Lansdown. React Native roles in London, UK."
  locale={locale}
  currentPath="/hiring/"
>
  <section class="section">
    <div class="container">
      <h1 class="section-heading">Join the team</h1>

      <div class="hiring-intro">
        <p>I'm hiring for the <strong>Mobile Platform</strong> squad at <strong>Hargreaves Lansdown</strong>. We're rebuilding HL's mobile app in React Native, a brownfield migration from the existing native iOS and Android apps. The platform team owns the architecture, shared components, and CI/CD pipelines that every mobile squad ships through.</p>
        <p>If you want to work on React Native at scale in a team that values clean architecture, strong testing, and genuine ownership, have a look at the open roles below.</p>
      </div>

      {/* My team roles */}
      {myTeamRoles.length > 0 ? (
        <div class="hiring-roles" id="my-team-roles">
          <h2 class="hiring-roles-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
              <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
            </svg>
            Open roles on my team
          </h2>
          <div class="hiring-role-grid">
            {myTeamRoles.map(role => (
              <a href={role.url} target="_blank" rel="noopener noreferrer" class="hiring-role-card" data-closing-date={role.closingDate} onclick={`t('job_apply',{role:'${role.title.replace(/'/g, "\\'")}'})`}>
                <div class="hiring-role-content">
                  <h3 class="hiring-role-title">{role.title}</h3>
                  <span class="hiring-role-team">Mobile Platform, UCX-Core</span>
                  <span class="hiring-role-location">{role.location}</span>
                </div>
                <span class="hiring-role-cta">
                  Apply now
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                    <polyline points="15 3 21 3 21 9"></polyline>
                    <line x1="10" y1="14" x2="21" y2="3"></line>
                  </svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      ) : (
        <div class="hiring-empty" id="my-team-empty">
          <p>No open roles on my team right now. Check back soon, or connect with me on <a href="https://www.linkedin.com/in/warrendeleon/" target="_blank" rel="noopener noreferrer">LinkedIn</a> to hear about future openings.</p>
        </div>
      )}

      {/* Other HL tech roles */}
      {otherRoles.length > 0 && (
        <div class="hiring-other" id="other-roles">
          <h2 class="hiring-other-title">Other engineering roles at HL</h2>
          <div class="hiring-role-grid">
            {otherRoles.map(role => (
              <a href={role.url} target="_blank" rel="noopener noreferrer" class="hiring-role-card hiring-role-card--secondary" data-closing-date={role.closingDate} onclick={`t('job_apply',{role:'${role.title.replace(/'/g, "\\'")}'})`}>
                <div class="hiring-role-content">
                  <h3 class="hiring-role-title">{role.title}</h3>
                  <span class="hiring-role-location">{role.location}</span>
                </div>
                <span class="hiring-role-cta">
                  View role
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                    <polyline points="15 3 21 3 21 9"></polyline>
                    <line x1="10" y1="14" x2="21" y2="3"></line>
                  </svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="hiring-all-roles">
        <p>Looking for more roles at Hargreaves Lansdown?</p>
        <a href={allRolesUrl} target="_blank" rel="noopener noreferrer" class="hiring-all-roles-link">
          View all HL roles on Workday
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
            <polyline points="15 3 21 3 21 9"></polyline>
            <line x1="10" y1="14" x2="21" y2="3"></line>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .hiring-intro {
    max-width: 720px;
    margin-bottom: 2.5rem;
  }

  .hiring-intro p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .hiring-intro strong {
    color: var(--text-primary);
  }

  .hiring-roles-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .hiring-roles-title svg {
    color: var(--color-green);
  }

  .hiring-role-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hiring-role-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    box-shadow: var(--shadow);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .hiring-role-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
  }

  .hiring-role-card--secondary {
    padding: 1.25rem 1.5rem;
  }

  .hiring-role-card--secondary .hiring-role-title {
    font-size: 1rem;
  }

  .hiring-role-content {
    display: flex;
    flex-direction: column;
  }

  .hiring-role-title {
    font-size: 1.1rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
    transition: color 0.2s ease;
  }

  .hiring-role-card:hover .hiring-role-title {
    color: var(--color-green);
  }

  .hiring-role-team {
    font-size: 0.95rem;
    color: var(--color-green);
    font-weight: 600;
    margin-bottom: 0.2rem;
  }

  .hiring-role-location {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .hiring-role-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-green);
    white-space: nowrap;
    transition: gap 0.2s ease;
  }

  .hiring-role-card:hover .hiring-role-cta {
    gap: 0.6rem;
  }

  .hiring-empty {
    padding: 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    text-align: center;
  }

  .hiring-empty p {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .hiring-empty a {
    color: var(--color-green);
    font-weight: 600;
  }

  .hiring-other {
    margin-top: 3rem;
  }

  .hiring-other-title {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
  }

  .hiring-all-roles {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
    text-align: center;
  }

  .hiring-all-roles p {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .hiring-all-roles-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-green);
    text-decoration: none;
    transition: gap 0.2s ease;
  }

  .hiring-all-roles-link:hover {
    gap: 0.6rem;
  }

  @media (max-width: 768px) {
    .hiring-role-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
</style>

<script>
  const today = new Date().toISOString().slice(0, 10);

  function pruneExpired(containerId: string, emptyId?: string) {
    const container = document.getElementById(containerId);
    if (!container) return;
    const cards = container.querySelectorAll('.hiring-role-card[data-closing-date]');
    let visible = cards.length;

    cards.forEach(card => {
      const closing = card.getAttribute('data-closing-date');
      if (closing && today > closing) {
        card.remove();
        visible--;
      }
    });

    if (visible === 0) {
      container.style.display = 'none';
      if (emptyId) {
        const empty = document.getElementById(emptyId);
        if (empty) empty.style.display = 'block';
      }
    }
  }

  pruneExpired('my-team-roles', 'my-team-empty');
  pruneExpired('other-roles');
</script>
