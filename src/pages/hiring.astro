---
import BaseLayout from '../layouts/BaseLayout.astro';

const locale = 'en' as const;

const openRoles = [
  {
    title: 'Software Engineer — React Native',
    team: 'Mobile Platform, UCX-Core',
    location: 'London, UK (Hybrid)',
    url: 'https://www.linkedin.com/jobs/view/4391097156/',
  },
];
---

<BaseLayout
  title="Join the team | Warren de Leon"
  description="Current engineering openings on the Mobile Platform team at Hargreaves Lansdown. React Native roles in London, UK."
  locale={locale}
  currentPath="/hiring/"
>
  <section class="section">
    <div class="container">
      <h1 class="section-heading">Join the team</h1>

      <div class="hiring-intro">
        <p>I'm hiring for the <strong>Mobile Platform</strong> squad at <strong>Hargreaves Lansdown</strong>. We're rebuilding HL's mobile app in React Native, a brownfield migration from the existing native iOS and Android apps. The platform team owns the architecture, shared components, and CI/CD pipelines that every mobile squad ships through.</p>
        <p>If you want to work on React Native at scale in a team that values clean architecture, strong testing, and genuine ownership, have a look at the open roles below.</p>
      </div>

      {openRoles.length > 0 ? (
        <div class="hiring-roles">
          <h2 class="hiring-roles-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
              <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
            </svg>
            Open roles
          </h2>
          <div class="hiring-role-grid">
            {openRoles.map(role => (
              <a href={role.url} target="_blank" rel="noopener noreferrer" class="hiring-role-card">
                <div class="hiring-role-content">
                  <h3 class="hiring-role-title">{role.title}</h3>
                  <span class="hiring-role-team">{role.team}</span>
                  <span class="hiring-role-location">{role.location}</span>
                </div>
                <span class="hiring-role-cta">
                  Apply on LinkedIn
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                    <polyline points="15 3 21 3 21 9"></polyline>
                    <line x1="10" y1="14" x2="21" y2="3"></line>
                  </svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      ) : (
        <div class="hiring-empty">
          <p>No open roles right now. Check back soon, or connect with me on <a href="https://www.linkedin.com/in/warrendeleon/" target="_blank" rel="noopener noreferrer">LinkedIn</a> to hear about future openings.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style is:global>
  .hiring-intro {
    max-width: 720px;
    margin-bottom: 2.5rem;
  }

  .hiring-intro p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .hiring-intro strong {
    color: var(--text-primary);
  }

  .hiring-roles-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .hiring-roles-title svg {
    color: var(--color-green);
  }

  .hiring-role-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hiring-role-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    box-shadow: var(--shadow);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .hiring-role-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
  }

  .hiring-role-content {
    display: flex;
    flex-direction: column;
  }

  .hiring-role-title {
    font-size: 1.1rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
    transition: color 0.2s ease;
  }

  .hiring-role-card:hover .hiring-role-title {
    color: var(--color-green);
  }

  .hiring-role-team {
    font-size: 0.95rem;
    color: var(--color-green);
    font-weight: 600;
    margin-bottom: 0.2rem;
  }

  .hiring-role-location {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .hiring-role-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-green);
    white-space: nowrap;
    transition: gap 0.2s ease;
  }

  .hiring-role-card:hover .hiring-role-cta {
    gap: 0.6rem;
  }

  .hiring-empty {
    padding: 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    text-align: center;
  }

  .hiring-empty p {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .hiring-empty a {
    color: var(--color-green);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .hiring-role-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
</style>
