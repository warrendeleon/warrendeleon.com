---
import BlogListing from '../../components/blog/BlogListing.astro';
import { getPostsForLocale } from '../../utils/blogHelpers';

export async function getStaticPaths({ paginate }: any) {
  // All posts in strict newest-to-oldest order (getPostsForLocale sorts
  // descending). The current series is also featured in its own hero card
  // above the feed, but the design lists All posts by date, so its parts
  // stay inline here rather than being demoted to the end.
  const posts = await getPostsForLocale('en');
  return paginate(posts, { pageSize: 12 });
}

const { page } = Astro.props;
---

<BlogListing locale="en" page={page} />
