---
import BlogListing from '../../components/blog/BlogListing.astro';
import { getPostsForLocale, getCurrentSeriesName } from '../../utils/blogHelpers';

export async function getStaticPaths({ paginate }: any) {
  const posts = await getPostsForLocale('en');
  // Demote the current-series hero's parts to the end of the feed (never remove:
  // that shrank pagination and 404'd indexed page URLs). Use getCurrentSeriesName
  // so this matches the hero (most recent series with 2+ parts); the newest post's
  // series alone would drop that post from the feed during a mini-series break.
  const currentSeries = await getCurrentSeriesName('en');
  const feed = currentSeries
    ? [...posts.filter(p => p.data.series !== currentSeries), ...posts.filter(p => p.data.series === currentSeries)]
    : posts;
  return paginate(feed, { pageSize: 12 });
}

const { page } = Astro.props;
---

<BlogListing locale="en" page={page} />
