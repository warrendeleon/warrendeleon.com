---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { t } from '../../i18n/index';
import type { Locale } from '../../i18n/index';
import { getReadingTime } from '../../utils/readingTime';

const locale: Locale = 'en';
const i18n = t(locale);

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

function toDateString(date: Date): string {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  return `${y}-${m}-${d}`;
}
---

<BaseLayout
  title={i18n.seo.blogTitle}
  description={i18n.seo.blogDescription}
  locale={locale}
  currentPath="/blog/"
>
  <section class="section">
    <div class="container">
      <h1 class="section-heading">Blog</h1>

      <div class="blog-grid">
        {posts.map(post => (
          <a
            href={`/blog/${post.id}/`}
            class:list={['blog-card', 'card', { 'blog-card-with-image': post.data.heroImage }]}
            data-publish-date={toDateString(post.data.publishDate)}
          >
            {post.data.heroImage && (
              <div class="blog-card-image">
                <img src={post.data.heroImage} alt={post.data.heroAlt || post.data.title} loading="lazy" />
              </div>
            )}
            <div class="blog-card-content">
              <span class="blog-card-meta">
                {formatDate(post.data.publishDate)} &middot; {getReadingTime(post.body ?? '')} min read
              </span>
              <h2 class="blog-card-title">{post.data.title}</h2>
              <p class="blog-card-desc">{post.data.description}</p>
              <div class="blog-card-tags">
                {post.data.tags.map(tag => (
                  <span class="blog-tag">{tag}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>

      <p id="blog-empty" class="blog-empty" style="display: none;">No posts yet. Check back soon.</p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
(function () {
  function filterPosts() {
    var now = new Date();
    var todayStr = now.getFullYear() + '-' +
      String(now.getMonth() + 1).padStart(2, '0') + '-' +
      String(now.getDate()).padStart(2, '0');
    var cards = document.querySelectorAll('.blog-card[data-publish-date]');
    var visibleCount = 0;
    cards.forEach(function (card) {
      var publishStr = card.getAttribute('data-publish-date');
      if (publishStr > todayStr) {
        card.style.display = 'none';
      } else {
        visibleCount++;
      }
    });
    var emptyMsg = document.getElementById('blog-empty');
    if (emptyMsg) emptyMsg.style.display = visibleCount === 0 ? 'block' : 'none';
  }
  filterPosts();
})();
</script>

<style is:global>
  .blog-grid {
    display: grid;
    gap: 1.5rem;
  }

  .blog-card {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    border-left: 3px solid var(--color-green);
    overflow: hidden;
  }

  .blog-card-with-image {
    border-left: none;
  }

  .blog-card-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .blog-card:hover .blog-card-image img {
    transform: scale(1.03);
  }

  .blog-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
  }

  .blog-card:hover .blog-card-title {
    color: var(--color-green);
  }

  .blog-card-meta {
    font-size: 0.85rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: 0.5rem;
  }

  .blog-card-title {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    transition: color 0.2s ease;
    line-height: 1.3;
  }

  .blog-card-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .blog-tag {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--badge-bg);
    color: var(--badge-text);
    border: 1px solid var(--border-color);
  }

  .blog-empty {
    text-align: center;
    color: var(--text-muted);
    font-size: 1rem;
    margin-top: 2rem;
  }
</style>
