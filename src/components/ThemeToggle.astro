---
import { t, type Locale } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);
---

<!-- Design: a plain round icon button — moon in light mode (tap for dark),
     sun in dark mode (tap for light). Same #theme-toggle + data-label
     contract as before; BaseLayout's click handler is unchanged. -->
<button class="theme-toggle" id="theme-toggle" type="button" aria-label={i18n.a11y.switchTheme} data-label-light={i18n.a11y.switchToLight} data-label-dark={i18n.a11y.switchToDark}>
  <svg class="theme-toggle-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
  <svg class="theme-toggle-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <line x1="12" y1="2" x2="12" y2="5"></line>
    <line x1="12" y1="19" x2="12" y2="22"></line>
    <line x1="2" y1="12" x2="5" y2="12"></line>
    <line x1="19" y1="12" x2="22" y2="12"></line>
    <line x1="4.9" y1="4.9" x2="7" y2="7"></line>
    <line x1="17" y1="17" x2="19.1" y2="19.1"></line>
    <line x1="4.9" y1="19.1" x2="7" y2="17"></line>
    <line x1="17" y1="7" x2="19.1" y2="4.9"></line>
  </svg>
</button>

<style is:global>
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    flex-shrink: 0;
    border: none;
    border-radius: 19px;
    background: transparent;
    color: var(--text-primary);
    cursor: pointer;
    padding: 0;
    transition: background 0.2s ease;
  }

  .theme-toggle:hover {
    background: var(--bg-secondary);
  }

  .theme-toggle .theme-toggle-sun { display: none; }
  .theme-toggle .theme-toggle-moon { display: block; }
  [data-theme="dark"] .theme-toggle .theme-toggle-sun { display: block; }
  [data-theme="dark"] .theme-toggle .theme-toggle-moon { display: none; }

  @media (max-width: 1023px) {
    .theme-toggle {
      width: 40px;
      height: 40px;
      border-radius: 20px;
    }
  }
</style>
