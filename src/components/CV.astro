---
import { t, type Locale } from '../i18n/index';

interface Props {
  locale: Locale;
  cv: any;
}

const { locale, cv } = Astro.props;
const i18n = t(locale);

// Each locale downloads its own pre-generated PDF (see scripts/generate-cv-pdfs.mjs).
const pdfHref =
  locale === 'en'
    ? '/pdf/CV_WARRENDELEON_2026.pdf'
    : `/pdf/CV_WARRENDELEON_2026_${locale.toUpperCase()}.pdf`;

const bold = (text: string) => text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
---

<article class="cv-canvas">
  <div class="cv-paper">

    <header class="cv-hero">
      <img class="cv-hero-avatar" src="/images/warren-deleon-headshot.webp" alt="Warren de Leon" width="112" height="112" loading="eager" />
      <p class="cv-eyebrow">{cv.role}</p>
      <h1 class="cv-name">Warren <span>de Leon</span></h1>
      <a href={pdfHref} download class="btn btn-primary cv-download" onclick={`t('cv_download',{locale:'${locale}'})`}>
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        {i18n.cv.downloadPdf}
      </a>
      <div class="cv-hero-divider"></div>
      <div class="cv-contact">
        <a href={`mailto:${cv.contact.email}`}>
          <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"></path></svg>
          {cv.contact.email}
        </a>
        <a href={`tel:${cv.contact.phone}`}>
          <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"></path></svg>
          {cv.contact.phone}
        </a>
        <a href={`https://${cv.contact.website}`} target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="M2 12h20M12 2a15.3 15.3 0 0 1 0 20 15.3 15.3 0 0 1 0-20"></path></svg>
          {cv.contact.website}
        </a>
        <span class="cv-contact-status">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"></path></svg>
          {cv.contact.status}
        </span>
        <a href={`https://${cv.contact.linkedin}`} target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8.34 17v-6.5H6.17V17h2.17zM7.25 9.5a1.26 1.26 0 1 0 0-2.52 1.26 1.26 0 0 0 0 2.52zM18 17v-3.57c0-1.9-1.01-2.78-2.36-2.78-1.09 0-1.58.6-1.85 1.02v-.87h-2.17V17h2.17v-3.5c0-.92.17-1.81 1.31-1.81 1.12 0 1.13 1.05 1.13 1.88V17H18z"></path></svg>
          {cv.contact.linkedin}
        </a>
        <a href={`https://${cv.contact.github}`} target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.37.5 0 5.87 0 12.5c0 4.42 2.87 8.17 6.84 9.5.5.09.66-.22.66-.48 0-.24-.01-.87-.01-1.7-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02.8-.22 1.65-.33 2.5-.34.85.01 1.7.12 2.5.34 1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85 0 1.34-.01 2.42-.01 2.75 0 .27.16.58.67.48A10.01 10.01 0 0 0 22 12.5C24 5.87 18.63.5 12 .5z"></path></svg>
          {cv.contact.github}
        </a>
      </div>
    </header>

    <section class="cv-block">
      <h2 class="cv-heading">{i18n.cv.profile}</h2>
      <p class="cv-profile">{cv.profile}</p>
    </section>

    <section class="cv-block">
      <h2 class="cv-heading">{i18n.cv.experience}</h2>

      {cv.experience.map((job: any) => (
        <div class="cv-exp">
          <div class="cv-exp-head">
            <h3 class="cv-company">{job.company}</h3>
            <span class="cv-dates">{job.dates}</span>
          </div>
          <p class="cv-role">{job.role}</p>
          <p class="cv-summary">{job.summary}</p>
          {job.bullets && (
            <ul class="cv-bullets">
              {job.bullets.map((b: string) => <li set:html={bold(b)} />)}
            </ul>
          )}
          {job.tech && <p class="cv-tech">{job.tech}</p>}
          {job.subRole && (
            <div class="cv-subrole">
              <div class="cv-exp-head">
                <h4 class="cv-role cv-role-head">{job.subRole.role}</h4>
                <span class="cv-dates">{job.subRole.dates}</span>
              </div>
              <p class="cv-summary">{job.subRole.summary}</p>
              <p class="cv-tech">{job.subRole.tech}</p>
            </div>
          )}
        </div>
      ))}

      {cv.experienceCompact.map((job: any) => (
        <div class="cv-exp cv-exp-compact">
          <div class="cv-exp-head">
            <h3 class="cv-company-compact">{job.company} <span>{job.role}</span></h3>
            <span class="cv-dates">{job.dates}</span>
          </div>
          <p class="cv-summary" set:html={bold(job.summary)} />
          <p class="cv-tech">{job.tech}</p>
        </div>
      ))}

      <h3 class="cv-subheading">{i18n.cv.earlierCareer}</h3>
      <ul class="cv-earlier">
        {cv.earlier.map((job: any) => (
          <li>
            <span class="cv-earlier-what">
              <strong>{job.company}</strong> — {job.role}{job.stack && <span class="cv-earlier-stack"> · {job.stack}</span>}
            </span>
            <span class="cv-earlier-when">{job.dates}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="cv-block">
      <h2 class="cv-heading">{i18n.cv.skills}</h2>
      <div class="cv-skills">
        {cv.skills.map((cat: any) => (
          <div class="cv-skill-row">
            <span class="cv-skill-label">{cat.label}</span>
            <div class="cv-chips">
              {cat.items.map((item: string) => (
                <span class={`cv-chip${cat.emphasis ? ' cv-chip-strong' : ''}`}>{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="cv-block">
      <h2 class="cv-heading">{i18n.cv.education}</h2>
      <ul class="cv-edu">
        {cv.education.map((e: any) => (
          <li>
            <span class="cv-edu-title">{e.title} <span class="cv-edu-inst">· {e.institution}</span></span>
            <span class="cv-edu-when">{e.dates}</span>
          </li>
        ))}
      </ul>
      <div class="cv-chips cv-certs">
        {cv.certs.map((c: string) => <span class="cv-chip">{c}</span>)}
      </div>
    </section>

    <section class="cv-block">
      <h2 class="cv-heading">{i18n.cv.languages}</h2>
      <div class="cv-languages">
        {cv.languages.map((l: any) => (
          <div class="cv-lang">
            <span class="cv-lang-name">{l.name}</span>
            <span class={`cv-lang-level${l.muted ? ' muted' : ''}`}>{l.level}</span>
          </div>
        ))}
      </div>
    </section>

  </div>
</article>

<a href={pdfHref} download class="cv-fab" aria-label={i18n.cv.downloadPdf} onclick={`t('cv_download',{locale:'${locale}'})`} hidden>
  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
  <span>{i18n.cv.downloadPdf}</span>
</a>

<script is:inline>
  (function () {
    var fab = document.querySelector('.cv-fab');
    if (!fab) return;
    // Show the floating download once the hero (with its own button) is scrolled past.
    function toggle() { fab.hidden = window.scrollY < 460; }
    window.addEventListener('scroll', toggle, { passive: true });
    toggle();
  })();
</script>

<style>
  /* ---------- Document: sheet on a canvas ---------- */
  .cv-canvas {
    background: var(--bg-secondary);
    padding: 2.5rem 1rem;
  }
  :global([data-theme="dark"]) .cv-canvas {
    background: var(--bg-primary);
  }
  .cv-paper {
    /* The CV is a printed white page: keep the sheet light in both themes and
       let only the canvas behind it follow the dark theme. */
    --bg-card: #ffffff;
    --bg-secondary: #f5f5f7;
    --text-primary: #0e0c19;
    --text-secondary: #555;
    --text-muted: #666;
    --border-color: #e0e0e0;
    --badge-bg: #f0f0f0;
    --badge-text: #333;
    max-width: 880px;
    margin: 0 auto;
    background: #ffffff;
    color: var(--text-primary);
    border: 1px solid var(--border-color);
    border-radius: 20px;
    box-shadow: var(--shadow-hover);
    padding: clamp(1.5rem, 4vw, 3rem);
  }

  /* ---------- Hero (always dark, mirrors the printed CV) ---------- */
  .cv-hero {
    position: relative;
    overflow: hidden;
    background: #0e0c19;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 18px;
    padding: 2.1rem 2.4rem;
    color: #fff;
    margin-bottom: 2.5rem;
  }
  .cv-hero::before {
    content: "";
    position: absolute;
    top: -80px;
    right: -50px;
    width: 320px;
    height: 320px;
    background: radial-gradient(circle, rgba(109, 196, 2, 0.22), transparent 64%);
    pointer-events: none;
  }
  .cv-hero-avatar {
    float: right;
    position: relative;
    z-index: 1;
    width: 112px;
    height: 112px;
    margin: 0.1rem 0 1rem 1.6rem;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 0 0 3px var(--color-green), 0 0 0 9px rgba(109, 196, 2, 0.18);
  }
  .cv-eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-green);
  }
  .cv-name {
    font-size: 2.8rem;
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.03em;
    margin: 0.5rem 0 0;
    color: #fff;
  }
  .cv-name span { color: #8fd640; }
  .cv-download { margin-top: 1.25rem; }
  .cv-hero-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.12);
    margin: 1.3rem 0 1.1rem;
    clear: right;
  }
  .cv-contact {
    display: grid;
    grid-auto-flow: column;
    grid-template-rows: repeat(3, auto);
    grid-template-columns: 1fr 1fr;
    gap: 0.62rem 2rem;
    font-size: 0.85rem;
    color: #d7d7dd;
  }
  .cv-contact a,
  .cv-contact-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #d7d7dd;
    text-decoration: none;
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .cv-contact a { transition: color 0.2s ease; }
  .cv-contact a:hover { color: #8fd640; }
  .cv-contact svg { flex: none; color: var(--color-green); }

  /* ---------- Section blocks ---------- */
  .cv-block { margin-bottom: 2.5rem; }
  .cv-block:last-of-type { margin-bottom: 0; }
  .cv-heading {
    font-size: 1.45rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 3px solid var(--color-green);
    display: inline-block;
  }
  .cv-profile {
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 47rem;
  }

  /* ---------- Experience ---------- */
  .cv-exp {
    padding-bottom: 1.25rem;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--border-color);
  }
  .cv-exp:last-of-type { border-bottom: none; }
  .cv-exp-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }
  .cv-company { font-size: 1.1rem; font-weight: 700; }
  .cv-dates {
    font-size: 0.82rem;
    color: var(--text-muted);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  .cv-role {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-green);
    margin-top: 0.15rem;
  }
  .cv-summary {
    margin: 0.55rem 0 0;
    color: var(--text-secondary);
    line-height: 1.6;
    font-size: 0.95rem;
  }
  .cv-bullets {
    list-style: none;
    margin: 0.7rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .cv-bullets li {
    position: relative;
    padding-left: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.55;
    font-size: 0.92rem;
  }
  .cv-bullets li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    background: var(--color-green);
    border-radius: 1px;
  }
  .cv-tech {
    margin-top: 0.7rem;
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', ui-monospace, monospace;
    font-size: 0.78rem;
    color: var(--text-muted);
  }
  .cv-subrole {
    margin-top: 0.95rem;
    padding-top: 0.85rem;
    border-top: 1px dashed var(--border-color);
  }
  .cv-role-head { margin-top: 0; }

  .cv-company-compact { font-size: 1.02rem; font-weight: 700; }
  .cv-company-compact span { color: var(--color-green); font-weight: 600; font-size: 0.92rem; }

  .cv-subheading {
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-primary);
    margin: 0.3rem 0 1rem;
  }
  .cv-earlier { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .cv-earlier li {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: baseline;
  }
  .cv-earlier-what { color: var(--text-secondary); font-size: 0.92rem; }
  .cv-earlier-what strong { color: var(--text-primary); }
  .cv-earlier-stack { color: var(--text-muted); }
  .cv-earlier-when {
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  /* ---------- Chips (skills, certs) ---------- */
  .cv-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .cv-chip {
    padding: 0.28rem 0.65rem;
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 500;
    background: var(--badge-bg);
    color: var(--badge-text);
    border: 1px solid var(--border-color);
  }
  .cv-chip-strong {
    border-color: var(--color-green);
    color: var(--color-green);
    font-weight: 600;
  }

  .cv-skills { display: flex; flex-direction: column; gap: 0.85rem; }
  .cv-skill-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 1rem;
    align-items: start;
  }
  .cv-skill-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-muted);
    padding-top: 0.35rem;
  }

  /* ---------- Education ---------- */
  .cv-edu { list-style: none; padding: 0; margin: 0 0 0.9rem; display: flex; flex-direction: column; gap: 0.65rem; }
  .cv-edu li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .cv-edu-title { font-weight: 600; }
  .cv-edu-inst { font-weight: 500; color: var(--text-muted); }
  .cv-edu-when {
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  .cv-certs .cv-chip { font-size: 0.72rem; }

  /* ---------- Languages ---------- */
  .cv-languages { display: flex; flex-wrap: wrap; gap: 1rem 1.6rem; }
  .cv-lang { display: flex; align-items: baseline; gap: 0.5rem; }
  .cv-lang-name { font-weight: 600; }
  .cv-lang-level { font-size: 0.82rem; color: var(--color-green); font-weight: 600; }
  .cv-lang-level.muted { color: var(--text-muted); }

  /* ---------- Floating download ---------- */
  .cv-fab {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.15rem;
    border-radius: 999px;
    background: var(--color-green);
    color: var(--color-white);
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    box-shadow: var(--shadow-hover);
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .cv-fab:hover { background: var(--color-green-dark); transform: translateY(-2px); }
  .cv-fab[hidden] { display: none; }

  @media (max-width: 768px) {
    .cv-canvas { padding: 1.25rem 0.75rem; }
    .cv-hero { padding: 1.75rem 1.5rem; text-align: center; }
    .cv-hero-avatar { float: none; display: block; margin: 0 auto 1rem; }
    .cv-hero-divider { clear: both; }
    .cv-contact {
      grid-auto-flow: row;
      grid-template-columns: 1fr;
      grid-template-rows: none;
      justify-items: center;
      gap: 0.55rem;
    }
    .cv-name { font-size: 2.2rem; }
    .cv-exp-head { flex-direction: column; gap: 0.1rem; }
    .cv-skill-row { grid-template-columns: 1fr; gap: 0.35rem; }
    .cv-skill-label { padding-top: 0; }
    .cv-earlier li { grid-template-columns: 1fr; gap: 0.1rem; }
    .cv-fab { bottom: 1rem; right: 1rem; }
  }
</style>
