---
import { t, getLocalePath, type Locale } from '../i18n/index';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const i18n = t(locale);

const home = getLocalePath(locale, '/');
const tabs = [
  { label: i18n.tabs.home, href: home, key: 'home' },
  { label: i18n.tabs.blog, href: getLocalePath(locale, '/blog/'), key: 'blog' },
  { label: i18n.tabs.work, href: getLocalePath(locale, '/work-experience/'), key: 'work' },
  { label: i18n.tabs.book, href: getLocalePath(locale, '/book-a-call/'), key: 'book' },
];

// Home is active only on the exact home path; the others match their section
// so nested pages (a blog post, a work-detail page) keep their tab lit.
function isActive(tab: (typeof tabs)[number]): boolean {
  if (tab.key === 'home') return currentPath === home;
  return currentPath.startsWith(tab.href);
}

const icons: Record<string, string> = {
  home: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline>',
  blog: '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>',
  work: '<rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>',
  book: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>',
};
---

<nav class="tab-bar" aria-label={i18n.a11y.mainNavigation}>
  {tabs.map((tab) => (
    <a
      href={tab.href}
      class:list={['tab-bar-item', { active: isActive(tab) }]}
      aria-current={isActive(tab) ? 'page' : undefined}
    >
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width={isActive(tab) ? '2.2' : '2'}
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        set:html={icons[tab.key]}
      />
      <span class="tab-bar-label">{tab.label}</span>
    </a>
  ))}
</nav>

<style>
  /* ≤699px: full-width fixed tab bar. 700–1023px: floating pill dock.
     ≥1024px: hidden — the sticky top nav takes over. */
  .tab-bar {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 430px;
    z-index: 60;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    padding: 8px 8px calc(14px + var(--safe-bottom));
    background: var(--bg-nav);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-top: 1px solid var(--border-color);
  }

  .tab-bar-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 6px 0;
    min-height: 44px;
    border-radius: 20px;
    color: var(--text-muted);
    font-size: 10px;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .tab-bar-item:hover {
    color: var(--text-primary);
  }

  .tab-bar-item.active {
    color: var(--color-green-text);
    font-weight: 700;
  }

  .tab-bar-label {
    line-height: 1.2;
  }

  @media (min-width: 700px) {
    .tab-bar {
      bottom: calc(16px + var(--safe-bottom));
      width: auto;
      max-width: none;
      display: flex;
      gap: 4px;
      padding: 7px 10px;
      border: 1px solid var(--border-color);
      border-radius: 32px;
      box-shadow: var(--shadow-dock);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
    }

    .tab-bar-item {
      width: 84px;
    }

    .tab-bar-item.active {
      background: var(--badge-bg);
    }
  }

  /* Desktop = wide AND mouse-driven. A 1366px iPad Pro in landscape reports
     hover:none/pointer:coarse and keeps the dock — width alone can't tell
     a touch tablet from a small laptop window. */
  @media (min-width: 1280px) and (hover: hover) and (pointer: fine) {
    .tab-bar {
      display: none;
    }
  }
</style>
