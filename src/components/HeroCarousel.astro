---
import { t, type Locale } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);

const photos = [
  'warren-1.webp', 'warren-2.webp', 'warren-3.webp',
  'profile-01.webp', 'profile-02.webp', 'profile-03.webp',
  'profile-04.webp', 'profile-05.webp', 'profile-06.webp',
  'profile-07.webp', 'profile-08.webp', 'profile-09.webp',
  'profile-10.webp', 'profile-11.webp', 'profile-12.webp',
];
---

<div class="carousel" id="hero-carousel" role="region" aria-label={i18n.a11y.photoCarousel} aria-roledescription="carousel">
  <div class="carousel-frame">
  {/* The photos are presentational; the region label describes the widget and
      the controls stay in the accessibility tree. Hiding the track spares
      screen-reader users 15 near-identical stops. */}
  <div class="carousel-track" id="carousel-track" aria-hidden="true">
    {photos.map((photo, i) => (
      <div class="carousel-slide">
        <img
          src={`/images/photos/${photo}`}
          alt=""
          loading={i === 0 ? 'eager' : 'lazy'}
          width="1200"
          height="800"
        />
      </div>
    ))}
  </div>
  <button class="carousel-btn carousel-btn-prev" id="carousel-prev" type="button" aria-label={i18n.a11y.previousPhoto}>
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
  </button>
  <button class="carousel-btn carousel-btn-next" id="carousel-next" type="button" aria-label={i18n.a11y.nextPhoto}>
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6" /></svg>
  </button>
  <span class="carousel-counter" id="carousel-counter" aria-hidden="true">1 / 15</span>
  <!-- Mobile design: gradient + name/role over the photo. The slot content
       is decorative (the page keeps its real h1); shown <700px only. -->
  <div class="carousel-overlay">
    <div class="carousel-overlay-gradient" aria-hidden="true"></div>
    <slot name="overlay" />
  </div>
  </div>
  <!-- Design: dot indicators sit BELOW the photo frame (≥700px). -->
  <div class="carousel-controls">
    <div class="carousel-dots" id="carousel-dots">
      {photos.map((_, i) => (
        <button
          class:list={['carousel-dot', { active: i === 0 }]}
          type="button"
          aria-label={i18n.a11y.goToPhoto.replace('{n}', String(i + 1))}
          aria-current={i === 0 ? 'true' : undefined}
          data-index={i}
        />
      ))}
    </div>
    <button class="carousel-pause" id="carousel-pause" type="button" aria-label={i18n.a11y.pauseCarousel} data-label-pause={i18n.a11y.pauseCarousel} data-label-play={i18n.a11y.playCarousel}>
      <svg class="icon-pause" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
        <rect x="6" y="4" width="4" height="16"></rect>
        <rect x="14" y="4" width="4" height="16"></rect>
      </svg>
      <svg class="icon-play" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="display:none;">
        <polygon points="5 3 19 12 5 21 5 3"></polygon>
      </svg>
    </button>
  </div>
</div>

<style>
  .carousel {
    position: relative;
    width: 100%;
  }

  /* The frame holds the photo visuals; the dot row lives below it. */
  .carousel-frame {
    position: relative;
    width: 100%;
    max-height: 500px;
    overflow: hidden;
    border-radius: 20px;
    background: var(--bg-secondary);
    box-shadow: var(--shadow-lift);
  }

  @media (min-width: 1024px) {
    .carousel-frame {
      aspect-ratio: 4 / 4.4;
      max-height: none;
    }
  }

  .carousel-track {
    display: flex;
    height: 100%;
    transition: transform 0.4s ease;
  }

  .carousel-slide {
    min-width: 100%;
    height: 100%;
  }

  .carousel-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.4);
    color: white;
    border: none;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease;
    z-index: 2;
  }

  .carousel-btn:hover {
    background: rgba(0, 0, 0, 0.7);
  }

  .carousel-btn-prev {
    left: 8px;
  }

  .carousel-btn-next {
    right: 8px;
  }

  .carousel-counter {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(0, 0, 0, 0.5);
    color: white;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    border-radius: 12px;
    z-index: 2;
  }

  /* Design: dot row below the photo — 6px pills, the active one widens to
     20px. Pause stays for a11y, restyled to match the quiet row. */
  .carousel-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 14px;
  }

  .carousel-dots {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 5px;
  }

  .carousel-dot {
    width: 6px;
    height: 6px;
    border-radius: 3px;
    border: none;
    background: var(--border-color);
    cursor: pointer;
    padding: 0;
    transition: width 0.25s ease, background 0.25s ease;
    position: relative;
  }

  .carousel-dot::before {
    content: '';
    position: absolute;
    top: -10px;
    left: -6px;
    right: -6px;
    bottom: -10px;
  }

  .carousel-dot.active {
    width: 20px;
    background: var(--color-green);
  }

  .carousel-pause {
    background: transparent;
    color: var(--text-muted);
    border: none;
    border-radius: 50%;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    margin-left: 4px;
    transition: color 0.2s ease;
  }

  .carousel-pause:hover {
    color: var(--text-primary);
  }

  /* Overlay title block: mobile only (design). Desktop keeps the photo clean
     and the title lives in the hero's left column. */
  .carousel-overlay { display: none; }

  /* Stacked-hero band (matches the hero's 1023px boundary): counter +
     arrows only, no dot row, name overlaid on the photo. */
  @media (max-width: 1023px) {
    .carousel-controls { display: none; }
    .carousel-frame { border-radius: 20px; aspect-ratio: 4 / 3.4; }
    .carousel-slide img { height: 100%; object-fit: cover; object-position: center top; }

    .carousel-overlay {
      display: block;
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 2;
    }
    .carousel-overlay-gradient {
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, transparent 40%, rgba(10, 10, 12, 0.45) 65%, rgba(10, 10, 12, 0.92) 100%);
    }
    .carousel-overlay :global(.hero-overlay-text) {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      padding: 0 18px 16px;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .carousel-overlay :global(.hero-overlay-eyebrow) {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--color-green);
    }
    .carousel-overlay :global(.hero-overlay-name) {
      font-size: 30px;
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.1;
      color: #ffffff;
    }

    /* Controls move up clear of the overlay text; counter matches design. */
    .carousel-btn { top: 42%; transform: translateY(-50%); width: 34px; height: 34px; }
    .carousel-counter { top: 10px; bottom: auto; right: 12px; }
  }
</style>

<script>
  const track = document.getElementById('carousel-track');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');
  const dotsContainer = document.getElementById('carousel-dots');
  const dots = dotsContainer?.querySelectorAll('.carousel-dot');
  const counter = document.getElementById('carousel-counter');
  const slideCount = dots?.length || 0;
  let current = 0;
  let autoplayTimer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    current = ((index % slideCount) + slideCount) % slideCount;
    if (track) {
      track.style.transform = `translateX(-${current * 100}%)`;
    }
    dots?.forEach((dot, i) => {
      dot.classList.toggle('active', i === current);
      if (i === current) {
        dot.setAttribute('aria-current', 'true');
      } else {
        dot.removeAttribute('aria-current');
      }
    });
    if (counter) counter.textContent = `${current + 1} / ${slideCount}`;
  }

  prevBtn?.addEventListener('click', () => {
    goTo(current - 1);
    resetAutoplay();
  });

  nextBtn?.addEventListener('click', () => {
    goTo(current + 1);
    resetAutoplay();
  });

  dots?.forEach(dot => {
    dot.addEventListener('click', () => {
      const index = Number((dot as HTMLElement).dataset.index);
      goTo(index);
      resetAutoplay();
    });
  });

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let isPlaying = !prefersReducedMotion;
  const pauseBtn = document.getElementById('carousel-pause');
  const iconPause = pauseBtn?.querySelector('.icon-pause') as HTMLElement;
  const iconPlay = pauseBtn?.querySelector('.icon-play') as HTMLElement;

  function updatePauseButton() {
    if (iconPause) iconPause.style.display = isPlaying ? '' : 'none';
    if (iconPlay) iconPlay.style.display = isPlaying ? 'none' : '';
    if (pauseBtn) {
      const label = isPlaying ? pauseBtn.dataset.labelPause : pauseBtn.dataset.labelPlay;
      if (label) pauseBtn.setAttribute('aria-label', label);
    }
  }

  function resetAutoplay() {
    clearInterval(autoplayTimer);
    if (isPlaying) {
      autoplayTimer = setInterval(() => goTo(current + 1), 4000);
    }
  }

  if (!prefersReducedMotion) {
    autoplayTimer = setInterval(() => goTo(current + 1), 4000);
  } else {
    updatePauseButton();
  }

  pauseBtn?.addEventListener('click', () => {
    isPlaying = !isPlaying;
    updatePauseButton();
    if (isPlaying) {
      resetAutoplay();
    } else {
      clearInterval(autoplayTimer);
    }
  });

  // Swipe support
  let touchStartX = 0;
  const carousel = document.getElementById('hero-carousel');

  carousel?.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });

  carousel?.addEventListener('touchend', (e) => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) {
      goTo(diff > 0 ? current + 1 : current - 1);
      resetAutoplay();
    }
  }, { passive: true });
</script>
