---
const photos = [
  'warren-1.jpg', 'warren-2.jpg', 'warren-3.jpg',
  'profile-01.jpg', 'profile-02.jpg', 'profile-03.jpg',
  'profile-04.jpg', 'profile-05.jpg', 'profile-06.jpg',
  'profile-07.jpg', 'profile-08.jpg', 'profile-09.jpg',
  'profile-10.jpg', 'profile-11.jpg', 'profile-12.jpg',
];
---

<div class="carousel" id="hero-carousel" role="region" aria-label="Photo carousel" aria-roledescription="carousel">
  <div class="carousel-track" id="carousel-track">
    {photos.map((photo, i) => (
      <div class="carousel-slide">
        <img
          src={`/images/photos/${photo}`}
          alt={`Warren de Leon — photo ${i + 1}`}
          loading={i === 0 ? 'eager' : 'lazy'}
          width="400"
          height="500"
        />
      </div>
    ))}
  </div>
  <button class="carousel-btn carousel-btn-prev" id="carousel-prev" type="button" aria-label="Previous photo">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
  </button>
  <button class="carousel-btn carousel-btn-next" id="carousel-next" type="button" aria-label="Next photo">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6" /></svg>
  </button>
  <span class="carousel-counter" id="carousel-counter">1 / 15</span>
  <div class="carousel-controls">
    <div class="carousel-dots" id="carousel-dots">
      {photos.map((_, i) => (
        <button
          class:list={['carousel-dot', { active: i === 0 }]}
          type="button"
          aria-label={`Go to photo ${i + 1}`}
          aria-current={i === 0 ? 'true' : undefined}
          data-index={i}
        />
      ))}
    </div>
    <button class="carousel-pause" id="carousel-pause" type="button" aria-label="Pause carousel">
      <svg class="icon-pause" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
        <rect x="6" y="4" width="4" height="16"></rect>
        <rect x="14" y="4" width="4" height="16"></rect>
      </svg>
      <svg class="icon-play" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="display:none;">
        <polygon points="5 3 19 12 5 21 5 3"></polygon>
      </svg>
    </button>
  </div>
</div>

<style>
  .carousel {
    position: relative;
    width: 100%;
    max-height: 500px;
    overflow: hidden;
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
  }

  .carousel-track {
    display: flex;
    height: 100%;
    transition: transform 0.4s ease;
  }

  .carousel-slide {
    min-width: 100%;
    height: 100%;
  }

  .carousel-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.4);
    color: white;
    border: none;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease;
    z-index: 2;
  }

  .carousel-btn:hover {
    background: rgba(0, 0, 0, 0.7);
  }

  .carousel-btn-prev {
    left: 8px;
  }

  .carousel-btn-next {
    right: 8px;
  }

  .carousel-counter {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(0, 0, 0, 0.5);
    color: white;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    border-radius: 12px;
    z-index: 2;
  }

  .carousel-controls {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 2;
  }

  .carousel-dots {
    display: flex;
    gap: 6px;
  }

  .carousel-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    padding: 0;
    transition: background 0.2s ease;
    position: relative;
  }

  .carousel-dot::before {
    content: '';
    position: absolute;
    top: -10px;
    left: -10px;
    right: -10px;
    bottom: -10px;
  }

  .carousel-dot.active {
    background: var(--color-green);
  }

  .carousel-pause {
    background: rgba(0, 0, 0, 0.4);
    color: white;
    border: none;
    border-radius: 50%;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .carousel-pause:hover {
    background: rgba(0, 0, 0, 0.7);
  }

  @media (max-width: 768px) {
    .carousel {
      max-width: 100%;
      border-radius: 12px;
    }
  }
</style>

<script>
  const track = document.getElementById('carousel-track');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');
  const dotsContainer = document.getElementById('carousel-dots');
  const dots = dotsContainer?.querySelectorAll('.carousel-dot');
  const counter = document.getElementById('carousel-counter');
  const slideCount = dots?.length || 0;
  let current = 0;
  let autoplayTimer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    current = ((index % slideCount) + slideCount) % slideCount;
    if (track) {
      track.style.transform = `translateX(-${current * 100}%)`;
    }
    dots?.forEach((dot, i) => {
      dot.classList.toggle('active', i === current);
      if (i === current) {
        dot.setAttribute('aria-current', 'true');
      } else {
        dot.removeAttribute('aria-current');
      }
    });
    if (counter) counter.textContent = `${current + 1} / ${slideCount}`;
  }

  prevBtn?.addEventListener('click', () => {
    goTo(current - 1);
    resetAutoplay();
  });

  nextBtn?.addEventListener('click', () => {
    goTo(current + 1);
    resetAutoplay();
  });

  dots?.forEach(dot => {
    dot.addEventListener('click', () => {
      const index = Number((dot as HTMLElement).dataset.index);
      goTo(index);
      resetAutoplay();
    });
  });

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let isPlaying = !prefersReducedMotion;
  const pauseBtn = document.getElementById('carousel-pause');
  const iconPause = pauseBtn?.querySelector('.icon-pause') as HTMLElement;
  const iconPlay = pauseBtn?.querySelector('.icon-play') as HTMLElement;

  function updatePauseButton() {
    if (iconPause) iconPause.style.display = isPlaying ? '' : 'none';
    if (iconPlay) iconPlay.style.display = isPlaying ? 'none' : '';
    pauseBtn?.setAttribute('aria-label', isPlaying ? 'Pause carousel' : 'Play carousel');
  }

  function resetAutoplay() {
    clearInterval(autoplayTimer);
    if (isPlaying) {
      autoplayTimer = setInterval(() => goTo(current + 1), 4000);
    }
  }

  if (!prefersReducedMotion) {
    autoplayTimer = setInterval(() => goTo(current + 1), 4000);
  } else {
    updatePauseButton();
  }

  pauseBtn?.addEventListener('click', () => {
    isPlaying = !isPlaying;
    updatePauseButton();
    if (isPlaying) {
      resetAutoplay();
    } else {
      clearInterval(autoplayTimer);
    }
  });

  // Swipe support
  let touchStartX = 0;
  const carousel = document.getElementById('hero-carousel');

  carousel?.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });

  carousel?.addEventListener('touchend', (e) => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) {
      goTo(diff > 0 ? current + 1 : current - 1);
      resetAutoplay();
    }
  }, { passive: true });
</script>
