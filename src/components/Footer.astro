---
import SocialLinks from './SocialLinks.astro';
import { t, getLocalePath, type Locale } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);
const year = new Date().getFullYear();
---

<!-- Finalised design: a single centred column on every viewport — links row,
     one flat row of social icons (RSS included), copyright. Only the sizes
     change per band. -->
<footer class="footer">
  <div class="footer-inner">
    <nav class="footer-nav" aria-label={i18n.a11y.footerNavigation}>
      <ul>
        <li><a href={getLocalePath(locale, '/work-experience/')}>{i18n.nav.workExperience}</a></li>
        <li><a href={getLocalePath(locale, '/blog/')}>{i18n.nav.blog}</a></li>
        <li><a href={getLocalePath(locale, '/book-a-call/')}>{i18n.nav.bookACall}</a></li>
        <li><a href={getLocalePath(locale, '/privacy/')}>{i18n.privacy.heading}</a></li>
      </ul>
    </nav>
    <div class="footer-social-row">
      <SocialLinks size={18} locale={locale} />
      <a href="/rss.xml" class="footer-rss" aria-label={i18n.a11y.rssFeed} target="_blank" rel="noopener noreferrer">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 11a9 9 0 0 1 9 9"></path>
          <path d="M4 4a16 16 0 0 1 16 16"></path>
          <circle cx="5" cy="19" r="1"></circle>
        </svg>
      </a>
    </div>
    <p class="footer-copy">&copy; {year} Warren de Leon. {i18n.footer.copyright}</p>
  </div>
</footer>

<style is:global>
  .footer {
    border-top: 1px solid var(--border-color);
    background: var(--bg-secondary);
    margin-top: 32px;
    /* Clearance so the fixed tab bar / floating dock never covers the last
       line. Removed at ≥1280px where neither exists. */
    padding-bottom: calc(84px + var(--safe-bottom));
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 32px 24px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  .footer-nav ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-nav a {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: color 0.2s ease;
    padding: 0.35rem 0;
    display: inline-flex;
    align-items: center;
  }

  .footer-nav a:hover {
    color: var(--color-green-text);
  }

  /* One flat row: plain icon hit-areas, no borders, RSS included. */
  .footer-social-row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2px;
  }

  .footer .social-links {
    display: contents;
  }

  .footer .social-links a,
  .footer-rss {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    padding: 0;
    border: none;
    color: var(--text-secondary);
    transition: color 0.2s ease;
  }

  .footer .social-links a:hover,
  .footer-rss:hover {
    color: var(--color-green-text);
  }

  .footer-copy {
    font-size: 0.72rem;
    color: var(--text-muted);
    padding-bottom: 30px;
  }

  /* Tablet band: 960px column, slightly tighter spacing (design). */
  @media (max-width: 1279px) {
    .footer-inner {
      max-width: 1008px;
      padding: 28px 24px 0;
      gap: 14px;
    }

    .footer-nav ul {
      gap: 22px;
    }
  }

  /* Mobile band: 430px column, larger 44px hit areas, tighter link row. */
  @media (max-width: 699px) {
    .footer-inner {
      max-width: 430px;
      padding: 22px 20px 0;
      gap: 12px;
    }

    .footer-nav ul {
      gap: 16px;
    }

    .footer-nav a {
      font-size: 0.75rem;
    }

    .footer .social-links a,
    .footer-rss {
      width: 44px;
      height: 44px;
    }

    .footer-copy {
      font-size: 0.68rem;
    }
  }

  /* Below the 390px artboard content width the eight 44px hits can't share
     a row; 40px keeps the design's single line. */
  @media (max-width: 389px) {
    .footer-social-row {
      flex-wrap: nowrap;
    }

    .footer .social-links a,
    .footer-rss {
      width: 40px;
      height: 40px;
    }
  }

  @media (min-width: 1280px) and (hover: hover) and (pointer: fine) {
    .footer {
      padding-bottom: 0;
    }
  }
</style>
