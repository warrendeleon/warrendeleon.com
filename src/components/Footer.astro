---
import SocialLinks from './SocialLinks.astro';
import { t, type Locale } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <SocialLinks size={18} />
    <p class="footer-copy">&copy; {year} Warren de Leon. {i18n.footer.copyright}</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border-color);
    padding: 2rem 0;
    margin-top: 2rem;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  .footer-copy {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
</style>
