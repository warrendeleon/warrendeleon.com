---
import TimelineEntry from './TimelineEntry.astro';
import { t, type Locale } from '../i18n/index';

interface Props {
  companies: Array<{
    company: string;
    logo?: string;
    href?: string;
    positions: Array<{
      title: string;
      startDate: string;
      endDate: string | null;
      description: string;
    }>;
  }>;
  locale: Locale;
}

const { companies, locale } = Astro.props;
const i18n = t(locale);
---

<div class="timeline">
  <span class="timeline-present-tag">{i18n.workExperience.present}</span>
  {companies.map((co) => (
    <TimelineEntry
      company={co.company}
      logo={co.logo}
      href={co.href}
      positions={co.positions}
      locale={locale}
    />
  ))}
</div>

<style is:global>
  /* Design: the company logo circles sit ON the rail (they replace the old
     small dots), with the "Latest" tag centred on the rail above them.
     Bands: dots 120px desktop (rail x 67) · 92px tablet (rail x 53) ·
     48px mobile (rail x 39). */
  .timeline {
    position: relative;
    /* Design: 36/30/22px of air between the intro copy and the Latest tag. */
    margin-top: 36px;
    padding-left: 160px;
    padding-top: 2.6rem;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 67px;
    top: 6px;
    bottom: 10px;
    width: 2px;
    background: var(--timeline-line);
  }

  .timeline-present-tag {
    position: absolute;
    top: 0;
    left: 68px;
    transform: translateX(-50%);
    background: var(--color-green);
    color: white;
    font-size: 0.69rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 4px 10px;
    border-radius: 5px;
    white-space: nowrap;
    z-index: 3;
  }

  @media (max-width: 1279px) {
    .timeline { margin-top: 30px; padding-left: 130px; gap: 16px; }
    .timeline::before { left: 53px; }
    .timeline-present-tag { left: 54px; }
  }

  @media (max-width: 699px) {
    .timeline { margin-top: 22px; padding-left: 82px; gap: 14px; }
    .timeline::before { left: 39px; }
    .timeline-present-tag { left: 40px; font-size: 0.66rem; padding: 3px 9px; }
  }
</style>
