---
import { slugify, getLocalePath, formatDateRange, type Locale } from '../i18n/index';

interface Props {
  company: string;
  logo?: string;
  positions: Array<{
    title: string;
    startDate: string;
    endDate: string | null;
    description: string;
  }>;
  locale: Locale;
}

const { company, logo, positions, locale } = Astro.props;
const slug = slugify(company);
const latestPosition = positions[0];
const dateRange = formatDateRange(
  positions[positions.length - 1].startDate,
  latestPosition.endDate,
  locale
);
const hasDescription = latestPosition.description && latestPosition.description.trim().length > 0;
---

<div class="timeline-entry">
  <div class="timeline-dot"></div>
  <a href={getLocalePath(locale, `/work/${slug}/`)} class="timeline-card card">
    <div class="timeline-card-inner">
      <div class="timeline-logo-col">
        <div class="timeline-logo">
          {logo ? (
            <img src={logo} alt={company} width="40" height="40" />
          ) : (
            <span class="timeline-logo-fallback">{company.charAt(0)}</span>
          )}
        </div>
      </div>
      <div class="timeline-content-col">
        <div class="timeline-card-header">
          <h3>{company}</h3>
          <span class="timeline-date">{dateRange}</span>
        </div>
        <p class="timeline-title">{latestPosition.title}</p>
        {hasDescription && (
          <p class="timeline-desc">{latestPosition.description.substring(0, 160)}...</p>
        )}
      </div>
    </div>
  </a>
</div>

<style is:global>
  .timeline-entry {
    position: relative;
    margin-bottom: 2rem;
  }

  .timeline-dot {
    position: absolute;
    left: -47px;
    top: 50%;
    transform: translateY(-50%);
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--timeline-dot);
    border: 3px solid var(--bg-primary);
    box-shadow: 0 0 0 2px var(--timeline-dot);
    z-index: 2;
  }

  .timeline-card {
    display: block;
    color: var(--text-primary);
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .timeline-card:hover {
    transform: translateX(4px);
    color: var(--text-primary);
  }

  .timeline-card-inner {
    display: grid;
    grid-template-columns: 15% 1fr;
    gap: 1.5rem;
    align-items: center;
  }

  .timeline-logo-col {
    display: flex;
    justify-content: center;
  }

  .timeline-logo {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: #f5f5f7;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 2px solid var(--border-color);
  }

  .timeline-logo img {
    width: 60%;
    height: 60%;
    object-fit: contain;
  }

  .timeline-logo-fallback {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-green);
  }

  .timeline-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .timeline-card-header h3 {
    font-size: 1.25rem;
    color: var(--color-green);
  }

  .timeline-date {
    font-size: 0.9rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .timeline-title {
    font-weight: 600;
    margin-top: 0.25rem;
    font-size: 1rem;
  }

  .timeline-desc {
    margin-top: 0.5rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .timeline-card-inner {
      grid-template-columns: 60px 1fr;
    }
  }
</style>
