---
interface Props {
  heading: string;
}

const { heading } = Astro.props;

const photos = [
  '/images/photos/warren-1.webp',
  '/images/photos/warren-2.webp',
  '/images/photos/warren-3.webp',
  '/images/photos/profile-01.webp',
  '/images/photos/profile-02.webp',
  '/images/photos/profile-03.webp',
  '/images/photos/profile-04.webp',
  '/images/photos/profile-05.webp',
  '/images/photos/profile-06.webp',
  '/images/photos/profile-07.webp',
  '/images/photos/profile-08.webp',
  '/images/photos/profile-09.webp',
  '/images/photos/profile-10.webp',
  '/images/photos/profile-11.webp',
  '/images/photos/profile-12.webp',
];
---

<section class="section">
  <div class="container">
    <h2 class="section-heading">{heading}</h2>
    <div class="photo-grid">
      {photos.map((photo, i) => (
        <div class="photo-item">
          <img src={photo} alt={`Photo ${i + 1}`} loading="lazy" width="400" height="400" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .photo-item {
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 1;
  }

  .photo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .photo-item:hover img {
    transform: scale(1.05);
  }

  @media (max-width: 768px) {
    .photo-grid {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 0.75rem;
    }
  }
</style>
