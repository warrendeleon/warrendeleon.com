---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogSearch from './BlogSearch.astro';
import SubscribeForm from '../SubscribeForm.astro';
import { t, getLocalePath } from '../../i18n/index';
import type { Locale } from '../../i18n/index';
import { getTagLabel } from '../../i18n/tagLabels';
import { getReadingTime } from '../../utils/readingTime';
import { getPostsForLocale, getPostSlug, getAvailableLocales, formatBlogDate, getSeriesSlug, publishSlot, type ScheduledPost } from '../../utils/blogHelpers';
import BreadcrumbsJsonLd from '../BreadcrumbsJsonLd.astro';
import type { MarkdownHeading } from 'astro';
import popularity from '../../data/popularity.json';
import AuthorCard from './AuthorCard.astro';
import MediaZoom from '../MediaZoom.astro';
import ReadingBar from './ReadingBar.astro';
import ReadingProgress from './ReadingProgress.astro';
import RelatedCard from './RelatedCard.astro';
import Shelf from './Shelf.astro';
import Toc from './Toc.astro';

interface Props {
  locale: Locale;
  post: ScheduledPost;
  // render()'s Content component; rendered as <Content /> below.
  Content: any;
  headings: MarkdownHeading[];
}

const { locale, post, Content, headings } = Astro.props;
const i18n = t(locale);

const showToc = headings.filter(h => h.depth <= 3).length >= 3;
const readingTime = getReadingTime(post.body ?? '');
const postSlug = getPostSlug(post.id);
const postPath = getLocalePath(locale, `/blog/${postSlug}/`);
const blogPath = getLocalePath(locale, '/blog/');
const hreflangLocales = await getAvailableLocales(postSlug);

// Match getPostsForLocale's cutoff: a post is live at its 08:30 slot (publishSlot),
// so the prev/next series nav only links siblings that are actually published.
const now = new Date();
const allPosts = await getPostsForLocale(locale, true);
const sortedAsc = [...allPosts].sort((a, b) => a.data.publishDate.valueOf() - b.data.publishDate.valueOf());

const currentIndex = sortedAsc.findIndex(p => getPostSlug(p.id) === postSlug);
const prevCandidate = currentIndex > 0 ? sortedAsc[currentIndex - 1] : null;
const nextCandidate = currentIndex < sortedAsc.length - 1 ? sortedAsc[currentIndex + 1] : null;
const prevPost = prevCandidate && publishSlot(prevCandidate.data.publishDate) <= now ? prevCandidate : null;
const nextPost = nextCandidate && publishSlot(nextCandidate.data.publishDate) <= now ? nextCandidate : null;

const blogPostingJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  image: post.data.heroImage ? `https://warrendeleon.com${post.data.heroImage}` : undefined,
  datePublished: post.data.publishDate.toISOString(),
  inLanguage: locale,
  author: {
    '@type': 'Person',
    name: 'Warren de Leon',
    url: 'https://warrendeleon.com',
  },
  publisher: {
    '@type': 'Person',
    name: 'Warren de Leon',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://warrendeleon.com${postPath}`,
  },
};

const manualRelated = post.data.relatedPosts || [];
const relatedPosts = manualRelated.length > 0
  ? manualRelated
      .map(slug => sortedAsc.find(p => getPostSlug(p.id) === slug))
      .filter((p): p is ScheduledPost => p !== undefined && (import.meta.env.DEV || publishSlot(p.data.publishDate) <= now))
      .slice(0, 3)
  : sortedAsc
      .filter(p => getPostSlug(p.id) !== postSlug && (import.meta.env.DEV || publishSlot(p.data.publishDate) <= now))
      .map(p => ({
        post: p,
        sharedTags: p.data.tags.filter(t => post.data.tags.includes(t)).length,
      }))
      .filter(p => p.sharedTags > 0)
      .sort((a, b) => b.sharedTags - a.sharedTags)
      .slice(0, 3)
      .map(p => p.post);

// "More from the blog": surface lower-traffic published posts the reader has not been pointed to yet.
// Views come from src/data/popularity.json (refreshed from Umami); posts with no entry count as 0,
// so new posts surface first. Excludes the current post and anything already in related posts.
const popularityViews = popularity as Record<string, number>;
const relatedSlugs = new Set(relatedPosts.map(p => getPostSlug(p.id)));
const recommendedPosts = sortedAsc
  .filter(p => {
    const slug = getPostSlug(p.id);
    return slug !== postSlug
      && !relatedSlugs.has(slug)
      && (import.meta.env.DEV || publishSlot(p.data.publishDate) <= now);
  })
  .map(p => ({ post: p, views: popularityViews[getPostSlug(p.id)] ?? 0 }))
  .sort((a, b) => a.views - b.views || a.post.data.publishDate.valueOf() - b.post.data.publishDate.valueOf())
  .slice(0, 9 - relatedPosts.length)
  .map(x => x.post);

// Series navigation: the published posts that share this post's `series`, in publish order.
// Position in the series is computed here, so no post needs a hand-assigned number.
const seriesPosts = post.data.series
  ? sortedAsc.filter(p =>
      p.data.series === post.data.series &&
      (import.meta.env.DEV || publishSlot(p.data.publishDate) <= now))
  : [];
const seriesIndex = seriesPosts.findIndex(p => getPostSlug(p.id) === postSlug);
const seriesPartLabel = i18n.blog.seriesPart
  .replace('{n}', String(seriesIndex + 1))
  .replace('{m}', String(seriesPosts.length));

// Prev/next stays inside the series while one exists (a "Part 5 of 5" post
// should not point Next at an unrelated post); chronological order is the
// fallback for standalone posts and at the ends of a series.
const seriesPrev = seriesIndex > 0 ? seriesPosts[seriesIndex - 1] : null;
const seriesNext = seriesIndex >= 0 && seriesIndex < seriesPosts.length - 1 ? seriesPosts[seriesIndex + 1] : null;
const navPrev = seriesPrev ?? prevPost;
const navNext = seriesNext ?? nextPost;

// One further-reading shelf: hand-picked/related-by-tag first, popularity-tail
// fillers after, capped at 9 so it stays a recommendation rather than an archive.
const furtherReading = [...relatedPosts, ...recommendedPosts].slice(0, 9);

const shareUrl = `https://warrendeleon.com${postPath}`;
const campaignParam = `&utm_campaign=${post.data.campaign}`;
const shareUrlLinkedIn = `${shareUrl}?utm_source=linkedin&utm_medium=share${campaignParam}`;
const shareUrlX = `${shareUrl}?utm_source=x&utm_medium=share${campaignParam}`;
const shareUrlFacebook = `${shareUrl}?utm_source=facebook&utm_medium=share${campaignParam}`;
const shareUrlWhatsApp = `${shareUrl}?utm_source=whatsapp&utm_medium=share${campaignParam}`;
const shareUrlCopy = `${shareUrl}?utm_source=copy&utm_medium=share${campaignParam}`;
---

<BaseLayout
  title={`${post.data.title} | Warren de Leon`}
  description={post.data.description}
  locale={locale}
  currentPath={postPath}
  hreflangLocales={hreflangLocales}
  ogImage={post.data.heroImage}
  ogType="article"
  jsonLd={blogPostingJsonLd}
  mobileBack={{
    href: blogPath,
    title: post.data.title,
    eyebrow: post.data.series ? `${post.data.series} · ${seriesPartLabel}` : undefined,
  }}
>
  <BlogSearch locale={locale} />
  <BreadcrumbsJsonLd items={[
    { name: 'Warren de Leon', url: getLocalePath(locale, '/') },
    { name: 'Blog', url: blogPath },
    ...(post.data.series ? [{ name: post.data.series, url: getLocalePath(locale, `/blog/series/${getSeriesSlug(post.data.series)}/`) }] : []),
    { name: post.data.title },
  ]} />

  <!-- Reading progress bar -->
  <ReadingProgress locale={locale} />

  {post.data.heroImage && (
    <div class="post-hero-image">
      <div class="post-hero-image-bg" style={`background-image: url(${post.data.heroImage})`}></div>
      <img src={post.data.heroImage} alt={post.data.heroAlt || post.data.title} />
      <div class="post-hero-image-overlay"></div>
    </div>
  )}

  <!-- Mobile reading bar: progress ring + current section + TOC trigger,
       share and back-to-top. Hidden ≥1024px where the sidebar TOC exists. -->
  <ReadingBar locale={locale} title={post.data.title} />

  <section class="post-hero section-alt" aria-label={i18n.a11y.postHeader}>
    <div class="container">
      <a href={blogPath} class="blog-back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        {i18n.blog.backToBlog}
      </a>

      <h1>{post.data.title}</h1>

      <div class="post-meta">
        <time datetime={post.data.publishDate.toISOString()}>
          {formatBlogDate(post.data.publishDate, locale)}
        </time>
        <span class="post-meta-separator" aria-hidden="true">&middot;</span>
        <span class="post-meta-reading">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          {readingTime} {i18n.blog.minRead}
        </span>
        {post.data.tags.length > 0 && (
          <>
            <span class="post-meta-separator" aria-hidden="true">&middot;</span>
            <div class="post-tags">
              {post.data.tags.map((tag: string) => (
                <a href={getLocalePath(locale, `/blog/tags/${tag}/`)} class="post-tag">{getTagLabel(tag, locale)}</a>
              ))}
            </div>
          </>
        )}
      </div>
    </div>
  </section>


  <article class="section post-content-section">
    <div class="container">
      {seriesPosts.length > 1 && (
        <aside class="series-nav" aria-label={post.data.series}>
          <div class="series-nav-head">
            <p class="series-nav-heading">
              <strong>{post.data.series}</strong>
              <span class="series-nav-part">{seriesPartLabel}</span>
            </p>
            <div class="series-nav-arrows" hidden>
              <button type="button" class="series-nav-arrow" data-series-prev aria-label={i18n.blog.previous}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
              </button>
              <button type="button" class="series-nav-arrow" data-series-next aria-label={i18n.blog.next}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </button>
            </div>
          </div>
          <ol class="series-nav-list" data-series-shelf>
            {seriesPosts.map((sp, i) => {
              const sSlug = getPostSlug(sp.id);
              const isCurrent = sSlug === postSlug;
              const num = String(i + 1).padStart(2, '0');
              return (
                <li class={isCurrent ? 'series-current' : ''} aria-current={isCurrent ? 'step' : undefined}>
                  {isCurrent ? (
                    <span class="series-card-inner">
                      <span class="series-card-num" aria-hidden="true">{num}</span>
                      <span class="series-card-title">{sp.data.title}</span>
                    </span>
                  ) : (
                    <a class="series-card-inner" href={getLocalePath(locale, `/blog/${sSlug}/`)}>
                      <span class="series-card-num" aria-hidden="true">{num}</span>
                      <span class="series-card-title">{sp.data.title}</span>
                    </a>
                  )}
                </li>
              );
            })}
          </ol>
        </aside>
      )}
      <div class={showToc ? 'post-layout' : ''}>
        {showToc && (
          <Toc label={i18n.blog.contents} headings={headings.filter(h => h.depth <= 3)} />
        )}
        <div class="prose" data-pagefind-body data-pagefind-meta={`title:${post.data.title}`}>
          <Content />
        </div>
      </div>

      <AuthorCard locale={locale} />

      <div class="share-links" aria-label={i18n.blog.sharePost}>
        <span>{i18n.blog.sharePost}</span>
        <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrlLinkedIn)}`} target="_blank" rel="noopener noreferrer" aria-label={i18n.a11y.shareOn.replace('{n}', 'LinkedIn')} class="share-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a href={`https://x.com/intent/tweet?url=${encodeURIComponent(shareUrlX)}&text=${encodeURIComponent(post.data.title)}`} target="_blank" rel="noopener noreferrer" aria-label={i18n.a11y.shareOn.replace('{n}', 'X')} class="share-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          X
        </a>
        <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrlFacebook)}`} target="_blank" rel="noopener noreferrer" aria-label={i18n.a11y.shareOn.replace('{n}', 'Facebook')} class="share-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          Facebook
        </a>
        <a href={`https://wa.me/?text=${encodeURIComponent(post.data.title + ' ' + shareUrlWhatsApp)}`} target="_blank" rel="noopener noreferrer" aria-label={i18n.a11y.shareOn.replace('{n}', 'WhatsApp')} class="share-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
        <button class="copy-link-btn share-btn" data-url={shareUrlCopy} aria-label={i18n.blog.copyLink}>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
          <span>{i18n.blog.copyLink}</span>
        </button>
      </div>
    </div>
  </article>

  <SubscribeForm locale={locale} />

  <section class="section">
    <div class="container">
      {furtherReading.length > 0 && (
        <section class="related-posts more-from-blog" aria-label={i18n.blog.moreFromBlog}>
          <Shelf heading={i18n.blog.moreFromBlog} labelPrev={i18n.blog.previous} labelNext={i18n.blog.next}>
            {furtherReading.map(rp => (
              <RelatedCard
                href={getLocalePath(locale, `/blog/${getPostSlug(rp.id)}/`)}
                image={rp.data.heroImage ? { src: rp.data.heroImage, alt: rp.data.heroAlt || rp.data.title } : undefined}
                dateISO={rp.data.publishDate.toISOString()}
                dateLabel={formatBlogDate(rp.data.publishDate, locale)}
                title={rp.data.title}
              />
            ))}
          </Shelf>
        </section>
      )}

      <nav class="blog-nav" aria-label={`${i18n.blog.previous} / ${i18n.blog.next}`}>
        {navPrev ? (
          <a href={getLocalePath(locale, `/blog/${getPostSlug(navPrev.id)}/`)} class="blog-nav-link blog-nav-prev">
            <span class="blog-nav-label">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
              </svg>
              {i18n.blog.previous}
            </span>
            <span class="blog-nav-title">{navPrev.data.title}</span>
          </a>
        ) : <span />}
        {navNext ? (
          <a href={getLocalePath(locale, `/blog/${getPostSlug(navNext.id)}/`)} class="blog-nav-link blog-nav-next">
            <span class="blog-nav-label">
              {i18n.blog.next}
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </span>
            <span class="blog-nav-title">{navNext.data.title}</span>
          </a>
        ) : <span />}
      </nav>
    </div>
  </section>

  <MediaZoom locale={locale} />

  <!-- TOC bottom sheet (mobile). Same headings as the sidebar TOC. -->
  {showToc && (
    <div class="post-sheet" id="toc-sheet" role="dialog" aria-modal="true" aria-label={i18n.blog.contents} hidden>
      <div class="post-sheet-backdrop" data-overlay-close></div>
      <div class="post-sheet-panel">
        <div class="post-sheet-grabber" aria-hidden="true"></div>
        <div class="post-sheet-head">
          <span class="post-sheet-title">{i18n.blog.contents}</span>
          <span class="post-sheet-meta" data-sheet-progress></span>
        </div>
        <ol class="post-sheet-list">
          {headings.filter(h => h.depth <= 3).map((h, i) => (
            <li class={`sheet-depth-${h.depth}`}>
              <a href={`#${h.slug}`} data-sheet-toc-link>
                <span class="sheet-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                <span>{h.text}</span>
              </a>
            </li>
          ))}
        </ol>
      </div>
    </div>
  )}

  <!-- Share bottom sheet: fallback when navigator.share is unavailable.
       Same UTM-tagged URLs and tracking as the inline share row. -->
  <div class="post-sheet" id="share-sheet" role="dialog" aria-modal="true" aria-label={i18n.blog.sharePost} hidden>
    <div class="post-sheet-backdrop" data-overlay-close></div>
    <div class="post-sheet-panel">
      <div class="post-sheet-grabber" aria-hidden="true"></div>
      <div class="post-sheet-head">
        <span class="post-sheet-title">{i18n.blog.sharePost}</span>
      </div>
      <div class="post-sheet-share-grid">
        <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrlLinkedIn)}`} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label={i18n.a11y.shareOn.replace('{n}', 'LinkedIn')}>LinkedIn</a>
        <a href={`https://x.com/intent/tweet?url=${encodeURIComponent(shareUrlX)}&text=${encodeURIComponent(post.data.title)}`} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label={i18n.a11y.shareOn.replace('{n}', 'X')}>X</a>
        <a href={`https://wa.me/?text=${encodeURIComponent(post.data.title + ' ' + shareUrlWhatsApp)}`} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label={i18n.a11y.shareOn.replace('{n}', 'WhatsApp')}>WhatsApp</a>
        <button type="button" class="copy-link-btn share-btn" data-url={shareUrlCopy} aria-label={i18n.blog.copyLink}><span>{i18n.blog.copyLink}</span></button>
      </div>
    </div>
  </div>

  <!-- Fullscreen code viewer: filled and opened by the code-block script. -->
  <div class="code-viewer" id="code-viewer" role="dialog" aria-modal="true" aria-label="Code" hidden>
    <div class="code-viewer-head">
      <span class="code-viewer-title" data-viewer-title></span>
      <button type="button" class="code-viewer-btn" data-viewer-wrap aria-pressed="false">Wrap</button>
      <button type="button" class="code-viewer-btn" data-viewer-copy>{i18n.blog.copyCode}</button>
      <button type="button" class="code-viewer-close" data-overlay-close aria-label={i18n.a11y.close}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
    <pre class="code-viewer-pre" data-viewer-pre tabindex="0"></pre>
  </div>

  <!-- Scroll to top button -->
  <button class="scroll-to-top" aria-label={i18n.footer.backToTop} hidden>
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="12" y1="19" x2="12" y2="5"></line>
      <polyline points="5 12 12 5 19 12"></polyline>
    </svg>
  </button>

  <!-- i18n data for scripts -->
  <div id="blog-i18n"
    data-copy={i18n.blog.copyCode}
    data-copied={i18n.blog.codeCopied}
    data-copy-link={i18n.blog.copyLink}
    data-link-copied={i18n.blog.copied}
    data-wrap={i18n.blog.wrap}
    data-expand={i18n.blog.expand}
    data-min-left={i18n.blog.minLeft}
    data-done={i18n.blog.done}
    data-reading-minutes={String(readingTime)}
    data-share-url={shareUrlCopy}
    data-share-title={post.data.title}
    hidden
  />
<script is:inline>
/* i18n strings for scripts */
var i18nEl = document.getElementById('blog-i18n');
var i18nData = i18nEl ? i18nEl.dataset : {};

/* The sidebar TOC only renders ≥1024px now (the bottom sheet covers mobile),
   so it always starts open. */

/* Callout blockquotes */
var calloutMap = {
  '🚩': 'callout-danger',
  '💡': 'callout-tip',
  '⚠️': 'callout-warning',
  'ℹ️': 'callout-info'
};
document.querySelectorAll('.prose blockquote').forEach(function(bq) {
  var firstP = bq.querySelector('p:first-child');
  if (!firstP) return;
  var text = firstP.textContent.trim();
  for (var emoji in calloutMap) {
    if (text.startsWith(emoji)) {
      bq.classList.add('callout', calloutMap[emoji]);
      firstP.textContent = text.slice(emoji.length).trim();
      break;
    }
  }
});

/* Copy link button */
document.querySelectorAll('.copy-link-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    navigator.clipboard.writeText(btn.dataset.url);
    t('blog_copy_link', { url: btn.dataset.url });
    var label = btn.querySelector('span');
    if (label) {
      label.textContent = i18nData.linkCopied || 'Copied!';
      setTimeout(function() { label.textContent = i18nData.copyLink || 'Copy link'; }, 2000);
    }
  });
});

/* Share button tracking */
document.querySelectorAll('.share-btn[href]').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var href = btn.getAttribute('href') || '';
    var platform = href.includes('linkedin') ? 'linkedin' : href.includes('x.com') ? 'x' : href.includes('facebook') ? 'facebook' : href.includes('wa.me') ? 'whatsapp' : 'unknown';
    t('blog_share', { platform: platform });
  });
});

/* Related post tracking */
document.querySelectorAll('.related-card').forEach(function(card) {
  card.addEventListener('click', function() {
    t('related_post_click', { post: card.getAttribute('href') });
  });
});

/* Blog prev/next tracking */
document.querySelectorAll('.blog-nav-link').forEach(function(link) {
  link.addEventListener('click', function() {
    var direction = link.classList.contains('blog-nav-prev') ? 'prev' : 'next';
    t('blog_nav', { direction: direction });
  });
});

/* Code block wrappers */
var plainLangs = ['', 'text', 'plaintext', 'txt'];
document.querySelectorAll('.prose pre').forEach(function(pre) {
  var code = pre.querySelector('code');
  var lang = pre.getAttribute('data-language') || '';
  var isPlain = plainLangs.indexOf(lang) !== -1;

  /* Hide line numbers for plain text blocks */
  if (isPlain && code) {
    code.querySelectorAll('.line').forEach(function(line) {
      var before = window.getComputedStyle(line, '::before');
      line.style.setProperty('--hide-line-num', '1');
    });
    pre.classList.add('plain-code');
  }

  /* Skip header for plain text blocks */
  if (isPlain) return;

  var wrapper = document.createElement('div');
  wrapper.className = 'code-block-wrapper';
  var header = document.createElement('div');
  header.className = 'code-block-header';
  var langLabel = document.createElement('span');
  langLabel.className = 'code-block-lang';
  langLabel.textContent = lang || 'code';
  var btn = document.createElement('button');
  btn.className = 'code-copy-btn';
  btn.innerHTML = '<span>' + (i18nData.copy || 'Copy') + '</span>';
  btn.setAttribute('aria-label', i18nData.copy || 'Copy');
  btn.addEventListener('click', function() {
    var text = code ? code.textContent : pre.textContent;
    navigator.clipboard.writeText(text);
    t('code_copy', { language: lang });
    btn.querySelector('span').textContent = i18nData.copied || 'Copied!';
    setTimeout(function() { btn.querySelector('span').textContent = i18nData.copy || 'Copy'; }, 2000);
  });

  // Wrap: soft-wrap long lines in place instead of horizontal scrolling.
  var wrapBtn = document.createElement('button');
  wrapBtn.className = 'code-copy-btn code-wrap-btn';
  wrapBtn.textContent = i18nData.wrap || 'Wrap';
  wrapBtn.setAttribute('aria-pressed', 'false');
  wrapBtn.addEventListener('click', function() {
    var wrapped = pre.style.whiteSpace === 'pre-wrap';
    pre.style.whiteSpace = wrapped ? '' : 'pre-wrap';
    pre.style.overflowWrap = wrapped ? '' : 'break-word';
    wrapBtn.setAttribute('aria-pressed', String(!wrapped));
    t('code_wrap', { language: lang, wrapped: !wrapped });
    syncScrollable();
  });

  // Expand: hand the block to the fullscreen viewer (wired in the module
  // script below via this custom event).
  var expandBtn = document.createElement('button');
  expandBtn.className = 'code-copy-btn code-expand-btn';
  expandBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="pointer-events:none"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>';
  expandBtn.setAttribute('aria-label', i18nData.expand || 'Expand');
  expandBtn.addEventListener('click', function() {
    document.dispatchEvent(new CustomEvent('post:code-expand', {
      detail: { code: code ? code.textContent : pre.textContent, title: pre.getAttribute('data-filename') || lang || 'code' }
    }));
    t('code_expand', { language: lang });
  });

  header.appendChild(langLabel);
  header.appendChild(wrapBtn);
  header.appendChild(btn);
  header.appendChild(expandBtn);
  pre.parentNode.insertBefore(wrapper, pre);
  wrapper.appendChild(header);
  wrapper.appendChild(pre);

  // Fade cue: only when the block actually overflows, gone at the far edge.
  function syncScrollable() {
    var scrollable = pre.scrollWidth > pre.clientWidth + 1;
    if (scrollable) wrapper.setAttribute('data-scrollable', '');
    else wrapper.removeAttribute('data-scrollable');
    syncAtEnd();
  }
  function syncAtEnd() {
    var atEnd = pre.scrollLeft + pre.clientWidth >= pre.scrollWidth - 2;
    if (atEnd) wrapper.setAttribute('data-at-end', '');
    else wrapper.removeAttribute('data-at-end');
  }
  pre.addEventListener('scroll', syncAtEnd, { passive: true });
  window.addEventListener('resize', syncScrollable, { passive: true });
  syncScrollable();
});

/* Consolidated scroll controller: one rAF-throttled listener drives the
   reading-progress bar, the mobile reading-bar ring/labels, the active
   section (sidebar TOC, bottom sheet, reading bar) and the scroll-depth
   analytics milestones. */
(function() {
  var bar = document.querySelector('.reading-progress-bar');
  var progressEl = document.querySelector('.reading-progress');
  var ring = document.querySelector('.prb-ring-fill');
  var prbSection = document.querySelector('[data-prb-section]');
  var prbProgress = document.querySelector('[data-prb-progress]');
  var sheetProgress = document.querySelector('[data-sheet-progress]');
  var readingBar = document.querySelector('.post-reading-bar');
  var totalMinutes = parseInt(i18nData.readingMinutes || '0', 10);
  var postTitle = prbSection ? prbSection.textContent : '';
  var RING_C = 75.4;

  if (readingBar && window.matchMedia('(max-width: 1279px), (hover: none) and (pointer: coarse)').matches) {
    readingBar.hidden = false;
  }

  var tocLinks = document.querySelectorAll('[data-toc-link]');
  var sheetLinks = document.querySelectorAll('[data-sheet-toc-link]');
  var headingEls = [];
  tocLinks.forEach(function(link, i) {
    var id = link.getAttribute('href').slice(1);
    var el = document.getElementById(id);
    if (el) headingEls.push({ el: el, link: link, sheetLi: sheetLinks[i] ? sheetLinks[i].parentNode : null, text: link.textContent });
    link.addEventListener('click', function() { t('toc_click', { section: link.textContent }); });
  });

  var milestones = [25, 50, 75, 100];
  var fired = {};
  var ticking = false;

  function update() {
    ticking = false;
    var scrollTop = window.scrollY;
    var docHeight = document.documentElement.scrollHeight - window.innerHeight;
    var pct = docHeight > 0 ? Math.min((scrollTop / docHeight) * 100, 100) : 0;

    if (bar) bar.style.width = pct + '%';
    if (progressEl) progressEl.setAttribute('aria-valuenow', String(Math.round(pct)));
    if (ring) ring.style.strokeDashoffset = String(RING_C * (1 - pct / 100));

    if (prbProgress && totalMinutes > 0) {
      var minsLeft = Math.max(0, Math.ceil(totalMinutes * (1 - pct / 100)));
      var label = Math.round(pct) + '% · ' + (minsLeft > 0
        ? (i18nData.minLeft || '{n} min left').replace('{n}', String(minsLeft))
        : (i18nData.done || 'Done'));
      prbProgress.textContent = label;
      if (sheetProgress) sheetProgress.textContent = label;
    }

    var current = null;
    var scrollPos = scrollTop + 100;
    for (var i = 0; i < headingEls.length; i++) {
      if (headingEls[i].el.offsetTop <= scrollPos) current = headingEls[i];
    }
    headingEls.forEach(function(h) {
      h.link.classList.remove('toc-active');
      h.link.removeAttribute('aria-current');
      if (h.sheetLi) h.sheetLi.classList.remove('sheet-active');
    });
    if (current) {
      current.link.classList.add('toc-active');
      current.link.setAttribute('aria-current', 'true');
      if (current.sheetLi) current.sheetLi.classList.add('sheet-active');
    }
    if (prbSection) prbSection.textContent = current ? current.text : postTitle;

    for (var j = 0; j < milestones.length; j++) {
      var m = milestones[j];
      if (pct >= m && !fired[m]) {
        fired[m] = true;
        t('scroll_depth', { depth: m });
      }
    }
  }

  window.addEventListener('scroll', function() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(update);
  }, { passive: true });
  update();
})();

/* Time on page */
(function() {
  var start = Date.now();
  function sendTime() {
    var seconds = Math.round((Date.now() - start) / 1000);
    if (seconds > 3) t('time_on_page', { seconds: seconds });
  }
  document.addEventListener('visibilitychange', function() {
    if (document.visibilityState === 'hidden') sendTime();
  });
  window.addEventListener('beforeunload', sendTime);
})();

/* External link clicks */
(function() {
  document.querySelector('.prose').addEventListener('click', function(e) {
    var link = e.target.closest('a[href]');
    if (!link) return;
    var href = link.getAttribute('href');
    if (href && href.startsWith('http') && !href.includes('warrendeleon.com')) {
      t('external_link', { url: href });
    }
  });
})();

/* Scroll to top */
(function() {
  var btn = document.querySelector('.scroll-to-top');
  if (!btn) return;
  function toggle() {
    if (window.scrollY > 400) { btn.hidden = false; } else { btn.hidden = true; }
  }
  window.addEventListener('scroll', toggle, { passive: true });
  btn.addEventListener('click', function() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
  toggle();
})();
</script>

<script>
  import { createOverlay } from '../../scripts/overlay';

  declare function t(event: string, data?: Record<string, unknown>): void;

  const i18nEl = document.getElementById('blog-i18n');
  const D = i18nEl ? (i18nEl as HTMLElement).dataset : ({} as DOMStringMap);
  const reduce = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ----- TOC bottom sheet -----
  const tocSheet = document.getElementById('toc-sheet');
  const tocOpenBtn = document.querySelector('[data-toc-open]');
  if (tocSheet && tocOpenBtn) {
    const tocOverlay = createOverlay({
      root: tocSheet,
      panel: tocSheet.querySelector('.post-sheet-panel') as HTMLElement,
      onOpen: () => tocOpenBtn.setAttribute('aria-expanded', 'true'),
      onClose: () => tocOpenBtn.setAttribute('aria-expanded', 'false'),
    });
    // ≥1024px the sidebar TOC covers navigation, so the pill stops being a
    // sheet trigger. Reactive: iPad rotation crosses this boundary live.
    const sidebarBand = window.matchMedia('(min-width: 1024px)');
    const syncTocTrigger = () => {
      if (sidebarBand.matches) tocOpenBtn.setAttribute('disabled', '');
      else tocOpenBtn.removeAttribute('disabled');
    };
    sidebarBand.addEventListener('change', syncTocTrigger);
    syncTocTrigger();
    tocOpenBtn.addEventListener('click', () => {
      tocOverlay.open();
      t('toc_sheet_open');
    });
    tocSheet.querySelectorAll('[data-sheet-toc-link]').forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const id = (link.getAttribute('href') || '').slice(1);
        const el = document.getElementById(id);
        tocOverlay.close();
        if (el) {
          window.setTimeout(() => {
            el.scrollIntoView({ behavior: reduce() ? 'auto' : 'smooth', block: 'start' });
          }, 120);
        }
        t('toc_click', { section: link.textContent?.trim() });
      });
    });
  }

  // ----- Share: native sheet first, custom sheet as fallback -----
  const shareSheet = document.getElementById('share-sheet');
  const shareOpenBtn = document.querySelector('[data-share-open]');
  if (shareSheet && shareOpenBtn) {
    const shareOverlay = createOverlay({
      root: shareSheet,
      panel: shareSheet.querySelector('.post-sheet-panel') as HTMLElement,
    });
    shareOpenBtn.addEventListener('click', async () => {
      if (navigator.share) {
        try {
          await navigator.share({ title: D.shareTitle, url: D.shareUrl });
          t('blog_share', { platform: 'native' });
          return;
        } catch (err) {
          // Cancelled or unsupported payload: fall through to the sheet.
          if ((err as DOMException).name === 'AbortError') return;
        }
      }
      shareOverlay.open();
    });
  }

  // ----- Fullscreen code viewer -----
  const viewer = document.getElementById('code-viewer');
  if (viewer) {
    const titleEl = viewer.querySelector('[data-viewer-title]') as HTMLElement;
    const preEl = viewer.querySelector('[data-viewer-pre]') as HTMLElement;
    const wrapBtn = viewer.querySelector('[data-viewer-wrap]') as HTMLButtonElement;
    const copyBtn = viewer.querySelector('[data-viewer-copy]') as HTMLButtonElement;
    const copyLabel = copyBtn.textContent || 'Copy';
    const viewerOverlay = createOverlay({
      root: viewer,
      initialFocus: () => preEl,
    });
    document.addEventListener('post:code-expand', (e) => {
      const detail = (e as CustomEvent).detail || {};
      titleEl.textContent = detail.title || 'code';
      preEl.textContent = detail.code || '';
      preEl.removeAttribute('data-wrap');
      wrapBtn.setAttribute('aria-pressed', 'false');
      viewerOverlay.open();
    });
    wrapBtn.addEventListener('click', () => {
      const wrapped = preEl.hasAttribute('data-wrap');
      if (wrapped) preEl.removeAttribute('data-wrap');
      else preEl.setAttribute('data-wrap', '');
      wrapBtn.setAttribute('aria-pressed', String(!wrapped));
    });
    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(preEl.textContent || '');
      copyBtn.textContent = D.copied || 'Copied!';
      window.setTimeout(() => { copyBtn.textContent = copyLabel; }, 2000);
    });
  }

  // ----- Reading-bar back to top -----
  document.querySelector('[data-prb-top]')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: reduce() ? 'auto' : 'smooth' });
  });

  // ----- Series shelf arrows (desktop band; CSS hides them below 1280) -----
  const shelf = document.querySelector('[data-series-shelf]') as HTMLElement | null;
  const arrows = document.querySelector('.series-nav-arrows') as HTMLElement | null;
  if (shelf && arrows) {
    const prev = arrows.querySelector('[data-series-prev]') as HTMLButtonElement;
    const next = arrows.querySelector('[data-series-next]') as HTMLButtonElement;
    const sync = () => {
      const overflows = shelf.scrollWidth > shelf.clientWidth + 1;
      arrows.hidden = !overflows;
      prev.disabled = shelf.scrollLeft <= 0;
      next.disabled = shelf.scrollLeft + shelf.clientWidth >= shelf.scrollWidth - 2;
    };
    const step = () => Math.max(shelf.clientWidth * 0.8, 230);
    prev.addEventListener('click', () => shelf.scrollBy({ left: -step(), behavior: reduce() ? 'auto' : 'smooth' }));
    next.addEventListener('click', () => shelf.scrollBy({ left: step(), behavior: reduce() ? 'auto' : 'smooth' }));
    shelf.addEventListener('scroll', sync, { passive: true });
    window.addEventListener('resize', sync, { passive: true });
    sync();
  }
</script>
</BaseLayout>

<style is:global>

  /* .reading-progress styles live in ReadingProgress.astro (shared with the
     design docs). */
  .post-hero-image { position: relative; width: 100vw; height: 420px; overflow: hidden; margin-left: calc(-50vw + 50%); }
  .post-hero-image-bg { position: absolute; inset: -60px; background-size: cover; background-position: center; filter: blur(24px) saturate(1.4) brightness(0.9); z-index: 0; }
  .post-hero-image img { position: relative; max-width: 1080px; width: 100%; height: 420px; object-fit: cover; display: block; margin: 0 auto; z-index: 1; }
  .post-hero-image-overlay { display: none; }
  .post-hero-image::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 100%; background: linear-gradient(to bottom, transparent 90%, var(--bg-secondary)); pointer-events: none; z-index: 2; }
  .post-hero { padding: 2rem 0 1.5rem; background: var(--bg-secondary); margin-bottom: 0; }
  .post-content-section { padding-top: 1.5rem; }
  /* Post title (design): 26px mobile · 30px tablet · 38px desktop. */
  .post-hero h1 { font-size: 38px; line-height: 1.2; margin-bottom: 1.25rem; letter-spacing: -0.02em; }
  .post-meta { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; font-size: 0.9rem; color: var(--text-muted); }
  .post-meta-separator { color: var(--text-muted); opacity: 0.4; }
  .post-meta-reading { display: inline-flex; align-items: center; gap: 0.35rem; }
  .post-meta-reading svg { opacity: 0.6; }
  /* Tag chips: shared .post-tag primitive in global.css. */
  .post-layout { display: grid; grid-template-columns: 1fr 280px; gap: 2rem; align-items: start; }
  .post-layout > .toc { grid-column: 2; grid-row: 1; align-self: start; }
  /* min-width: 0 lets the 1fr track shrink below the content's intrinsic width.
     Without it a wide child (mermaid SVG, code, table) blows the column past the
     viewport and the body text wraps to that over-wide column on mobile. */
  .post-layout > .prose { grid-column: 1; grid-row: 1; min-width: 0; }
  /* .toc visual styles live in Toc.astro (shared with the design docs);
     the .post-layout grid rules for it stay here. */
  .blog-back-link { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.95rem; font-weight: 500; color: var(--text-secondary); margin-bottom: 1.5rem; transition: color 0.2s ease, gap 0.2s ease; }
  .blog-back-link:hover { color: var(--color-green-text); gap: 0.6rem; }

  /* Design: the in-body back link is desktop-only — mobile/tablet use the
     top bar chevron, so both showing doubles the affordance. */
  @media (max-width: 1279px), (hover: none) and (pointer: coarse) {
    .blog-back-link { display: none; }
  }
  /* .author-card styles live in AuthorCard.astro (shared with the design docs). */
  .share-links { display: flex; align-items: center; gap: 0.75rem; margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--border-color); flex-wrap: wrap; }
  .share-links > span { font-size: 0.9rem; color: var(--text-muted); font-weight: 600; }
  .share-btn { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.95rem; padding: 0.45rem 0.85rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-card); color: var(--text-secondary); cursor: pointer; text-decoration: none; font-weight: 500; transition: border-color 0.2s ease, color 0.2s ease, transform 0.15s ease; font-family: inherit; }
  .share-btn:hover { border-color: var(--color-green); color: var(--color-green-text); transform: translateY(-1px); }
  .share-btn svg { flex-shrink: 0; }
  .related-posts { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border-color); }
  /* .related-card styles live in RelatedCard.astro (shared with the design docs). */
  .blog-nav { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 3rem; }
  .blog-nav-link { display: flex; flex-direction: column; gap: 0.5rem; padding: 1.25rem 1.5rem; border: 1px solid var(--border-color); border-radius: 12px; background: var(--bg-secondary); text-decoration: none; transition: border-color 0.2s ease, transform 0.2s ease; }
  .blog-nav-link:hover { border-color: var(--color-green); transform: translateY(-2px); }
  .blog-nav-label { display: flex; align-items: center; gap: 0.35rem; font-size: 0.9rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; color: var(--color-green-text); }
  .blog-nav-title { font-size: 0.95rem; font-weight: 500; color: var(--text-primary); line-height: 1.35; }
  .blog-nav-next { text-align: right; }
  .blog-nav-next .blog-nav-label { justify-content: flex-end; }
  .scroll-to-top { position: fixed; bottom: 2rem; right: 2rem; width: 44px; height: 44px; border-radius: 50%; border: 1px solid var(--border-color); background: var(--bg-card); color: var(--text-secondary); cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow); transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease, opacity 0.2s ease; z-index: 50; }
  .scroll-to-top:hover { border-color: var(--color-green); color: var(--color-green-text); transform: translateY(-2px); }
  .scroll-to-top[hidden] { display: none; }

  /* ===== Mobile reading bar =====
     On post pages it REPLACES the tab bar (per the design): reading room
     beats section switching mid-article, and back is one tap away.
     nav.tab-bar[aria-label] out-specifies TabBar's Astro-scoped selector
     (.tab-bar[data-astro-cid-*]), which a bare .tab-bar loses to. */
  @media (max-width: 1279px), (hover: none) and (pointer: coarse) {
    nav.tab-bar[aria-label] { display: none; }
  }
  /* .post-reading-bar / .prb-* styles live in ReadingBar.astro (shared with
     the design docs). */

  /* ===== Fullscreen code viewer ===== */
  .code-viewer { position: fixed; inset: 0; z-index: 90; background: var(--bg-primary); display: flex; flex-direction: column; opacity: 0; transition: opacity 0.2s ease; }
  .code-viewer[hidden] { display: none; }
  .code-viewer.is-open { opacity: 1; }
