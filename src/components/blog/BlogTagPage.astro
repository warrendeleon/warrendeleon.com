---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogSearch from './BlogSearch.astro';
import SubscribeForm from '../SubscribeForm.astro';
import { t, getLocalePath } from '../../i18n/index';
import type { Locale } from '../../i18n/index';
import { getTagLabel } from '../../i18n/tagLabels';
import { getReadingTime } from '../../utils/readingTime';
import { getPostSlug, formatBlogDate, toDateString, shortenSeriesName, getSeriesSlug } from '../../utils/blogHelpers';
import BreadcrumbsJsonLd from '../BreadcrumbsJsonLd.astro';

interface Props {
  locale: Locale;
  posts: any[];
  tag: string;
}

const { locale, posts, tag } = Astro.props;
const i18n = t(locale);
const blogPath = getLocalePath(locale, '/blog/');
const tagLabel = getTagLabel(tag, locale);

// Thin tag pages are near dead ends; the series these posts belong to are the
// natural next hop, so surface them as chips under the header.
const relatedSeries = [...new Set(posts.map((p: any) => p.data.series).filter(Boolean))]
  .map((name) => ({ name: name as string, slug: getSeriesSlug(name as string) }));
---

<BaseLayout
  title={`${i18n.blog.postsTagged} ${tagLabel} | Warren de Leon`}
  description={`${i18n.blog.postsTagged} ${tagLabel}`}
  locale={locale}
  currentPath={getLocalePath(locale, `/blog/tags/${tag}/`)}
  mobileBack={{ href: getLocalePath(locale, '/blog/tags/'), title: tagLabel, eyebrow: i18n.blog.browseByTag }}
>
  <BlogSearch locale={locale} />
  <BreadcrumbsJsonLd items={[
    { name: 'Warren de Leon', url: getLocalePath(locale, '/') },
    { name: 'Blog', url: blogPath },
    { name: i18n.blog.browseByTag, url: getLocalePath(locale, '/blog/tags/') },
    { name: tagLabel },
  ]} />

  <section class="section">
    <div class="container">
      <div class="tag-page-header">
        <a href={blogPath} class="blog-back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          {i18n.blog.backToBlog}
        </a>
        <!-- Design: the tag name renders in the mono face. -->
        <h1 class="section-title tag-page-title">{i18n.blog.postsTagged} <span class="blog-mono">{tagLabel}</span></h1>
        <p class="tag-page-count">{posts.length} {posts.length === 1 ? i18n.blog.post : i18n.blog.posts}</p>
        {relatedSeries.length > 0 && (
          <p class="tag-page-series">
            {i18n.blog.seriesLabel}:
            {relatedSeries.map((s) => (
              <a href={getLocalePath(locale, `/blog/series/${s.slug}/`)} class="post-tag">{shortenSeriesName(s.name)}</a>
            ))}
          </p>
        )}
      </div>

      <div class="blog-feed">
        {posts.map(post => (
          <a
            href={getLocalePath(locale, `/blog/${getPostSlug(post.id)}/`)}
            class="feed-post"
            data-publish-date={toDateString(post.data.publishDate)}
          >
            {post.data.heroImage && (
              <div class="feed-post-thumb">
                <img src={post.data.heroImage} alt={post.data.heroAlt || post.data.title} loading="lazy" />
              </div>
            )}
            <div class="feed-post-body">
              <div class="feed-post-meta blog-mono">
                <span>{formatBlogDate(post.data.publishDate, locale)} &middot; {getReadingTime(post.body ?? '')} {i18n.blog.minRead}</span>
                {post.data.series && <span class="feed-post-series">{shortenSeriesName(post.data.series)}</span>}
              </div>
              <h2 class="feed-post-title">{post.data.title}</h2>
              <p class="feed-post-desc">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>

      <p id="blog-empty" class="blog-empty" style="display: none;" data-is-dev={import.meta.env.DEV ? 'true' : undefined}>{i18n.blog.noPostsYet}</p>
    </div>
  </section>

  <SubscribeForm locale={locale} />
</BaseLayout>

<script is:inline>
(function () {
  function filterPosts() {
    if (document.querySelector('#blog-empty[data-is-dev]')) return;
    var now = new Date();
    var todayStr = now.getFullYear() + '-' +
      String(now.getMonth() + 1).padStart(2, '0') + '-' +
      String(now.getDate()).padStart(2, '0');
    var cards = document.querySelectorAll('.feed-post[data-publish-date]');
    var visibleCount = 0;
    cards.forEach(function (card) {
      var publishStr = card.getAttribute('data-publish-date');
      if (publishStr > todayStr) {
        card.style.display = 'none';
      } else {
        visibleCount++;
      }
    });
    var emptyMsg = document.getElementById('blog-empty');
    if (emptyMsg) emptyMsg.style.display = visibleCount === 0 ? 'block' : 'none';
    var countEl = document.querySelector('.tag-page-count');
    if (countEl) {
      if (visibleCount === 0) { countEl.style.display = 'none'; }
    }
  }
  filterPosts();
})();
</script>

<style is:global>
  .tag-page-header { margin-bottom: 2rem; }
  .tag-page-header .blog-back-link { display: flex; width: fit-content; align-items: center; gap: 0.4rem; font-size: 0.9rem; font-weight: 500; color: var(--text-secondary); margin-bottom: 1.5rem; transition: color 0.2s ease, gap 0.2s ease; }
  .tag-page-header .blog-back-link:hover { color: var(--color-green-text); gap: 0.6rem; }

  /* Design: the in-body back link is desktop-only — mobile/tablet use the
     top bar chevron. */
  @media (max-width: 1279px), (hover: none) and (pointer: coarse) {
    .tag-page-header .blog-back-link { display: none; }
  }
  .tag-page-count { font-size: 1rem; color: var(--text-muted); margin-top: 0.75rem; }

  /* Detail-page title (design): 26px mobile, 30px from tablet up. */
  .tag-page-title { font-size: 30px; }
  @media (max-width: 699px) {
    .tag-page-title { font-size: 26px; }
  }
  .tag-page-series { margin-top: 0.6rem; display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: baseline; color: var(--text-muted); font-size: 0.95rem; }
  /* Post list reuses the shared .feed-post row card (global.css) */
  .blog-empty { text-align: center; color: var(--text-muted); font-size: 1rem; margin-top: 2rem; }
</style>
