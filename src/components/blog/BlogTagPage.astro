---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLocalePath } from '../../i18n/index';
import type { Locale } from '../../i18n/index';
import { getTagLabel } from '../../i18n/tagLabels';
import { getReadingTime } from '../../utils/readingTime';
import { getPostSlug, formatBlogDate, toDateString } from '../../utils/blogHelpers';

interface Props {
  locale: Locale;
  posts: any[];
  tag: string;
}

const { locale, posts, tag } = Astro.props;
const i18n = t(locale);
const blogPath = getLocalePath(locale, '/blog/');
const tagLabel = getTagLabel(tag, locale);
---

<BaseLayout
  title={`${i18n.blog.postsTagged} ${tagLabel} | Warren de Leon`}
  description={`${i18n.blog.postsTagged} ${tagLabel}`}
  locale={locale}
  currentPath={getLocalePath(locale, `/blog/tag/${tag}/`)}
>
  <section class="section">
    <div class="container">
      <div class="tag-page-header">
        <a href={blogPath} class="blog-back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          {i18n.blog.backToBlog}
        </a>
        <h1 class="section-heading">{i18n.blog.postsTagged} {tagLabel}</h1>
        <p class="tag-page-count">{posts.length} {posts.length === 1 ? i18n.blog.post : i18n.blog.posts}</p>
      </div>

      <div class="blog-grid">
        {posts.map(post => (
          <a
            href={getLocalePath(locale, `/blog/${getPostSlug(post.id)}/`)}
            class="blog-card"
            data-publish-date={toDateString(post.data.publishDate)}
          >
            {post.data.heroImage && (
              <div class="blog-card-image">
                <img src={post.data.heroImage} alt={post.data.heroAlt || post.data.title} loading="lazy" />
              </div>
            )}
            <div class="blog-card-content">
              <span class="blog-card-meta">
                {formatBlogDate(post.data.publishDate, locale)} &middot; {getReadingTime(post.body ?? '')} {i18n.blog.minRead}
              </span>
              <h2 class="blog-card-title">{post.data.title}</h2>
              <p class="blog-card-desc">{post.data.description}</p>
              <div class="blog-card-tags">
                {post.data.tags.map((t: string) => (
                  <span class="blog-tag">{getTagLabel(t, locale)}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>

      <p id="blog-empty" class="blog-empty" style="display: none;">{i18n.blog.noPostsYet}</p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
(function () {
  function filterPosts() {
    var now = new Date();
    var todayStr = now.getFullYear() + '-' +
      String(now.getMonth() + 1).padStart(2, '0') + '-' +
      String(now.getDate()).padStart(2, '0');
    var cards = document.querySelectorAll('.blog-card[data-publish-date]');
    var visibleCount = 0;
    cards.forEach(function (card) {
      var publishStr = card.getAttribute('data-publish-date');
      if (publishStr > todayStr) {
        card.style.display = 'none';
      } else {
        visibleCount++;
      }
    });
    var emptyMsg = document.getElementById('blog-empty');
    if (emptyMsg) emptyMsg.style.display = visibleCount === 0 ? 'block' : 'none';
    var countEl = document.querySelector('.tag-page-count');
    if (countEl) {
      if (visibleCount === 0) { countEl.style.display = 'none'; }
    }
  }
  filterPosts();
})();
</script>

<style is:global>
  .tag-page-header { margin-bottom: 2rem; }
  .tag-page-header .blog-back-link { display: flex; width: fit-content; align-items: center; gap: 0.4rem; font-size: 0.9rem; font-weight: 500; color: var(--text-secondary); margin-bottom: 1.5rem; transition: color 0.2s ease, gap 0.2s ease; }
  .tag-page-header .blog-back-link:hover { color: var(--color-green); gap: 0.6rem; }
  .tag-page-count { font-size: 0.9rem; color: var(--text-muted); margin-top: 0.5rem; }
  .blog-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 1.5rem; }
  .blog-card { display: flex; flex-direction: column; text-decoration: none; color: inherit; background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 12px; overflow: hidden; box-shadow: var(--shadow); transition: box-shadow 0.2s ease, transform 0.2s ease; }
  .blog-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-hover); }
  .blog-card:hover .blog-card-title { color: var(--color-green); }
  .blog-card-image { width: 100%; height: 200px; overflow: hidden; }
  .blog-card-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
  .blog-card:hover .blog-card-image img { transform: scale(1.03); }
  .blog-card-content { display: flex; flex-direction: column; flex: 1; padding: 1.25rem 1.5rem 1.5rem; }
  .blog-card-meta { font-size: 0.9rem; color: var(--text-muted); display: block; margin-bottom: 0.75rem; }
  .blog-card-title { font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem; transition: color 0.2s ease; line-height: 1.3; }
  .blog-card-desc { color: var(--text-secondary); font-size: 1rem; line-height: 1.6; margin-bottom: 1rem; flex: 1; }
  .blog-card-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .blog-tag { display: inline-block; padding: 0.25rem 0.65rem; border-radius: 6px; font-size: 0.9rem; font-weight: 600; background: var(--badge-bg); color: var(--badge-text); border: 1px solid var(--border-color); }
  .blog-empty { text-align: center; color: var(--text-muted); font-size: 1rem; margin-top: 2rem; }
</style>
