---
import { t, getLocalePath } from '../../i18n/index';
import type { Locale } from '../../i18n/index';
import { getSeriesSlug, getSeriesPosts, getSeriesProgress, publishSlot } from '../../utils/blogHelpers';
import { getSeriesDescription } from '../../i18n/seriesDescriptions';

interface Props {
  locale: Locale;
  seriesName: string;
}

const { locale, seriesName } = Astro.props;
const i18n = t(locale);

const seriesSlug = getSeriesSlug(seriesName);
// Date-gated so the dev preview (which includes future posts) matches prod.
const nowTs = new Date();
const parts = (await getSeriesPosts(locale, seriesSlug)).filter(p => publishSlot(p.data.publishDate) <= nowTs);
const intro = parts[0];
// Prefer the curated, translated series description; fall back to the intro post's.
const desc = getSeriesDescription(seriesName, locale) || intro?.data.description || '';
const hubPath = getLocalePath(locale, `/blog/series/${seriesSlug}/`);

// Design: eyebrow carries the whole arc ("19 parts · Ongoing — next part
// 29 Jun" on tablet/desktop, "19 parts · In progress" on mobile) and the
// progress block shows published-of-total.
const progress = await getSeriesProgress(locale, seriesName);
const progressPct = progress.total > 0 ? Math.round((progress.published / progress.total) * 100) : 0;
const nextLabel = progress.nextDate
  ? progress.nextDate.toLocaleDateString(locale === 'en' ? 'en-GB' : locale, { day: 'numeric', month: 'short' })
  : null;
---

{intro && parts.length >= 2 && (
  <div class="series-hero-card">
    <div class="series-hero-art" aria-hidden="true">
      {intro.data.heroImage && (
        <img src={intro.data.heroImage} alt="" loading="lazy" />
      )}
    </div>
    <div class="series-hero-body">
      <span class="series-hero-eyebrow blog-mono">
        {`${progress.total} ${i18n.blog.parts}`} &middot;{' '}
        {nextLabel ? (
          <>
            <span class="series-hero-eyebrow-full">{i18n.blog.seriesOngoing.replace('{date}', nextLabel)}</span>
            <span class="series-hero-eyebrow-short">{i18n.blog.inProgress}</span>
          </>
        ) : (
          i18n.blog.seriesComplete
        )}
      </span>
      <h3 class="series-hero-title">
        <a class="series-hero-link" href={hubPath}>{seriesName}</a>
      </h3>
      <p class="series-hero-desc">{desc}</p>
      <div class="series-hero-progress">
        <div class="series-hero-progress-row">
          <span>{i18n.blog.publishedOfTotal.replace('{x}', String(progress.published)).replace('{y}', String(progress.total))}</span>
          <span class="series-hero-hint">{i18n.blog.startSeries} <span aria-hidden="true">&rarr;</span></span>
          {nextLabel && <span class="series-hero-next">{i18n.blog.nextPart} &middot; {nextLabel}</span>}
        </div>
        <div class="series-hero-progress-track">
          <div class="series-hero-progress-fill" style={`width: ${progressPct}%`}></div>
        </div>
      </div>
      <span class="series-hero-view" aria-hidden="true">{i18n.blog.viewSeries}</span>
    </div>
  </div>
)}

<style>
  /* Design "Blog Home Desktop/Tablet": one compact clickable card — image
     column | text column. The title link stretches over the whole card. */
  .series-hero-card {
    position: relative;
    display: grid;
    grid-template-columns: 440px 1fr;
    border: 1px solid var(--border-color);
    border-radius: 14px;
    overflow: hidden;
    background: var(--bg-card);
    box-shadow: var(--shadow-card);
  }

  .series-hero-link { color: inherit; text-decoration: none; }
  .series-hero-link::after { content: ''; position: absolute; inset: 0; }
  .series-hero-card:hover { border-color: var(--color-green); }

  .series-hero-art {
    position: relative;
    background: var(--bg-secondary);
    min-height: 250px;
  }

  .series-hero-art img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .series-hero-body {
    padding: 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 11px;
    justify-content: center;
  }

  .series-hero-eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-green-text);
  }

  /* Mobile swaps the long eyebrow tail for "In progress". */
  .series-hero-eyebrow-short { display: none; }

  .series-hero-title {
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.015em;
    line-height: 1.25;
    color: var(--text-primary);
    margin: 0;
  }

  .series-hero-desc {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .series-hero-progress {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 6px;
  }

  .series-hero-progress-row {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    font-size: 11.5px;
    font-weight: 600;
    color: var(--text-muted);
  }

  .series-hero-hint { color: var(--color-green-text); font-weight: 700; }
  .series-hero-next { display: none; }

  .series-hero-progress-track {
    height: 6px;
    border-radius: 3px;
    background: var(--badge-bg);
    overflow: hidden;
  }

  .series-hero-progress-fill {
    height: 100%;
    border-radius: 3px;
    background: var(--color-green);
  }

  /* The View series button is the mobile artboard's affordance. */
  .series-hero-view { display: none; }

  /* Tablet band (design): 360px image, tighter column, no shadow. */
  @media (max-width: 1279px) {
    .series-hero-card {
      grid-template-columns: 360px 1fr;
      border-radius: 16px;
      box-shadow: none;
    }
    .series-hero-art { min-height: 200px; }
    .series-hero-body { padding: 20px 24px; gap: 9px; }
    .series-hero-eyebrow { font-size: 11px; letter-spacing: 0.07em; }
    .series-hero-title { font-size: 19px; font-weight: 700; letter-spacing: -0.01em; line-height: 1.3; }
    .series-hero-desc { font-size: 13.5px; line-height: 1.55; }
    .series-hero-progress { max-width: 420px; margin-top: 0; }
  }

  /* Mobile (design): stacked card — image, copy, progress with next-part
     date, solid View series button. */
  @media (max-width: 699px) {
    .series-hero-card { display: flex; flex-direction: column; }
    .series-hero-art { min-height: 0; aspect-ratio: 21 / 10; }
    .series-hero-art img { position: static; display: block; }
    .series-hero-body { padding: 14px 16px 16px; gap: 6px; }
    .series-hero-eyebrow { font-size: 10.5px; }
    .series-hero-eyebrow-full { display: none; }
    .series-hero-eyebrow-short { display: inline; }
    .series-hero-title { font-size: 18.4px; }
    .series-hero-desc { font-size: 13px; }
    .series-hero-progress { max-width: none; margin-top: 6px; }
    .series-hero-hint { display: none; }
    .series-hero-next { display: inline; }

    .series-hero-view {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 44px;
      margin-top: 4px;
      border-radius: 22px;
      background: var(--color-green);
      color: #ffffff;
      font-size: 13.5px;
      font-weight: 700;
    }
  }
</style>
