---
import { t, getLocalePath } from '../../i18n/index';
import type { Locale } from '../../i18n/index';
import { getPostSlug, getSeriesSlug, getSeriesPosts, toDateString } from '../../utils/blogHelpers';
import { getSeriesDescription } from '../../i18n/seriesDescriptions';

interface Props {
  locale: Locale;
  seriesName: string;
}

const { locale, seriesName } = Astro.props;
const i18n = t(locale);

const seriesSlug = getSeriesSlug(seriesName);
const parts = await getSeriesPosts(locale, seriesSlug);
const intro = parts[0];
// Prefer the curated, translated series description; fall back to the intro post's.
const desc = getSeriesDescription(seriesName, locale) || intro?.data.description || '';
const HERO_PART_LIMIT = 5;
const visibleParts = parts.slice(0, HERO_PART_LIMIT);
const hubPath = getLocalePath(locale, `/blog/series/${seriesSlug}/`);
---

{intro && parts.length >= 2 && (
  <div class="series-hero-card">
    <div class="series-hero-head">
      <h3 class="series-hero-title">
        <a href={hubPath}>{seriesName}</a>
      </h3>
      <p class="series-hero-desc">{desc}</p>
    </div>
    <div class="series-hero-grid">
      <a class="series-hero-art" href={hubPath} tabindex="-1" aria-hidden="true">
        {intro.data.heroImage && (
          <img src={intro.data.heroImage} alt={intro.data.heroAlt || seriesName} loading="lazy" />
        )}
      </a>
      <div class="series-hero-parts">
        <ol class="series-parts">
          {visibleParts.map((p, i) => (
            <li data-publish-date={toDateString(p.data.publishDate)}>
              <a href={getLocalePath(locale, `/blog/${getPostSlug(p.id)}/`)}>
                <span class="series-part-n blog-mono">{String(i + 1).padStart(2, '0')}</span>
                <span class="series-part-title">{p.data.title}</span>
              </a>
            </li>
          ))}
        </ol>
        <a class="series-hero-cta" href={hubPath}>
          {i18n.blog.viewAllParts.replace('{n}', String(parts.length))} <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
)}

<style>
  .series-hero-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    box-shadow: var(--shadow);
    padding: 2.6rem 2.8rem;
  }

  .series-hero-head { margin-bottom: 2.2rem; }

  .series-hero-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 2.8rem;
    align-items: center;
  }

  .series-hero-art {
    display: block;
    aspect-ratio: 4 / 3;
    border-radius: 16px;
    overflow: hidden;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
  }

  .series-hero-art img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .series-hero-title {
    font-size: clamp(1.8rem, 3.2vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.07;
  }

  .series-hero-title a { color: var(--text-primary); text-decoration: none; transition: color 0.2s ease; }
  .series-hero-title a:hover { color: var(--color-green-text); }

  .series-hero-desc {
    margin: 1rem 0 0;
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .series-parts { list-style: none; margin: 0 0 1.6rem; padding: 0; }

  .series-parts li a {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    padding: 0.7rem 0;
    border-top: 1px solid var(--border-color);
    text-decoration: none;
    color: inherit;
  }

  .series-parts li:first-child a { border-top: none; }
  .series-part-n { flex: none; width: 1.8rem; font-size: 0.9rem; color: var(--color-green-text); }
  .series-part-title { font-size: 1.2rem; font-weight: 700; color: var(--text-primary); line-height: 1.3; transition: color 0.15s ease; }
  .series-parts li a:hover .series-part-title { color: var(--color-green-text); }

  .series-hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 0.98rem;
    color: var(--color-green-text);
    text-decoration: none;
  }

  @media (max-width: 760px) {
    .series-hero-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .series-hero-art { order: -1; aspect-ratio: 16 / 10; }
  }
</style>
