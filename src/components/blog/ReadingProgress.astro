---
// The 3px green top progress bar, extracted from BlogPost so post pages and
// the design-system docs render the same element. Each page's own script
// drives the width.
import { t, type Locale } from '../../i18n/index';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const i18n = t(locale);
---

<div class="reading-progress" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" aria-label={i18n.blog.contents}>
  <div class="reading-progress-bar"></div>
</div>

<style is:global>
  .reading-progress { position: fixed; top: 0; left: 0; width: 100%; height: 3px; z-index: 200; background: transparent; }
  .reading-progress-bar { height: 100%; width: 0; background: var(--color-green); transition: width 0.1s linear; }
</style>
