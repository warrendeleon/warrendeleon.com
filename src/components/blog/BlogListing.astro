---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogSearch from './BlogSearch.astro';
import SeriesHeroCard from './SeriesHeroCard.astro';
import SubscribeForm from '../SubscribeForm.astro';
import { t, getLocalePath } from '../../i18n/index';
import type { Locale } from '../../i18n/index';
import { getReadingTime } from '../../utils/readingTime';
import { getPostsForLocale, getPostSlug, formatBlogDate, toDateString, getAllSeries, getSeriesSlug, getSeriesPosts, getCurrentSeriesName, shortenSeriesName, publishSlot, type FeedPost } from '../../utils/blogHelpers';
import { getSeriesDescription } from '../../i18n/seriesDescriptions';
import { getTagLabel } from '../../i18n/tagLabels';
import type { Page } from 'astro';

interface Props {
  locale: Locale;
  page: Page<FeedPost>;
}

const { locale, page } = Astro.props;
const i18n = t(locale);

const allPosts = await getPostsForLocale(locale);
const allSeries = await getAllSeries(locale);
const isFirstPage = page.currentPage === 1;

// Current series = the most recent series with at least two published posts (see
// getCurrentSeriesName). Shown on page one as the lead with its parts in reading
// order. The feed route uses the same helper to demote this series' parts, so a
// mid-run break falls back to the flagship and no post is dropped from the feed.
const nowTs = new Date();
const currentSeriesName = isFirstPage ? await getCurrentSeriesName(locale) : null;
const currentSeriesSlug = currentSeriesName ? getSeriesSlug(currentSeriesName) : null;
// Date-gated to match SeriesHeroCard, which only renders date-published
// parts — an ungated count here can promise a card that never appears.
const currentParts = (currentSeriesSlug ? await getSeriesPosts(locale, currentSeriesSlug) : [])
  .filter(p => publishSlot(p.data.publishDate) <= nowTs);
const hasCurrentSeries = currentParts.length >= 2 && !!currentSeriesName && !!currentSeriesSlug;

// More series = every other series, each with its intro post for art + a description.
const moreSeriesBase = isFirstPage ? allSeries.filter(s => s.name !== currentSeriesName) : [];
const moreSeries = await Promise.all(moreSeriesBase.map(async s => {
  const intro = (await getSeriesPosts(locale, s.slug))[0];
  return { ...s, intro, desc: getSeriesDescription(s.name, locale) || intro?.data.description || '' };
}));
const feedPosts = page.data;
const blogBase = getLocalePath(locale, '/blog/');
const tagsPath = getLocalePath(locale, '/blog/tags/');

// Top tags for the desktop sidebar card, most-used first (same derivation as
// BlogSearch's "Try" chips: counted across all published posts).
const tagCounts = new Map<string, number>();
for (const p of allPosts) for (const tag of p.data.tags) tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
const topTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 8).map(([tag]) => tag);
---

<BaseLayout
  title={page.currentPage === 1 ? i18n.seo.blogTitle : i18n.blog.pageTitle.replace('{n}', String(page.currentPage))}
  description={i18n.seo.blogDescription}
  locale={locale}
  currentPath={getLocalePath(locale, page.url.current.replace(/^\/(?:es|ca|tl)/, ''))}
>
  <section class="section blog-lead">
    <div class="container">
      <h1 class="section-title blog-title">Blog</h1>

      <BlogSearch locale={locale} />

      {hasCurrentSeries && currentSeriesName && (
        <div class="series-hero">
          <div class="blog-eyebrow-row">
            <h2 class="blog-section-heading">{i18n.blog.currentSeries}</h2>
            <a class="blog-eyebrow-link" href={getLocalePath(locale, '/blog/series/')}>{i18n.blog.allSeries} <span aria-hidden="true">&rarr;</span></a>
          </div>
          <SeriesHeroCard locale={locale} seriesName={currentSeriesName} />
        </div>
      )}
    </div>
  </section>

  <section class="section blog-after">
    <div class="container">
      {moreSeries.length > 0 && (
        <div class="series-shelf-block">
          <div class="series-shelf-head">
            <h2 class="blog-section-heading">{i18n.blog.moreSeries}</h2>
            <div class="series-shelf-nav">
              <button type="button" class="series-shelf-arrow" data-dir="prev" aria-label={i18n.blog.previous}>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
              </button>
              <button type="button" class="series-shelf-arrow" data-dir="next" aria-label={i18n.blog.next}>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </button>
            </div>
          </div>
          <div class="series-shelf">
            <div class="series-shelf-track">
              {moreSeries.map(s => (
                <a class="series-card" href={getLocalePath(locale, `/blog/series/${s.slug}/`)}>
                  {s.intro?.data.heroImage && (
                    <div class="series-card-art">
                      <img src={s.intro.data.heroImage} alt={s.intro.data.heroAlt || s.name} loading="lazy" />
                    </div>
                  )}
                  <div class="series-card-body">
                    <span class="series-card-kicker blog-mono">{s.count} {i18n.blog.parts}</span>
                    <h3 class="series-card-title">{shortenSeriesName(s.name)}</h3>
                    {s.desc && <p class="series-card-desc">{s.desc}</p>}
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      )}
    </div>
  </section>

  <section class="section blog-feed-section">
    <div class="container blog-feed-grid">
      <div class="blog-feed-main">
      {feedPosts.length > 0 && (
        <div class="blog-feed-block">
          <div class="blog-eyebrow-row">
            <h2 class="blog-section-heading">{i18n.blog.allPosts}</h2>
            <span class="blog-eyebrow-links">
              <a class="blog-eyebrow-link blog-link-series" href={getLocalePath(locale, '/blog/series/')}>{i18n.blog.browseBySeries} <span aria-hidden="true">&rarr;</span></a>
              <a class="blog-eyebrow-link blog-link-tags" href={tagsPath}>{i18n.blog.browseByTag} <span aria-hidden="true">&rarr;</span></a>
            </span>
          </div>
          <div class="blog-feed" data-feed>
            {feedPosts.map(post => (
              <a
                href={post.enFallback ? `/blog/${getPostSlug(post.id)}/` : getLocalePath(locale, `/blog/${getPostSlug(post.id)}/`)}
                class="feed-post"
                data-publish-date={toDateString(post.data.publishDate)}
                hreflang={post.enFallback ? 'en' : undefined}
              >
                {post.data.heroImage && (
                  <div class="feed-post-thumb">
                    <img src={post.data.heroImage} alt={post.data.heroAlt || post.data.title} loading="lazy" />
                  </div>
                )}
                <div class="feed-post-body">
                  <div class="feed-post-meta blog-mono">
                    <span>{formatBlogDate(post.data.publishDate, locale)} &middot; {getReadingTime(post.body ?? '')} {i18n.blog.minRead}</span>
                    {post.data.series && <span class="feed-post-series">{shortenSeriesName(post.data.series)}</span>}
                    {post.enFallback && <span class="feed-post-lang">{i18n.blog.inEnglish}</span>}
                  </div>
                  <h3 class="feed-post-title" lang={post.enFallback ? 'en' : undefined}>{post.data.title}</h3>
                  {post.data.description && <p class="feed-post-desc" lang={post.enFallback ? 'en' : undefined}>{post.data.description}</p>}
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      {page.url.next && (
        <a
          class="blog-load-more"
          href={page.url.next}
          data-load-more
          data-loading-label={i18n.blog.loading}
        >{i18n.blog.loadMore}</a>
      )}

      {page.lastPage > 1 && (
        <nav class="blog-pagination" aria-label={i18n.a11y.blogPagination}>
          {page.url.prev ? (
            <a href={page.url.prev} class="blog-pagination-link blog-pagination-prev">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
              </svg>
              {i18n.blog.previous}
            </a>
          ) : <span />}

          <div class="blog-pagination-pages">
            {Array.from({ length: page.lastPage }, (_, i) => i + 1).map(num => (
              <a
                href={num === 1 ? blogBase : `${blogBase}${num}/`}
                class:list={['blog-pagination-num', { 'blog-pagination-current': num === page.currentPage }]}
                aria-current={num === page.currentPage ? 'page' : undefined}
              >
                {num}
              </a>
            ))}
          </div>

          {page.url.next ? (
            <a href={page.url.next} class="blog-pagination-link blog-pagination-next">
              {i18n.blog.next}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          ) : <span />}
        </nav>
      )}

      <p id="blog-empty" class="blog-empty" style="display: none;" data-is-dev={import.meta.env.DEV ? 'true' : undefined}>{i18n.blog.noPostsYet}</p>

      <!-- Mobile/tablet: subscribe card at the end of the feed (design
           "Blog Home Mobile"); the desktop sidebar carries its own copy. -->
      <div class="blog-subscribe-inline">
        <SubscribeForm locale={locale} variant="inline" />
      </div>
      </div>

      <!-- Desktop sidebar: newsletter card + top tags (design: sticky 300px). -->
      <aside class="blog-sidebar">
        <SubscribeForm locale={locale} />
        <div class="blog-sidebar-tags">
          <span class="blog-sidebar-tags-head">{i18n.blog.browseByTag}</span>
          <div class="blog-sidebar-tags-cloud">
            {topTags.map(tag => (
              <a class="post-tag" href={getLocalePath(locale, `/blog/tags/${tag}/`)}>{getTagLabel(tag, locale)}</a>
            ))}
          </div>
          <a class="blog-eyebrow-link" href={tagsPath}>{i18n.blog.browseByTag} <span aria-hidden="true">&rarr;</span></a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<script is:inline>
(function () {
  var emptyMsg = document.getElementById('blog-empty');
  var isDev = emptyMsg && emptyMsg.hasAttribute('data-is-dev');
  if (isDev) return;

  var now = new Date();
  var todayStr = now.getFullYear() + '-' +
    String(now.getMonth() + 1).padStart(2, '0') + '-' +
    String(now.getDate()).padStart(2, '0');
  var items = document.querySelectorAll('.feed-post[data-publish-date]');
  var visibleCount = 0;
  items.forEach(function (item) {
    if (item.getAttribute('data-publish-date') > todayStr) {
      item.style.display = 'none';
    } else {
      visibleCount++;
    }
  });
  document.querySelectorAll('.series-parts li[data-publish-date]').forEach(function (li) {
    if (li.getAttribute('data-publish-date') > todayStr) li.style.display = 'none';
  });
  if (emptyMsg) emptyMsg.style.display = visibleCount === 0 ? 'block' : 'none';
})();
</script>

<script is:inline>
(function () {
  function init() {
    document.querySelectorAll('.series-shelf-block').forEach(function (block) {
      var shelf = block.querySelector('.series-shelf');
      var nav = block.querySelector('.series-shelf-nav');
      var prev = block.querySelector('[data-dir="prev"]');
      var next = block.querySelector('[data-dir="next"]');
      if (!shelf || !nav || !prev || !next) return;

      function step() {
        var card = shelf.querySelector('.series-card');
        return card ? card.getBoundingClientRect().width + 22 : 340;
      }
      function update() {
        var max = shelf.scrollWidth - shelf.clientWidth;
        nav.hidden = max <= 4;
        prev.disabled = shelf.scrollLeft <= 2;
        next.disabled = shelf.scrollLeft >= max - 2;
      }

      prev.addEventListener('click', function () { shelf.scrollBy({ left: -step(), behavior: 'smooth' }); });
      next.addEventListener('click', function () { shelf.scrollBy({ left: step(), behavior: 'smooth' }); });
      shelf.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
      update();
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

<script is:inline>
/* "Load more posts": fetches the next paginated page (real /blog/N/ route),
   appends its feed cards, and re-points the button at the page after that.
   The link itself is a plain <a href> to the next page, so crawlers and
   no-JS visitors keep working pagination. */
(function () {
  var btn = document.querySelector('[data-load-more]');
  var feed = document.querySelector('[data-feed]');
  if (!btn || !feed) return;

  var label = btn.textContent;
  var busy = false;

  btn.addEventListener('click', function (e) {
    e.preventDefault();
    if (busy) return;
    busy = true;
    btn.textContent = btn.getAttribute('data-loading-label') || label;
    btn.setAttribute('aria-busy', 'true');

    fetch(btn.href)
      .then(function (r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.text();
      })
      .then(function (html) {
        var doc = new DOMParser().parseFromString(html, 'text/html');
        var posts = doc.querySelectorAll('[data-feed] .feed-post');
        posts.forEach(function (p) { feed.appendChild(p); });
        t('blog_load_more', { page: btn.href });
        var nextBtn = doc.querySelector('[data-load-more]');
        if (nextBtn) {
          btn.href = nextBtn.getAttribute('href');
          btn.textContent = label;
          btn.removeAttribute('aria-busy');
          busy = false;
        } else {
          btn.remove();
        }
      })
      .catch(function () {
        // Fetch failed: fall back to plain navigation to the next page.
        window.location.href = btn.href;
      });
  });
})();
</script>

<style is:global>

  .blog-section-heading {
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.2;
    color: var(--text-primary);
    margin: 0 0 1.5rem;
  }

  /* Current series hero — the card itself lives in SeriesHeroCard.astro */
  .series-hero { margin-bottom: 3.6rem; }

  /* More series — manual scroll carousel with arrow controls */
  .series-shelf-block { margin-bottom: 3.6rem; }

  .series-shelf-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .series-shelf-head .blog-section-heading { margin-bottom: 0; }
  .series-shelf-nav { display: flex; gap: 0.6rem; flex: none; }
  .series-shelf-nav[hidden] { display: none; }

  .series-shelf-arrow {
    width: 42px;
    height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--border-color);
    background: var(--bg-card);
    color: var(--text-secondary);
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease, opacity 0.2s ease;
  }

  .series-shelf-arrow:hover:not(:disabled) { border-color: var(--color-green); color: var(--color-green-text); }
  .series-shelf-arrow:disabled { opacity: 0.35; cursor: default; }

  .series-shelf {
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    padding: 0.5rem 0;
  }

  .series-shelf::-webkit-scrollbar { display: none; }
  .series-shelf-track { display: flex; gap: 1.4rem; width: max-content; }

  .series-card {
    width: 320px;
    flex: none;
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .series-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-hover); }
  .series-card-art { aspect-ratio: 21 / 9; overflow: hidden; background: var(--bg-secondary); }
  .series-card-art img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .series-card-body { padding: 1.1rem 1.3rem 1.3rem; }
  .series-card-kicker { font-size: 0.9rem; letter-spacing: 0.05em; text-transform: uppercase; color: var(--color-green-text); }
  .series-card-title { font-size: 1.18rem; font-weight: 700; letter-spacing: -0.02em; margin: 0.4rem 0 0.5rem; color: var(--text-primary); transition: color 0.15s ease; }
  .series-card:hover .series-card-title { color: var(--color-green-text); }
  .series-card-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* All posts feed-card styles are shared in global.css */
  .blog-empty { text-align: center; color: var(--text-muted); font-size: 1rem; margin-top: 2rem; }

  /* Pagination */
  .blog-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
  }

  .blog-pagination-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-decoration: none;
    border: 1px solid var(--border-color);
    background: var(--bg-card);
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .blog-pagination-link:hover { border-color: var(--color-green); color: var(--color-green-text); }
  .blog-pagination-pages { display: flex; align-items: center; gap: 0.25rem; }

  .blog-pagination-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-decoration: none;
    border: 1px solid transparent;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }

  .blog-pagination-num:hover { border-color: var(--border-color); background: var(--bg-secondary); }
  .blog-pagination-current { background: var(--color-green); color: white; border-color: var(--color-green); }
  .blog-pagination-current:hover { background: var(--color-green-dark); border-color: var(--color-green-dark); color: white; }

  /* ===== Redesign: page head, eyebrow rows, load-more, sidebar ===== */
  .blog-title { font-size: var(--fs-h1); font-weight: 800; letter-spacing: -0.02em; margin-bottom: 1rem; }

  .blog-eyebrow-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .blog-eyebrow-row .blog-section-heading { margin-bottom: 0; }
  .blog-eyebrow-links { display: inline-flex; gap: 1.1rem; }
  .blog-eyebrow-link {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-green-text);
    white-space: nowrap;
    text-decoration: none;
  }

  .blog-load-more {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    margin-top: 14px;
    border: 1px solid var(--border-color);
    border-radius: 24px;
    background: var(--bg-card);
    color: var(--text-primary);
    font-size: 0.85rem;
    font-weight: 700;
    text-decoration: none;
    transition: border-color 0.2s ease;
  }
  .blog-load-more:hover { border-color: var(--color-green); }
  .blog-load-more[aria-busy="true"] { opacity: 0.6; }

  /* Sidebar: single column by default; design's sticky 300px aside ≥1024. */
  .blog-sidebar { display: none; }

  /* End-of-feed subscribe card (design mobile artboard): left-aligned,
     stacked inputs, full-width button. Hidden ≥1024 where the sidebar
     carries the form. */
  .blog-subscribe-inline .subscribe {
    margin: 24px 0 8px;
    padding: 0;
    background: none;
    border: none;
  }
  .blog-subscribe-inline .subscribe .container {
    max-width: none;
    padding: 20px 18px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 16px;
  }
  .blog-subscribe-inline .subscribe-main { max-width: none; text-align: left; }
  .blog-subscribe-inline .subscribe-copy h3 { font-size: 15.5px; }
  .blog-subscribe-inline .subscribe-copy p { font-size: 12.5px; line-height: 1.5; margin-bottom: 0.75rem; }
  .blog-subscribe-inline .subscribe-form { max-width: none; }
  .blog-subscribe-inline .subscribe-row { flex-direction: column; }
  .blog-subscribe-inline .subscribe-btn { width: 100%; }
  .blog-subscribe-inline .subscribe-note { font-size: 0.72rem; }

  @media (min-width: 1024px) {
    .blog-subscribe-inline { display: none; }
  }

  @media (min-width: 1024px) {
    .blog-load-more { display: none; }

    .blog-feed-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 300px;
      gap: 36px;
      align-items: start;
    }

    .blog-sidebar {
      display: flex;
      flex-direction: column;
      gap: 20px;
      position: sticky;
      top: 84px;
    }

    /* Compact the full-width subscribe band into a sidebar card. */
    .blog-sidebar .subscribe { padding: 0; margin: 0; background: none; }
    .blog-sidebar .subscribe .container { padding: 22px; background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 14px; }
    .blog-sidebar .subscribe-form { flex-direction: column; align-items: stretch; }
    .blog-sidebar .subscribe-row { flex-direction: column; }
    .blog-sidebar .subscribe-btn { width: 100%; }

    .blog-sidebar-tags {
      padding: 22px;
      border: 1px solid var(--border-color);
      border-radius: 14px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .blog-sidebar-tags-head {
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-muted);
    }
    .blog-sidebar-tags-cloud { display: flex; gap: 6px; flex-wrap: wrap; }
  }

  @media (max-width: 1023px) {
    .blog-pagination { display: none; }
    .blog-link-series { display: none; }
  }

  @media (min-width: 1024px) {
    .blog-link-tags { display: none; }
  }

  /* Tablet: the lead post spans both feed columns as a 300px|text card
     (design "Blog Home Tablet"). */
  @media (min-width: 700px) and (max-width: 1023px) {
    [data-feed] .feed-post:first-child {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: 300px 1fr;
      padding: 0;
