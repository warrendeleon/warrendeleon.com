---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogSearch from './BlogSearch.astro';
import Breadcrumb from '../Breadcrumb.astro';
import { t, getLocalePath } from '../../i18n/index';
import type { Locale } from '../../i18n/index';
import { getPostsForLocale } from '../../utils/blogHelpers';
import { getTagLabel } from '../../i18n/tagLabels';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);
const blogPath = getLocalePath(locale, '/blog/');

// Every tag with its published-post count. A dedicated page has room for the
// full list, so there is no cap. Highest-traffic tags lead (count, then name),
// so the useful entry points aren't buried in an alphabetical wall.
const posts = await getPostsForLocale(locale);
const tagCounts = new Map<string, number>();
for (const p of posts) {
  for (const tag of p.data.tags ?? []) tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
}
const tags = [...tagCounts.entries()]
  .map(([tag, count]) => ({ tag, count, label: getTagLabel(tag, locale) }))
  .sort((a, b) => b.count - a.count || a.label.localeCompare(b.label));
---

<BaseLayout
  title={`${i18n.blog.browseByTag} | Warren de Leon`}
  description={i18n.seo.blogDescription}
  locale={locale}
  currentPath={getLocalePath(locale, '/blog/tags/')}
  mobileBack={{ href: blogPath, title: i18n.blog.browseByTag, eyebrow: 'Blog' }}
>
  <BlogSearch locale={locale} />

  <section class="section">
    <div class="container">
      <div class="tag-page-header">
        <Breadcrumb
          label={i18n.a11y.breadcrumb}
          items={[{ label: i18n.nav.blog, href: blogPath }]}
        />
        <h1 class="section-title">{i18n.blog.browseByTag}</h1>
        <p class="tags-subtitle">{i18n.blog.tagsSubtitle.replace('{t}', String(tags.length)).replace('{p}', String(posts.length))}</p>
      </div>

      <ul class="tag-cloud">
        {tags.map(({ tag, label, count }) => (
          <li>
            <a class="tag-cloud-item" href={getLocalePath(locale, `/blog/tags/${tag}/`)}>
              <span class="tag-cloud-label">{label}</span>
              <span class="tag-cloud-count">{count}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .tag-page-header { margin-bottom: 2rem; }


  .tags-subtitle { margin-top: 0.75rem; font-size: 0.85rem; line-height: 1.6; color: var(--text-secondary); }

  .tag-cloud { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 8px; }
  .tag-cloud-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 44px;
    padding: 0 14px;
    border-radius: 22px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .tag-cloud-item:hover { color: var(--color-green-text); border-color: var(--color-green); }
  .tag-cloud-label {
    font-size: 0.85rem;
    font-weight: 600;
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', ui-monospace, monospace;
  }
  .tag-cloud-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    padding: 0 6px;
    border-radius: 11px;
    background: rgba(109, 196, 2, 0.14);
    color: var(--color-green-text);
    font-size: 0.72rem;
    font-weight: 700;
  }
</style>
