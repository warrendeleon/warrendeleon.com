---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogSearch from './BlogSearch.astro';
import SubscribeForm from '../SubscribeForm.astro';
import { t, getLocalePath } from '../../i18n/index';
import type { Locale } from '../../i18n/index';
import { getReadingTime } from '../../utils/readingTime';
import { getPostSlug, formatBlogDate, toDateString, getSeriesSlug, getPostsForLocale, publishSlot } from '../../utils/blogHelpers';
import { getSeriesDescription, getSeriesRepo } from '../../i18n/seriesDescriptions';
import { getSeriesPlan } from '../../data/seriesPlans';
import BreadcrumbsJsonLd from '../BreadcrumbsJsonLd.astro';
import Breadcrumb from '../Breadcrumb.astro';

interface Props {
  locale: Locale;
  posts: any[];
  seriesName: string;
}

const { locale, posts, seriesName } = Astro.props;
const i18n = t(locale);
const blogPath = getLocalePath(locale, '/blog/');

// The hub's own URL. Without this the page inherited currentPath=/blog/, which set
// its canonical and hreflang to the blog index, telling search engines the series
// page was a duplicate. That alone kept it from ranking. Drive them off the real URL.
const siteUrl = 'https://warrendeleon.com';
const seriesPath = getLocalePath(locale, `/blog/series/${getSeriesSlug(seriesName)}/`);

// Series lede + meta description: prefer a curated, per-series description (already
// translated into every locale), falling back to the intro post's description and
// then a generic label. Keeps the lede keyword-rich without leaving anything stale.
const lede = getSeriesDescription(seriesName, locale) || posts[0]?.data.description || `${i18n.blog.seriesLabel}: ${seriesName}`;

// Momentum signals: total reading time, whether more parts are scheduled (and
// when the next lands), and a start-here CTA for first-time visitors.
const totalMinutes = posts.reduce((sum: number, p: any) => sum + getReadingTime(p.body ?? ''), 0);
const cutoff = new Date();
cutoff.setUTCHours(23, 59, 59, 999);
const scheduled = (await getPostsForLocale(locale, true))
  .filter(p => p.data.series === seriesName && p.data.publishDate > cutoff)
  .sort((a, b) => a.data.publishDate.valueOf() - b.data.publishDate.valueOf());
const nextPartDate = scheduled[0]?.data.publishDate ?? null;

// Design: the parts timeline shows planned parts too — dimmed, unlinked,
// "Planned · date". Titles and dates of scheduled posts are already public
// in the repo; descriptions stay off for unpublished parts.
//
// Published is decided by DATE (publishSlot), never by which helper bucket a
// post arrived in: in dev, getPostsForLocale includes future posts, and a
// bucket-based split rendered everything as published in the preview.
const seenIds = new Set<string>();
const union = [...posts, ...scheduled].filter((p: any) => {
  if (seenIds.has(p.id)) return false;
  seenIds.add(p.id);
  return true;
}).sort((a: any, b: any) => a.data.publishDate.valueOf() - b.data.publishDate.valueOf());

const nowTs = new Date();

// Normalise real posts and planned-but-unwritten parts (data/seriesPlans.ts,
// from the content strategy) into one timeline. Published is decided by
// date; planned entries have no file yet, so no link and no description.
interface TimelinePart {
  title: string;
  date: Date;
  published: boolean;
  slug?: string;
  desc?: string;
  minutes?: number;
}

const normalise = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim().slice(0, 32);
const realTitleKeys = new Set(union.map((p: any) => normalise(p.data.title)));

const fromPosts: TimelinePart[] = union.map((p: any) => ({
  title: p.data.title,
  date: p.data.publishDate,
  published: publishSlot(p.data.publishDate) <= nowTs,
  slug: getPostSlug(p.id),
  desc: p.data.description,
  minutes: getReadingTime(p.body ?? ''),
}));

// Safety net: a planned entry whose title now matches a real post is stale.
const fromPlan: TimelinePart[] = getSeriesPlan(seriesName)
  .filter(pl => !realTitleKeys.has(normalise(pl.title)))
  .map(pl => ({ title: pl.title, date: new Date(pl.date), published: false }));

const allParts: TimelinePart[] = [...fromPosts, ...fromPlan].sort((a, b) => a.date.valueOf() - b.date.valueOf());
const publishedCount = allParts.filter(p => p.published).length;
const totalParts = allParts.length;
const progressPct = totalParts > 0 ? Math.round((publishedCount / totalParts) * 100) : 0;
const firstPart = union.find((p: any) => publishSlot(p.data.publishDate) <= nowTs) ?? null;
const publishedParts = union.filter((p: any) => publishSlot(p.data.publishDate) <= nowTs);
const nextPlannedDate = allParts.find(p => !p.published)?.date ?? null;
const heroImage = firstPart?.data.heroImage;
const heroAlt = firstPart?.data.heroAlt || seriesName;
const repoUrl = getSeriesRepo(seriesName);

// ItemList structured data: tells search engines this is an ordered, multi-part guide
// and makes the parts eligible for a list/carousel rich result.
const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: seriesName,
  description: lede,
  numberOfItems: publishedParts.length,
  itemListElement: publishedParts.map((post, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${siteUrl}${getLocalePath(locale, `/blog/${getPostSlug(post.id)}/`)}`,
    name: post.data.title,
  })),
};
---

<BaseLayout
  title={`${seriesName} | Warren de Leon`}
  description={lede}
  locale={locale}
  currentPath={seriesPath}
  jsonLd={itemListJsonLd}
  mobileBack={{ href: blogPath, title: seriesName, eyebrow: i18n.blog.seriesLabel }}
>
  <BlogSearch locale={locale} />
  <BreadcrumbsJsonLd items={[
    { name: 'Warren de Leon', url: getLocalePath(locale, '/') },
    { name: 'Blog', url: blogPath },
    { name: i18n.blog.browseBySeries, url: getLocalePath(locale, '/blog/series/') },
    { name: seriesName },
  ]} />

  {heroImage && (
    <div class="series-page-hero">
      <img src={heroImage} alt={heroAlt} />
    </div>
  )}

  <section class="section series-page-section">
    <div class="container">
      <div class="series-head-grid">
      {heroImage && (
        <div class="series-page-hero-inline">
          <img src={heroImage} alt="" loading="lazy" aria-hidden="true" />
        </div>
      )}
      <div class="tag-page-header">
        <Breadcrumb
          label={i18n.a11y.breadcrumb}
          items={[
            { label: i18n.nav.blog, href: blogPath },
            { label: i18n.blog.seriesCrumb, href: getLocalePath(locale, '/blog/series/') },
          ]}
        />
        <p class="series-page-eyebrow blog-mono">{i18n.blog.seriesLabel} &middot; {totalParts} {i18n.blog.parts} &middot; {nextPlannedDate ? i18n.blog.inProgress : i18n.blog.seriesComplete}</p>
        <h1 class="section-heading">{seriesName}</h1>
        <p class="series-page-lede">{lede}</p>

        <div class="series-progress">
          <div class="series-progress-labels blog-mono">
            <span>{i18n.blog.publishedOfTotal.replace('{x}', String(publishedCount)).replace('{y}', String(totalParts))}</span>
            {nextPlannedDate && <span>{i18n.blog.nextPart} &middot; {formatBlogDate(nextPlannedDate, locale)}</span>}
          </div>
          <div class="series-progress-track" role="progressbar" aria-valuenow={progressPct} aria-valuemin="0" aria-valuemax="100" aria-label={i18n.blog.publishedOfTotal.replace('{x}', String(publishedCount)).replace('{y}', String(totalParts))}>
            <div class="series-progress-fill" style={`width: ${progressPct}%`}></div>
          </div>
        </div>

        {firstPart && (
          <a href={getLocalePath(locale, `/blog/${getPostSlug(firstPart.id)}/`)} class="series-start-btn">
            {i18n.blog.startSeries} <span aria-hidden="true">&rarr;</span>
          </a>
        )}
      </div>
      </div>

      <div class="series-body-grid">
      <ol class="series-timeline">
        {allParts.map((part, i) => (
          <li class:list={['series-timeline-item', { 'is-upcoming': !part.published }]}>
            <span class="series-timeline-dot blog-mono" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            {part.published && part.slug ? (
              <a
                href={getLocalePath(locale, `/blog/${part.slug}/`)}
                class="series-timeline-card"
                data-publish-date={toDateString(part.date)}
              >
                <span class="series-timeline-title">{part.title}</span>
                {part.desc && <span class="series-timeline-desc">{part.desc}</span>}
                <span class="series-timeline-meta blog-mono">{formatBlogDate(part.date, locale)} &middot; {part.minutes} {i18n.blog.minRead}</span>
              </a>
            ) : (
              <span class="series-timeline-card">
                <span class="series-timeline-title">{part.title}</span>
                <span class="series-timeline-meta blog-mono">{i18n.blog.planned} &middot; {formatBlogDate(part.date, locale)}</span>
              </span>
            )}
          </li>
        ))}
      </ol>

      <!-- Sticky sidebar (≥1024px, design): newsletter + companion code. -->
      <aside class="series-sidebar">
        <SubscribeForm locale={locale} />
        {repoUrl && (
          <div class="series-repo-card">
            <span class="series-repo-head">{i18n.blog.companionCode}</span>
            <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="blog-eyebrow-link">
              {repoUrl.replace('https://', '')} <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
        )}
      </aside>
      </div>

      <p id="blog-empty" class="blog-empty" style="display: none;" data-is-dev={import.meta.env.DEV ? 'true' : undefined}>{i18n.blog.noPostsYet}</p>
    </div>
  </section>

</BaseLayout>

<script is:inline>
  (function () {
    if (document.querySelector('#blog-empty[data-is-dev]')) return;
    var now = new Date();
    var todayStr = now.getFullYear() + '-' +
      String(now.getMonth() + 1).padStart(2, '0') + '-' +
      String(now.getDate()).padStart(2, '0');
    /* A published-looking card with a future date means the static build
       predates its slot. The design keeps planned parts VISIBLE — downgrade
       the card to the upcoming style and disable the link, never hide it. */
    var items = document.querySelectorAll('.series-timeline-card[data-publish-date]');
    var visibleCount = 0;
    items.forEach(function (item) {
      if (item.getAttribute('data-publish-date') > todayStr) {
        item.closest('.series-timeline-item').classList.add('is-upcoming');
        item.removeAttribute('href');
        item.setAttribute('aria-disabled', 'true');
      } else {
        visibleCount++;
      }
    });
    var emptyMsg = document.getElementById('blog-empty');
    if (emptyMsg) emptyMsg.style.display = visibleCount === 0 ? 'block' : 'none';
  })();
</script>

<style is:global>
  .tag-page-header { margin-bottom: 2rem; }

  .tag-page-count { font-size: 1rem; color: var(--text-muted); margin-top: 0.75rem; }

  /* Detail-page title (design): 26px mobile, 30px from tablet up. */
  .tag-page-header .section-heading { font-size: 30px; }
  @media (max-width: 699px) {
    .tag-page-header .section-heading { font-size: 26px; }
  }
  .series-page-eyebrow { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--color-green-text); margin-bottom: 0.4rem; }
  .series-page-lede { font-size: 1.05rem; line-height: 1.6; color: var(--text-secondary); margin-top: 0.75rem; }

  /* Hero image band (design: 210px mobile, contained on desktop) */
  .series-page-hero { height: 210px; overflow: hidden; background: var(--bg-secondary); }
  .series-page-hero img { width: 100%; height: 100%; object-fit: cover; display: block; }
  @media (min-width: 1024px) {
    .series-page-hero { height: 320px; }
    .series-page-hero img { max-width: 1100px; margin: 0 auto; }
  }
  .series-page-section { padding-top: 1.5rem; }

  /* Publication progress */
  .series-progress { display: flex; flex-direction: column; gap: 6px; margin-top: 1rem; max-width: 640px; }
  .series-progress-labels { display: flex; justify-content: space-between; gap: 1rem; font-size: 0.74rem; font-weight: 600; color: var(--text-muted); }
  .series-progress-track { height: 6px; border-radius: 3px; background: var(--badge-bg); overflow: hidden; }
  .series-progress-fill { height: 100%; border-radius: 3px; background: var(--color-green); }

  /* Start CTA: solid green pill per design */
  .series-start-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 48px;
    padding: 0 24px;
    margin-top: 1.1rem;
    border-radius: 24px;
    background: var(--color-green);
    color: #fff;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .series-start-btn:hover { background: var(--color-green-dark); color: #fff; }
  @media (max-width: 699px) {
    .series-start-btn { display: flex; width: 100%; }
  }

  /* Parts timeline: numbered dots on a vertical rail */
  .series-timeline { list-style: none; margin: 0; padding: 8px 0; position: relative; display: flex; flex-direction: column; gap: 10px; }
  .series-timeline::before { content: ''; position: absolute; left: 13px; top: 8px; bottom: 8px; width: 2px; background: var(--border-color); }
  .series-timeline-item { position: relative; padding-left: 38px; }
  .series-timeline-dot {
    position: absolute;
    left: 0;
    top: 14px;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--bg-primary);
    border: 2px solid var(--color-green);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    font-size: 0.62rem;
    font-weight: 800;
    color: var(--color-green-text);
  }
  .series-timeline-card {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 12px 14px;
    border: 1px solid var(--border-color);
    border-radius: 14px;
    background: var(--bg-card);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.2s ease;
  }
  a.series-timeline-card:hover { border-color: var(--color-green); }
  .series-timeline-title { font-size: 0.85rem; font-weight: 700; line-height: 1.35; color: var(--text-primary); }
  .series-timeline-desc {
    font-size: 0.76rem;
    line-height: 1.5;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .series-timeline-meta { font-size: 0.66rem; color: var(--text-muted); margin-top: 2px; }

  .series-timeline-item.is-upcoming { opacity: 0.55; }
  .series-timeline-item.is-upcoming .series-timeline-dot { border-color: var(--border-color); color: var(--text-muted); }

  @media (min-width: 1024px) {
    .series-timeline-title { font-size: 1rem; }
    .series-timeline-desc { font-size: 0.85rem; }
  }

  /* ≥700px (design tablet/desktop): hero image sits beside the header. */
  .series-page-hero-inline { display: none; }

  @media (min-width: 700px) {
    .series-page-hero { display: none; }
    .series-page-section { padding-top: 3rem; }

    .series-head-grid {
      display: grid;
      grid-template-columns: 380px minmax(0, 1fr);
      gap: 36px;
      align-items: center;
      margin-bottom: 1.5rem;
    }

    .series-page-hero-inline {
      display: block;
      aspect-ratio: 4 / 3;
      border-radius: 16px;
      overflow: hidden;
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
    }
    .series-page-hero-inline img { width: 100%; height: 100%; object-fit: cover; display: block; }

    .series-head-grid .tag-page-header { margin-bottom: 0; }
    .series-start-btn { display: inline-flex; width: auto; }
  }

  /* Parts + sticky sidebar (design): newsletter + companion code. */
  .series-sidebar { display: flex; flex-direction: column; gap: 20px; margin-top: 2rem; }

  .series-repo-card {
    padding: 22px;
    border: 1px solid var(--border-color);
    border-radius: 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .series-repo-head {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  @media (min-width: 1024px) {
    .series-body-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 280px;
      gap: 36px;
      align-items: start;
    }

    .series-sidebar {
      position: sticky;
      top: 84px;
      margin-top: 8px;
    }

    /* Compact the subscribe band into a sidebar card (same as blog home).
       The form's root class is .subscribe, not .subscribe-section — the old
       selector matched nothing, so the band never compacted here. */
    .series-sidebar .subscribe { padding: 0; margin: 0; background: none; }
    .series-sidebar .subscribe .container { padding: 22px; background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 14px; }
    .series-sidebar .subscribe-form { flex-direction: column; align-items: stretch; }
    .series-sidebar .subscribe-row { flex-direction: column; }
    .series-sidebar .subscribe-btn { width: 100%; }
  }

  .blog-empty { text-align: center; color: var(--text-muted); font-size: 1rem; margin-top: 2rem; }
</style>
