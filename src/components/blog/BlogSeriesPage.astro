---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogSearch from './BlogSearch.astro';
import SubscribeForm from '../SubscribeForm.astro';
import { t, getLocalePath } from '../../i18n/index';
import type { Locale } from '../../i18n/index';
import { getTagLabel } from '../../i18n/tagLabels';
import { getReadingTime } from '../../utils/readingTime';
import { getPostSlug, formatBlogDate, toDateString, getSeriesSlug, getPostsForLocale } from '../../utils/blogHelpers';
import { getSeriesDescription } from '../../i18n/seriesDescriptions';
import BreadcrumbsJsonLd from '../BreadcrumbsJsonLd.astro';

interface Props {
  locale: Locale;
  posts: any[];
  seriesName: string;
}

const { locale, posts, seriesName } = Astro.props;
const i18n = t(locale);
const blogPath = getLocalePath(locale, '/blog/');

// The hub's own URL. Without this the page inherited currentPath=/blog/, which set
// its canonical and hreflang to the blog index, telling search engines the series
// page was a duplicate. That alone kept it from ranking. Drive them off the real URL.
const siteUrl = 'https://warrendeleon.com';
const seriesPath = getLocalePath(locale, `/blog/series/${getSeriesSlug(seriesName)}/`);

// Series lede + meta description: prefer a curated, per-series description (already
// translated into every locale), falling back to the intro post's description and
// then a generic label. Keeps the lede keyword-rich without leaving anything stale.
const lede = getSeriesDescription(seriesName, locale) || posts[0]?.data.description || `${i18n.blog.seriesLabel}: ${seriesName}`;

// Momentum signals: total reading time, whether more parts are scheduled (and
// when the next lands), and a start-here CTA for first-time visitors.
const totalMinutes = posts.reduce((sum: number, p: any) => sum + getReadingTime(p.body ?? ''), 0);
const cutoff = new Date();
cutoff.setUTCHours(23, 59, 59, 999);
const scheduled = (await getPostsForLocale(locale, true))
  .filter(p => p.data.series === seriesName && p.data.publishDate > cutoff)
  .sort((a, b) => a.data.publishDate.valueOf() - b.data.publishDate.valueOf());
const nextPartDate = scheduled[0]?.data.publishDate ?? null;
const firstPart = posts[0];

// ItemList structured data: tells search engines this is an ordered, multi-part guide
// and makes the parts eligible for a list/carousel rich result.
const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: seriesName,
  description: lede,
  numberOfItems: posts.length,
  itemListElement: posts.map((post, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${siteUrl}${getLocalePath(locale, `/blog/${getPostSlug(post.id)}/`)}`,
    name: post.data.title,
  })),
};
---

<BaseLayout
  title={`${seriesName} | Warren de Leon`}
  description={lede}
  locale={locale}
  currentPath={seriesPath}
  jsonLd={itemListJsonLd}
>
  <BlogSearch locale={locale} />
  <BreadcrumbsJsonLd items={[
    { name: 'Warren de Leon', url: getLocalePath(locale, '/') },
    { name: 'Blog', url: blogPath },
    { name: i18n.blog.browseBySeries, url: getLocalePath(locale, '/blog/series/') },
    { name: seriesName },
  ]} />

  <section class="section">
    <div class="container">
      <div class="tag-page-header">
        <a href={blogPath} class="blog-back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          {i18n.blog.backToBlog}
        </a>
        <p class="series-page-eyebrow">{i18n.blog.seriesLabel}</p>
        <h1 class="section-heading">{seriesName}</h1>
        <p class="series-page-lede">{lede}</p>
        <p class="tag-page-count blog-mono">
          {posts.length} {posts.length === 1 ? i18n.blog.post : i18n.blog.posts}
          <span aria-hidden="true">&middot;</span>
          {totalMinutes} {i18n.blog.minRead}
          <span aria-hidden="true">&middot;</span>
          {nextPartDate
            ? i18n.blog.seriesOngoing.replace('{date}', formatBlogDate(nextPartDate, locale))
            : i18n.blog.seriesComplete}
        </p>
        {firstPart && (
          <a href={getLocalePath(locale, `/blog/${getPostSlug(firstPart.id)}/`)} class="btn btn-outline series-start-btn">
            {i18n.blog.startSeries} <span aria-hidden="true">&rarr;</span>
          </a>
        )}
      </div>

      <ol class="blog-feed series-page-feed">
        {posts.map((post, i) => (
          <li>
            <a
              href={getLocalePath(locale, `/blog/${getPostSlug(post.id)}/`)}
              class="feed-post"
              data-publish-date={toDateString(post.data.publishDate)}
            >
              {post.data.heroImage && (
                <div class="feed-post-thumb">
                  <img src={post.data.heroImage} alt={post.data.heroAlt || post.data.title} loading="lazy" />
                </div>
              )}
              <div class="feed-post-body">
                <div class="feed-post-meta blog-mono">
                  <span class="feed-post-part">{String(i + 1).padStart(2, '0')}</span>
                  <span>{formatBlogDate(post.data.publishDate, locale)} &middot; {getReadingTime(post.body ?? '')} {i18n.blog.minRead}</span>
                </div>
                <h2 class="feed-post-title">{post.data.title}</h2>
                {post.data.description && <p class="feed-post-desc">{post.data.description}</p>}
              </div>
            </a>
          </li>
        ))}
      </ol>

      <p id="blog-empty" class="blog-empty" style="display: none;">{i18n.blog.noPostsYet}</p>
    </div>
  </section>

  <SubscribeForm locale={locale} />
</BaseLayout>

<script is:inline>
  (function () {
    var now = new Date();
    var todayStr = now.getFullYear() + '-' +
      String(now.getMonth() + 1).padStart(2, '0') + '-' +
      String(now.getDate()).padStart(2, '0');
    var items = document.querySelectorAll('.feed-post[data-publish-date]');
    var visibleCount = 0;
    items.forEach(function (item) {
      if (item.getAttribute('data-publish-date') > todayStr) {
        item.parentElement.style.display = 'none';
      } else {
        visibleCount++;
      }
    });
    var emptyMsg = document.getElementById('blog-empty');
    if (emptyMsg) emptyMsg.style.display = visibleCount === 0 ? 'block' : 'none';
  })();
</script>

<style is:global>
  .tag-page-header { margin-bottom: 2rem; }
  .tag-page-header .blog-back-link { display: flex; width: fit-content; align-items: center; gap: 0.4rem; font-size: 0.9rem; font-weight: 500; color: var(--text-secondary); margin-bottom: 1.5rem; transition: color 0.2s ease, gap 0.2s ease; }
  .tag-page-header .blog-back-link:hover { color: var(--color-green-text); gap: 0.6rem; }
  .tag-page-count { font-size: 1rem; color: var(--text-muted); margin-top: 0.75rem; }
  .series-start-btn { margin-top: 1rem; }
  .series-page-eyebrow { font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-green-text); margin-bottom: 0.4rem; }
  .series-page-lede { font-size: 1.05rem; line-height: 1.6; color: var(--text-secondary); margin-top: 0.75rem; }

  /* Parts list reuses the shared .feed-post row card (global.css); reset the <ol> chrome */
  .series-page-feed { list-style: none; margin: 0; padding: 0; }

  .blog-empty { text-align: center; color: var(--text-muted); font-size: 1rem; margin-top: 2rem; }
</style>
