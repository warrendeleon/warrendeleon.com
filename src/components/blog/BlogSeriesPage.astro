---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogSearch from './BlogSearch.astro';
import { t, getLocalePath } from '../../i18n/index';
import type { Locale } from '../../i18n/index';
import { getTagLabel } from '../../i18n/tagLabels';
import { getReadingTime } from '../../utils/readingTime';
import { getPostSlug, formatBlogDate, toDateString, getSeriesSlug } from '../../utils/blogHelpers';

interface Props {
  locale: Locale;
  posts: any[];
  seriesName: string;
}

const { locale, posts, seriesName } = Astro.props;
const i18n = t(locale);
const blogPath = getLocalePath(locale, '/blog/');

// The hub's own URL. Without this the page inherited currentPath=/blog/, which set
// its canonical and hreflang to the blog index, telling search engines the series
// page was a duplicate. That alone kept it from ranking. Drive them off the real URL.
const siteUrl = 'https://warrendeleon.com';
const seriesPath = getLocalePath(locale, `/blog/series/${getSeriesSlug(seriesName)}/`);

// Reuse the first (intro) post's description as the series lede + meta description:
// it is already keyword-rich and already translated into every locale, so no new
// per-series copy is needed and nothing goes stale.
const lede = posts[0]?.data.description ?? `${i18n.blog.seriesLabel}: ${seriesName}`;

// ItemList structured data: tells search engines this is an ordered, multi-part guide
// and makes the parts eligible for a list/carousel rich result.
const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: seriesName,
  description: lede,
  numberOfItems: posts.length,
  itemListElement: posts.map((post, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${siteUrl}${getLocalePath(locale, `/blog/${getPostSlug(post.id)}/`)}`,
    name: post.data.title,
  })),
};
---

<BaseLayout
  title={`${seriesName} | Warren de Leon`}
  description={lede}
  locale={locale}
  currentPath={seriesPath}
  jsonLd={itemListJsonLd}
>
  <BlogSearch locale={locale} />

  <section class="section">
    <div class="container">
      <div class="tag-page-header">
        <a href={blogPath} class="blog-back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          {i18n.blog.backToBlog}
        </a>
        <p class="series-page-eyebrow">{i18n.blog.seriesLabel}</p>
        <h1 class="section-heading">{seriesName}</h1>
        <p class="series-page-lede">{lede}</p>
        <p class="tag-page-count">{posts.length} {posts.length === 1 ? i18n.blog.post : i18n.blog.posts}</p>
      </div>

      <ol class="series-page-list">
        {posts.map((post, i) => (
          <li>
            <a
              href={getLocalePath(locale, `/blog/${getPostSlug(post.id)}/`)}
              class="series-page-item"
              data-publish-date={toDateString(post.data.publishDate)}
            >
              <span class="series-page-num" aria-hidden="true">{i + 1}</span>
              <span class="series-page-body">
                <span class="series-page-item-meta">
                  {formatBlogDate(post.data.publishDate, locale)} &middot; {getReadingTime(post.body ?? '')} {i18n.blog.minRead}
                </span>
                <span class="series-page-item-title">{post.data.title}</span>
                <span class="series-page-item-desc">{post.data.description}</span>
              </span>
            </a>
          </li>
        ))}
      </ol>

      <p id="blog-empty" class="blog-empty" style="display: none;">{i18n.blog.noPostsYet}</p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    var now = new Date();
    var todayStr = now.getFullYear() + '-' +
      String(now.getMonth() + 1).padStart(2, '0') + '-' +
      String(now.getDate()).padStart(2, '0');
    var items = document.querySelectorAll('.series-page-item[data-publish-date]');
    var visibleCount = 0;
    items.forEach(function (item) {
      if (item.getAttribute('data-publish-date') > todayStr) {
        item.parentElement.style.display = 'none';
      } else {
        visibleCount++;
      }
    });
    var emptyMsg = document.getElementById('blog-empty');
    if (emptyMsg) emptyMsg.style.display = visibleCount === 0 ? 'block' : 'none';
  })();
</script>

<style is:global>
  .tag-page-header { margin-bottom: 2rem; }
  .tag-page-header .blog-back-link { display: flex; width: fit-content; align-items: center; gap: 0.4rem; font-size: 0.9rem; font-weight: 500; color: var(--text-secondary); margin-bottom: 1.5rem; transition: color 0.2s ease, gap 0.2s ease; }
  .tag-page-header .blog-back-link:hover { color: var(--color-green); gap: 0.6rem; }
  .tag-page-count { font-size: 0.9rem; color: var(--text-muted); margin-top: 0.5rem; }
  .series-page-eyebrow { font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-green); margin-bottom: 0.4rem; }
  .series-page-lede { font-size: 1.05rem; line-height: 1.6; color: var(--text-secondary); max-width: 60ch; margin-top: 0.75rem; }

  .series-page-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .series-page-item {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.25rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .series-page-item:hover { transform: translateY(-2px); box-shadow: var(--shadow-hover); }
  .series-page-item:hover .series-page-item-title { color: var(--color-green); }
  .series-page-num {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    color: var(--color-green);
    font-weight: 700;
    font-size: 0.95rem;
  }
  .series-page-body { display: flex; flex-direction: column; gap: 0.35rem; }
  .series-page-item-meta { font-size: 0.85rem; color: var(--text-muted); }
  .series-page-item-title { font-size: 1.2rem; font-weight: 700; color: var(--text-primary); line-height: 1.3; transition: color 0.2s ease; }
  .series-page-item-desc { color: var(--text-secondary); font-size: 0.98rem; line-height: 1.6; }
  .blog-empty { text-align: center; color: var(--text-muted); font-size: 1rem; margin-top: 2rem; }
</style>
