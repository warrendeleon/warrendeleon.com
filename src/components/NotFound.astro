---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t, getLocalePath, type Locale } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);

const links = [
  { label: i18n.nav.home, href: getLocalePath(locale, '/') },
  { label: i18n.nav.blog, href: getLocalePath(locale, '/blog/') },
  { label: i18n.nav.workExperience, href: getLocalePath(locale, '/work-experience/') },
];
---

<BaseLayout
  title={`${i18n.notFound.title} | Warren de Leon`}
  description={i18n.notFound.message}
  locale={locale}
  currentPath="/404"
>
  <section class="section">
    <div class="container text-center">
      <h1>404</h1>
      <p class="nf-message mt-2">{i18n.notFound.message}</p>
      <div class="nf-links mt-3">
        {links.map((l) => (
          <a href={l.href} class="btn btn-outline">{l.label}</a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf-message {
    font-size: 1.2rem;
    color: var(--text-secondary);
  }

  .nf-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>
