---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocalePath, type Locale } from '../../i18n/index';
import { getDesignData } from '../../lib/design-data';
import { DESIGN_GROUPS, DESIGN_ROOT, type DesignGroup } from '../../lib/design-ia';

interface Props {
  locale: Locale;
  currentPath: string;
  seoTitle: string;
  seoDescription: string;
  /** Which IA group this page belongs to; omitted on the landing hub. */
  group?: DesignGroup['key'];
  title: string;
  intro: string;
  /** In-page anchors for the "On this page" card. */
  toc?: { id: string; label: string }[];
}

const { locale, currentPath, seoTitle, seoDescription, group, title, intro, toc = [] } = Astro.props;
const d = getDesignData(locale);
const rootPath = getLocalePath(locale, DESIGN_ROOT);

// Localised nav model: each group with its built pages resolved to labels +
// hrefs. Drives both the desktop rail and the mobile section menu.
const nav = DESIGN_GROUPS.map((g) => ({
  key: g.key,
  label: d.groups[g.key],
  pages: g.pages
    .filter((p) => p.built)
    .map((p) => ({
      label: d.nav[p.slug as keyof typeof d.nav],
      href: getLocalePath(locale, p.path),
    })),
})).filter((g) => g.pages.length > 0);

const groupLabel = group ? d.groups[group] : null;
const issueSubject = encodeURIComponent(`Design system: ${title}`);
---

<BaseLayout title={seoTitle} description={seoDescription} locale={locale} currentPath={currentPath}>
  <section class="section">
    <div class="container">
      <div class="ds-shell">
        <aside class="ds-rail" aria-label={d.sectionsLabel}>
          <a href={rootPath} class:list={['ds-rail-home', { active: currentPath === rootPath }]}>{d.designLabel}</a>
          {nav.map((g) => (
            <div class="ds-rail-group">
              <p class="ds-rail-group-label">{g.label}</p>
              <ul>
                {g.pages.map((p) => (
                  <li>
                    <a
                      href={p.href}
                      class:list={['ds-rail-link', { active: currentPath === p.href }]}
                      aria-current={currentPath === p.href ? 'page' : undefined}
                    >
                      {p.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </aside>

        <div class="ds-content">
          <nav class="ds-breadcrumb" aria-label={d.breadcrumbLabel}>
            <a href={rootPath}>{d.designLabel}</a>
            {groupLabel && (
              <>
                <span class="ds-crumb-sep" aria-hidden="true">/</span>
                <span>{groupLabel}</span>
              </>
            )}
          </nav>

          <!-- Mobile/tablet section menu: the rail is desktop-only, so below
               1280px this collapsible carries the whole section's navigation.
               Same details/summary pattern as the article ToC. -->
          <nav class="ds-mobile-nav" aria-label={d.sectionsLabel}>
            <details class="ds-mnav">
              <summary>{d.designLabel} — {d.sectionsLabel}</summary>
              <div class="ds-mnav-body">
                {nav.map((g) => (
                  <div class="ds-mnav-group">
                    <p class="ds-mnav-label">{g.label}</p>
                    <div class="ds-mnav-links">
                      {g.pages.map((p) => (
                        <a
                          href={p.href}
                          class:list={['post-tag', { 'ds-mnav-active': currentPath === p.href }]}
                          aria-current={currentPath === p.href ? 'page' : undefined}
                        >
                          {p.label}
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </details>
          </nav>

          <header class="ds-header">
            <h1 class="section-title">{title}</h1>
            <p class="ds-intro">{intro}</p>
          </header>

          {toc.length > 0 && (
            <nav class="ds-toc" aria-label={d.onThisPage}>
              <p class="ds-toc-label">{d.onThisPage}</p>
              <ul>
                {toc.map((i) => (
                  <li><a href={`#${i.id}`}>{i.label}</a></li>
                ))}
              </ul>
            </nav>
          )}

          <div class="ds-body">
            <slot />
          </div>

          <footer class="ds-foot">
            <a href={`mailto:hi@warrendeleon.com?subject=${issueSubject}`}>{d.spottedIssue}</a>
          </footer>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* Two-column docs shell: sticky section rail + content. Below 1280px the
     rail is replaced by the ds-mobile-nav collapsible above the header. */
  .ds-shell {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .ds-rail {
    display: none;
  }

  @media (min-width: 1280px) {
    .ds-shell {
      grid-template-columns: 230px minmax(0, 1fr);
      gap: 3rem;
      align-items: start;
    }
    .ds-rail {
      display: block;
      position: sticky;
      top: 88px;
      max-height: calc(100vh - 108px);
      overflow-y: auto;
      padding-right: 0.5rem;
    }
    .ds-mobile-nav { display: none; }
  }

  .ds-rail-home {
    display: block;
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    padding-bottom: 1rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
  }
  .ds-rail-home:hover,
  .ds-rail-home.active { color: var(--color-green-text); }

  /* Each group reads as a clear section: bordered block label + indented links. */
  .ds-rail-group { margin-bottom: 1.5rem; }
  .ds-rail-group ul { list-style: none; margin: 0; padding: 0; }
  .ds-rail-group-label {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-primary);
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    margin: 0 0 0.6rem;
    padding: 0.3rem 0.6rem;
    background: var(--badge-bg);
    border-radius: 6px;
    display: inline-block;
  }
  .ds-rail-link {
    display: block;
    padding: 0.3rem 0 0.3rem 0.85rem;
    font-size: 0.88rem;
    color: var(--text-secondary);
    border-left: 2px solid var(--border-color);
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .ds-rail-link:hover { color: var(--text-primary); border-left-color: var(--text-muted); }
  .ds-rail-link.active {
    color: var(--color-green-text);
    font-weight: 700;
    border-left-color: var(--color-green);
  }

  /* Mobile section menu (same details pattern as the article ToC). */
  .ds-mobile-nav { margin-bottom: 1.25rem; }
  .ds-mnav {
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--bg-secondary);
    padding: 0.85rem 1rem;
  }
  .ds-mnav summary {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    cursor: pointer;
    list-style: none;
    min-height: 28px;
    display: flex;
    align-items: center;
  }
  .ds-mnav summary::-webkit-details-marker { display: none; }
  .ds-mnav summary::after { content: '▸'; margin-left: 0.4rem; font-size: 0.8em; }
  .ds-mnav[open] summary::after { content: '▾'; }
  .ds-mnav-body { padding-top: 0.75rem; display: flex; flex-direction: column; gap: 0.85rem; }
  .ds-mnav-label {
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-primary);
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    margin: 0 0 0.4rem;
  }
  .ds-mnav-links { display: flex; flex-wrap: wrap; gap: 6px; }
  .ds-mnav-links .ds-mnav-active {
    border-color: var(--color-green);
    color: var(--color-green-text);
    font-weight: 700;
  }

  .ds-content { max-width: 820px; min-width: 0; }

  .ds-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .ds-breadcrumb a { color: var(--text-muted); }
  .ds-breadcrumb a:hover { color: var(--color-green-text); }
  .ds-crumb-sep { opacity: 0.5; }

  .ds-header { margin-bottom: 2rem; }
  .ds-intro {
    font-size: 1.15rem;
    line-height: 1.55;
    color: var(--text-secondary);
    max-width: 60ch;
    margin: 0;
  }
  @media (max-width: 699px) {
    .ds-intro { font-size: 1.02rem; }
  }

  /* On this page */
  .ds-toc {
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--bg-secondary);
    padding: 1rem 1.25rem;
    margin-bottom: 2.5rem;
  }
  .ds-toc-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    margin: 0 0 0.6rem;
  }
  .ds-toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .ds-toc a {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  .ds-toc a:hover { color: var(--color-green-text); }

  /* Body typography — scoped to DIRECT children of a page section, so it can
     never restyle a real component embedded as a specimen (the Timeline's h2,
     the SubscribeForm's h3, SocialLinks' anchors...). */
  .ds-body > section { margin-bottom: 3rem; scroll-margin-top: 5rem; }
  .ds-body > section:last-child { margin-bottom: 0; }
  .ds-body > section > h2 {
    font-size: var(--fs-h2);
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--color-green);
    display: inline-block;
  }
  .ds-body > section > h3 {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 2rem 0 0.75rem;
  }
  .ds-body > section > p {
    font-size: var(--fs-body);
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0 0 1.1rem;
    max-width: 65ch;
  }
  .ds-body > section > p:last-child { margin-bottom: 0; }
  .ds-body > section > p a,
  .ds-body > section > ul.ds-list a {
    color: var(--color-green-text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ds-body > section > ul.ds-list {
    margin: 0 0 1.1rem;
    padding-left: 1.25rem;
    color: var(--text-secondary);
    font-size: var(--fs-body);
    line-height: 1.7;
    max-width: 65ch;
  }
  .ds-body > section > ul.ds-list li { margin-bottom: 0.4rem; }
  .ds-body > section > ul.ds-list li::marker { color: var(--color-green-text); }
  .ds-body code.ds-code {
    background: var(--code-bg);
    padding: 0.12rem 0.4rem;
    border-radius: 5px;
    font-size: 0.86em;
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
    border: 1px solid var(--border-color);
    color: var(--text-primary);
  }

  /* Guidance grid: each Do / Don't is its own card with a rendered example.
     Mobile-first single column; pairs sit side by side from 700px. */
  .ds-guidance-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 0 0 1.5rem;
  }
  @media (min-width: 700px) {
    .ds-guidance-grid { grid-template-columns: 1fr 1fr; }
  }

  /* Spacing annotations: a hatched band whose size IS the gap being
     documented (height driven by the live token or literal), with a mono
     label beside it. The hatch marks "this is measured space, not content". */
  .ds-hatch {
    background: rgba(229, 62, 62, 0.07);
    background-image: repeating-linear-gradient(
      45deg,
      rgba(229, 62, 62, 0.22) 0 1px,
      transparent 1px 7px
    );
    border-top: 1px dashed rgba(229, 62, 62, 0.55);
    border-bottom: 1px dashed rgba(229, 62, 62, 0.55);
  }
  .ds-gap-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .ds-gap-row .ds-hatch { flex: 1; }
  .ds-gap-label {
    font-size: 0.68rem;
    font-weight: 600;
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    color: var(--text-muted);
    white-space: nowrap;
  }
  .ds-annotated {
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--bg-card);
    padding: 1.25rem 1.25rem 1.25rem;
    margin: 0 0 1rem;
  }
  .ds-annotated figcaption {
    margin-top: 0.85rem;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-secondary);
  }
  /* A neutral stand-in for "some content" in rhythm demos. */
  .ds-content-bar {
    height: 34px;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: var(--badge-bg);
  }

  /* Demo helpers: neutralise fixed/sticky positioning when a real piece of
     chrome (tab bar, reading bar, sidebar ToC) is shown inline as a specimen. */
  .ds-fixed-demo .tab-bar,
  .ds-fixed-demo .post-reading-bar {
    position: static !important;
    transform: none !important;
    left: auto !important;
    bottom: auto !important;
    border-radius: 16px;
    border: 1px solid var(--border-color);
  }
  .ds-static-demo .toc {
    position: static;
    max-height: none;
  }

  .ds-foot {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    font-size: 0.85rem;
  }
  .ds-foot a { color: var(--text-muted); }
  .ds-foot a:hover { color: var(--color-green-text); }
</style>
