---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReadingBar from '../blog/ReadingBar.astro';
import ReadingProgress from '../blog/ReadingProgress.astro';
import Toc from '../blog/Toc.astro';
import { t, getLocalePath, type Locale } from '../../i18n/index';
import { getDesignData } from '../../lib/design-data';
import { DESIGN_ROOT, type DesignGroup } from '../../lib/design-ia';

interface Props {
  locale: Locale;
  currentPath: string;
  seoTitle: string;
  seoDescription: string;
  /** Which IA group this page belongs to; omitted on the landing hub. */
  group?: DesignGroup['key'];
  title: string;
  intro: string;
  /** In-page anchors for the contents card. */
  toc?: { id: string; label: string }[];
}

const { locale, currentPath, seoTitle, seoDescription, group, title, intro, toc = [] } = Astro.props;
const d = getDesignData(locale);
const i18n = t(locale);
const rootPath = getLocalePath(locale, DESIGN_ROOT);
const isHub = currentPath === rootPath;
// Content pages get the post's mobile chrome: the reading action bar whose
// ring button opens the contents as a bottom sheet, replacing the dock.
const hasReadingBar = !isHub && toc.length > 0;

const groupLabel = group ? d.groups[group] : null;
const issueSubject = encodeURIComponent(`Design system: ${title}`);

// Contents via the blog's real Toc component: sticky right column on desktop,
// inline collapsible on smaller screens — the same anatomy a post has.
const tocHeadings = toc.map((i) => ({ slug: i.id, text: i.label, depth: 2 }));
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  locale={locale}
  currentPath={currentPath}
  mobileBack={isHub ? undefined : { href: rootPath, title, eyebrow: groupLabel ? `${d.designLabel} · ${groupLabel}` : d.designLabel }}
>
  <section class="section">
    <div class="container">
      <div class="ds-content">
        <nav class="ds-breadcrumb" aria-label={d.breadcrumbLabel}>
          <a href={rootPath}>{d.designLabel}</a>
          {groupLabel && (
            <>
              <span class="ds-crumb-sep" aria-hidden="true">/</span>
              <span>{groupLabel}</span>
            </>
          )}
        </nav>

        <header class="ds-header">
          <h1 class="section-title">{title}</h1>
          <p class="ds-intro">{intro}</p>
        </header>

        <div class:list={['ds-layout', { 'ds-has-toc': toc.length > 0 }]}>
          {toc.length > 0 && (
            <div class="ds-contents">
              <Toc label={d.onThisPage} headings={tocHeadings} />
            </div>
          )}
          <div class="ds-body">
            <slot />
          </div>
        </div>

        <footer class="ds-foot">
          <span>{d.spottedIssue}</span>
          <a href={`mailto:hi@warrendeleon.com?subject=${issueSubject}`}>{d.spottedIssueLink}</a>
        </footer>
      </div>
    </div>
  </section>

  {hasReadingBar && (
    <>
      <ReadingProgress locale={locale} />
      <ReadingBar locale={locale} title={title} hidden={false} />

      <!-- Contents bottom sheet — the post's own pattern and classes. -->
      <div class="post-sheet" id="ds-toc-sheet" role="dialog" aria-modal="true" aria-label={i18n.blog.contents} hidden>
        <div class="post-sheet-backdrop" data-overlay-close></div>
        <div class="post-sheet-panel">
          <div class="post-sheet-grabber" aria-hidden="true"></div>
          <div class="post-sheet-head">
            <span class="post-sheet-title">{i18n.blog.contents}</span>
            <span class="post-sheet-meta" data-sheet-progress></span>
          </div>
          <ul class="post-sheet-list">
            {toc.map((item, i) => (
              <li data-sheet-item={item.id}>
                <a href={`#${item.id}`} data-sheet-close>
                  <span class="sheet-num" aria-hidden="true">{i + 1}</span>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </>
  )}
</BaseLayout>

{hasReadingBar && (
  <script>
    // The post reading-bar behaviour, for docs pages: ring progress, current
    // section label, contents sheet, share, back-to-top. Same affordances as
    // BlogPost's wiring, driven by the docs' own section anchors.
    const bar = document.querySelector<HTMLElement>('.post-reading-bar');
    const sheet = document.getElementById('ds-toc-sheet');
    if (bar && sheet) {
      const RING = 75.4;
      const ringFill = bar.querySelector<SVGCircleElement>('.prb-ring-fill');
      const secLabel = bar.querySelector<HTMLElement>('[data-prb-section]');
      const progLabel = bar.querySelector<HTMLElement>('[data-prb-progress]');
      const tocBtn = bar.querySelector<HTMLButtonElement>('[data-toc-open]');
      const shareBtn = bar.querySelector<HTMLButtonElement>('[data-share-open]');
      const topBtn = bar.querySelector<HTMLButtonElement>('[data-prb-top]');
      const topBar = document.querySelector<HTMLElement>('.reading-progress-bar');
      const tocLinks = [...document.querySelectorAll<HTMLAnchorElement>('.ds-contents [data-toc-link]')];
      const sections = [...document.querySelectorAll<HTMLElement>('.ds-body > section[id]')];
      const pageTitle = secLabel?.textContent ?? '';

      let ticking = false;
      function paint() {
        ticking = false;
        const max = document.documentElement.scrollHeight - window.innerHeight;
        const p = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
        if (ringFill) ringFill.style.strokeDashoffset = String((RING * (1 - p)).toFixed(1));
        if (progLabel) progLabel.textContent = `${Math.round(p * 100)}%`;
        if (topBar) topBar.style.width = `${(p * 100).toFixed(1)}%`;
        let current: HTMLElement | null = null;
        for (const s of sections) {
          if (s.getBoundingClientRect().top <= 120) current = s;
        }
        if (secLabel) secLabel.textContent = current?.querySelector('h2')?.textContent?.trim() || pageTitle;
        // Pinned-ToC scroll-spy, the post's own .toc-active highlight.
        for (const link of tocLinks) {
          link.classList.toggle('toc-active', !!current && link.getAttribute('href') === `#${current.id}`);
        }
      }
      window.addEventListener('scroll', () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(paint);
      }, { passive: true });
      paint();

      // Sheet open/close — the post sheet's is-open transition dance.
      const desktopToc = window.matchMedia('(min-width: 1024px)');
      function openSheet() {
        if (desktopToc.matches) return; // the pinned sidebar covers it there
        sheet.hidden = false;
        requestAnimationFrame(() => sheet.classList.add('is-open'));
        tocBtn?.setAttribute('aria-expanded', 'true');
      }
      function closeSheet() {
        sheet.classList.remove('is-open');
        tocBtn?.setAttribute('aria-expanded', 'false');
        window.setTimeout(() => { sheet.hidden = true; }, 300);
      }
      tocBtn?.addEventListener('click', () => (sheet.hidden ? openSheet() : closeSheet()));
      sheet.querySelector('[data-overlay-close]')?.addEventListener('click', closeSheet);
      sheet.querySelectorAll('[data-sheet-close]').forEach((a) => a.addEventListener('click', closeSheet));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !sheet.hidden) closeSheet();
      });

      // Share: the native sheet where it exists, copy-the-link otherwise.
      shareBtn?.addEventListener('click', async () => {
        const data = { title: document.title, url: window.location.href };
        if (navigator.share) {
          try { await navigator.share(data); } catch { /* dismissed */ }
        } else {
          try { await navigator.clipboard.writeText(data.url); } catch { /* blocked */ }
        }
      });

      topBtn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    }
  </script>
)}

<style is:global>
  /* Two-column docs shell: sticky section rail + content. Below 1280px the
     pages follow the blog post's own anatomy: back chevron in the mobile top
     bar, breadcrumb, and the article ToC as the contents card — a sticky
     right column on desktop, inline above the content below 1024px. */
  .ds-content { min-width: 0; }

  .ds-layout { display: grid; grid-template-columns: 1fr; }
  .ds-body { min-width: 0; }
  /* Inline contents card on small screens (the blog hides its ToC here in
     favour of the reading-bar sheet; the docs keep it inline instead). */
  /* This whole block is is:global, so plain selectors reach the Toc.
     Below 1024 the contents live behind the reading bar as a bottom sheet
     (the post's own pattern), so the sidebar card doesn't render at all. */
  .ds-contents { display: none; }

  @media (min-width: 1024px) {
    .ds-has-toc {
      grid-template-columns: minmax(0, 1fr) 280px;
      gap: 40px;
      /* NO align-items: start — the contents cell must stretch to the row
         height or the sticky ToC has no room to travel (the post layout
         relies on the same default stretch). */
    }
    /* Same shape as the post layout: content left, contents right, pinned. */
    .ds-has-toc .ds-body { grid-column: 1; grid-row: 1; }
    .ds-has-toc .ds-contents { display: block; grid-column: 2; grid-row: 1; }
    /* The Toc's own styles already pin it: sticky, top 5rem, capped height. */

    /* The pinned sidebar covers contents here, as on a post. */
    #ds-toc-sheet { display: none; }
  }

  /* On design content pages the reading bar REPLACES the dock (the post
     rule), scoped by the sheet's presence so the hub keeps its dock. */
  @media (max-width: 1279px), (hover: none) and (pointer: coarse) {
    html:has(#ds-toc-sheet) nav.tab-bar[aria-label] { display: none; }
  }

  .ds-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .ds-breadcrumb a { color: var(--text-muted); }
  .ds-breadcrumb a:hover { color: var(--color-green-text); }
  .ds-crumb-sep { opacity: 0.5; }

  .ds-header { margin-bottom: 2rem; }
  .ds-intro {
    font-size: 1.15rem;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0;
  }
  @media (max-width: 699px) {
    .ds-intro { font-size: 1.02rem; }
  }

  /* Body typography — scoped to DIRECT children of a page section, so it can
     never restyle a real component embedded as a specimen (the Timeline's h2,
     the SubscribeForm's h3, SocialLinks' anchors...). */
  .ds-body > section { margin-bottom: 3rem; scroll-margin-top: 5rem; }
  .ds-body > section:last-child { margin-bottom: 0; }
  .ds-body > section > h2 {
    font-size: var(--fs-h2);
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--color-green);
    display: inline-block;
  }
  .ds-body > section > h3 {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 2rem 0 0.75rem;
  }
  .ds-body > section > p {
    font-size: var(--fs-body);
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0 0 1.1rem;
  }
  .ds-body > section > p:last-child { margin-bottom: 0; }
  .ds-body > section > p a,
  .ds-body > section > ul.ds-list a {
    color: var(--color-green-text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ds-body > section > ul.ds-list {
    margin: 0 0 1.1rem;
    padding-left: 1.25rem;
    color: var(--text-secondary);
    font-size: var(--fs-body);
    line-height: 1.7;
  }
  .ds-body > section > ul.ds-list li { margin-bottom: 0.4rem; }
  .ds-body > section > ul.ds-list li::marker { color: var(--color-green-text); }
  .ds-body code.ds-code {
    background: var(--code-bg);
    padding: 0.12rem 0.4rem;
    border-radius: 5px;
    font-size: 0.86em;
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
    border: 1px solid var(--border-color);
    color: var(--text-primary);
  }

  /* Guidance grid: each Do / Don't is its own card with a rendered example.
     Mobile-first single column; pairs sit side by side from 700px. */
  .ds-guidance-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 0 0 1.5rem;
  }
  @media (min-width: 700px) {
    .ds-guidance-grid { grid-template-columns: 1fr 1fr; }
  }

  /* Spacing annotations: a hatched band whose size IS the gap being
     documented (height driven by the live token or literal), with a mono
     label beside it. The hatch marks "this is measured space, not content". */
  .ds-hatch {
    background: rgba(229, 62, 62, 0.07);
    background-image: repeating-linear-gradient(
      45deg,
      rgba(229, 62, 62, 0.22) 0 1px,
      transparent 1px 7px
    );
    border-top: 1px dashed rgba(229, 62, 62, 0.55);
    border-bottom: 1px dashed rgba(229, 62, 62, 0.55);
  }
  .ds-gap-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .ds-gap-row .ds-hatch { flex: 1; }
  .ds-gap-label {
    font-size: 0.68rem;
    font-weight: 600;
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    color: var(--text-muted);
    white-space: nowrap;
  }
  .ds-annotated {
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--bg-card);
    padding: 1.25rem 1.25rem 1.25rem;
    margin: 0 0 1rem;
  }
  .ds-annotated figcaption {
    margin-top: 0.85rem;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-secondary);
  }
  /* A neutral stand-in for "some content" in rhythm demos. */
  .ds-content-bar {
    height: 34px;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: var(--badge-bg);
  }

  /* Demo helpers: neutralise fixed/sticky positioning when a real piece of
     chrome (tab bar, reading bar, sidebar ToC) is shown inline as a specimen. */
  .ds-fixed-demo .tab-bar,
  .ds-fixed-demo .post-reading-bar {
    position: static !important;
    transform: none !important;
    left: auto !important;
    bottom: auto !important;
    border-radius: 16px;
    border: 1px solid var(--border-color);
  }
  /* The dock and the reading bar hide themselves at ≥1280 (correct on the
     site, wrong in a specimen): keep the demos visible on desktop, where the
     dock renders in its ≥700 pill form. */
  @media (min-width: 1280px) and (hover: hover) and (pointer: fine) {
    .ds-fixed-demo .tab-bar { display: flex !important; }
    .ds-fixed-demo .post-reading-bar { display: flex !important; }
  }
  .ds-static-demo .toc {
    position: static;
    max-height: none;
  }

  .ds-foot {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  /* The mailto reads as a real link: green and underlined, not muted prose. */
  .ds-foot a {
    color: var(--color-green-text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ds-foot a:hover { color: var(--color-green-text-hover); }
</style>
