---
// Colour / elevation tokens from the parser, with a swatch for BOTH themes
// side by side. The swatches use the literal resolved values (not the live
// CSS var), so light and dark render together regardless of the page theme.
//
// Laid out as a wrapping list, not a <table>: shadow values are long and hex
// pairs plus a usage note never fitted six columns — a table forced sideways
// scrolling on every screen. Rows stack cleanly at any width instead.
import type { ColorToken } from '../../lib/design-tokens.mjs';
import CopyHex from './CopyHex.astro';

interface Props {
  rows: ColorToken[];
  /** token name → one-line usage note. */
  usage?: Record<string, string>;
  kind?: 'color' | 'shadow';
  headers: { swatch: string; token: string; light: string; dark: string; usage: string };
  /** localised aria prefix for the copy chips, e.g. "Copy". */
  copyLabel: string;
}
const { rows, usage, kind = 'color', headers, copyLabel } = Astro.props;
---

<ul class="ds-swlist">
  {rows.map((r) => (
    <li class="ds-sw-row">
      <span class="ds-sw-stages" aria-label={headers.swatch}>
        <span class="ds-sw-stage ds-sw-light">
          {kind === 'shadow' ? (
            <span class="ds-sw-shadow" style={`box-shadow:${r.light}`}></span>
          ) : (
            <span class="ds-sw-chip" style={`background:${r.light}`}></span>
          )}
        </span>
        <span class="ds-sw-stage ds-sw-dark">
          {kind === 'shadow' ? (
            <span class="ds-sw-shadow" style={`box-shadow:${r.dark}`}></span>
          ) : (
            <span class="ds-sw-chip" style={`background:${r.dark}`}></span>
          )}
        </span>
      </span>
      <span class="ds-sw-info">
        <code class="ds-sw-token">{r.name}</code>
        <span class="ds-sw-val"><span class="ds-sw-key">{headers.light}</span> <CopyHex value={r.light} label={copyLabel} /></span>
        <span class="ds-sw-val"><span class="ds-sw-key">{headers.dark}</span> <CopyHex value={r.dark} label={copyLabel} /></span>
        {usage?.[r.name] && <span class="ds-sw-usage">{usage[r.name]}</span>}
      </span>
    </li>
  ))}
</ul>

<style>
  .ds-swlist {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
  }
  .ds-sw-row {
    display: flex;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--border-color);
    background: var(--bg-card);
  }
  .ds-sw-row:last-child { border-bottom: none; }

  /* Fixed light/dark stages so a swatch reads true whatever the page theme.
     NO overflow clipping: the shadow tokens' whole point is the glow around
     the box, and a clipped stage swallowed it (the faint dark-mode light
     shadows vanished entirely). */
  .ds-sw-stages {
    display: flex;
    flex-shrink: 0;
    border: 1px solid var(--border-color);
    border-radius: 9px;
    align-self: flex-start;
  }
  .ds-sw-stage {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
  }
  .ds-sw-light { background: #ffffff; border-radius: 8px 0 0 8px; }
  .ds-sw-dark { background: #111111; border-radius: 0 8px 8px 0; }
  .ds-sw-chip {
    display: block;
    width: 28px;
    height: 28px;
    border-radius: 7px;
    border: 1px solid rgba(128, 128, 128, 0.35);
  }
  .ds-sw-shadow {
    display: block;
    width: 30px;
    height: 30px;
    border-radius: 7px;
  }
  .ds-sw-light .ds-sw-shadow { background: #ffffff; }
  .ds-sw-dark .ds-sw-shadow { background: #222222; }

  .ds-sw-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .ds-sw-token {
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-primary);
    overflow-wrap: anywhere;
  }
  .ds-sw-val {
    font-size: 0.78rem;
    color: var(--text-secondary);
    overflow-wrap: anywhere;
  }
  .ds-sw-key {
    display: inline-block;
    min-width: 3.2em;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .ds-sw-usage {
    margin-top: 0.2rem;
    font-size: 0.82rem;
    line-height: 1.45;
    color: var(--text-secondary);
  }

  /* Roomier from tablet up: values sit beside the token instead of under it. */
  @media (min-width: 700px) {
    .ds-sw-row { gap: 1.25rem; align-items: flex-start; }
    .ds-sw-stage { width: 64px; height: 56px; }
  }
</style>
