---
// Renders a responsive scale (type or spacing) straight from the token parser.
// A real table from 700px up; below that each row stacks into a labelled block
// (the classic data-label collapse), so nothing ever scrolls sideways.
import type { ScaleToken } from '../../lib/design-tokens.mjs';

interface Props {
  rows: ScaleToken[];
  headers: { token: string; desktop: string; tablet: string; mobile: string; usage?: string };
  /** token name → one-line usage note. */
  usage?: Record<string, string>;
}
const { rows, headers, usage } = Astro.props;
const showUsage = !!headers.usage;
---

<div class="table-mini-wrap">
  <table class="table-mini table-stack">
    <thead>
      <tr>
        <th>{headers.token}</th>
        <th>{headers.desktop}</th>
        <th>{headers.tablet}</th>
        <th>{headers.mobile}</th>
        {showUsage && <th>{headers.usage}</th>}
      </tr>
    </thead>
    <tbody>
      {rows.map((r) => (
        <tr>
          <td class="stack-lead" data-label={headers.token}><code class="ds-token">{r.name}</code></td>
          <td class="ds-num" data-label={headers.desktop}>{r.desktop}</td>
          <td class="ds-num" data-label={headers.tablet}>{r.tablet}</td>
          <td class="ds-num" data-label={headers.mobile}>{r.mobile}</td>
          {showUsage && <td class="ds-usage stack-end" data-label={headers.usage}>{usage?.[r.name] ?? ''}</td>}
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .ds-token {
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    font-size: 0.8rem;
    color: var(--text-primary);
    overflow-wrap: anywhere;
  }
  .ds-num {
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace;
    color: var(--text-primary);
  }
</style>
