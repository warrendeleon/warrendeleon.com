---
// Paired guidance cards, Sainsbury's style: "Do" (green, tick) beside "Don't"
// (red, cross). Text-only by default; pass rich markup via the `do`/`dont` slots
// when a specimen belongs inside the card.
interface Props {
  doText?: string;
  dontText?: string;
  doLabel: string;
  dontLabel: string;
}
const { doText, dontText, doLabel, dontLabel } = Astro.props;
---

<div class="ds-dodont">
  <div class="ds-card ds-do">
    <p class="ds-dodont-head">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
      {doLabel}
    </p>
    <slot name="do"><p class="ds-dodont-text">{doText}</p></slot>
  </div>
  <div class="ds-card ds-dont">
    <p class="ds-dodont-head">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      {dontLabel}
    </p>
    <slot name="dont"><p class="ds-dodont-text">{dontText}</p></slot>
  </div>
</div>

<style>
  .ds-dodont {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 0 0 1.5rem;
  }
  @media (min-width: 700px) {
    .ds-dodont { grid-template-columns: 1fr 1fr; }
  }
  .ds-card {
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--bg-card);
    padding: 1.1rem 1.25rem;
  }
  .ds-do { border-left: 3px solid var(--color-green); }
  .ds-dont { border-left: 3px solid #e53e3e; }
  .ds-dodont-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 0.6rem;
  }
  .ds-do .ds-dodont-head { color: var(--color-green-text); }
  .ds-dont .ds-dodont-head { color: #e53e3e; }
  .ds-dodont-text {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--text-secondary);
  }
</style>
