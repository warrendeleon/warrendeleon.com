---
import Nav from '../components/Nav.astro';
import TabBar from '../components/TabBar.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { locales, getLocalePath, t, type Locale } from '../i18n/index';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  currentPath: string;
  canonicalPath?: string;
  jsonLd?: object;
  ogImage?: string;
  ogType?: string;
  preloadImage?: string;
  hreflangLocales?: Locale[];
  /* Mobile top-bar variant for content pages: a back chevron replaces the
     logo and a two-line title (eyebrow + title) fades in once the reader
     scrolls past the hero. Desktop nav is unaffected. */
  mobileBack?: { href: string; title: string; eyebrow?: string };
}

const { title, description, locale, currentPath, canonicalPath, jsonLd, ogImage, ogType, preloadImage, hreflangLocales, mobileBack } = Astro.props;

// Default to every locale; pages that only exist in some locales (e.g. an
// untranslated blog post) pass the subset that actually exists, so we never
// emit an hreflang alternate to a page that 404s.
const altLocales = hreflangLocales ?? locales;

const siteUrl = 'https://warrendeleon.com';
const canonical = `${siteUrl}${canonicalPath || currentPath}`;

function getCleanPath(path: string): string {
  for (const loc of locales) {
    if (loc !== 'en' && path.startsWith(`/${loc}/`)) {
      return path.slice(loc.length + 1);
    }
    if (loc !== 'en' && path === `/${loc}`) {
      return '/';
    }
  }
  return path;
}

const cleanPath = getCleanPath(currentPath);
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <!-- viewport-fit=cover lets env(safe-area-inset-*) resolve on iOS, which the
     fixed tab bar and bottom sheets need to clear the home indicator. -->
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <script is:inline>
      // Theme must resolve before first paint: at the end of <body> it gave
      // dark-theme visitors a white flash on every navigation.
      (function () {
        var stored = null;
        try { stored = localStorage.getItem('theme'); } catch (e) { /* storage blocked */ }
        var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
        var meta = document.createElement('meta');
        meta.name = 'theme-color';
        meta.content = theme === 'dark' ? '#111111' : '#ffffff';
        document.head.appendChild(meta);
      })();
    </script>
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="alternate" type="application/rss+xml" title="Warren de Leon | Blog" href="/rss.xml" />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} type="image/webp" />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType || "website"} />
    <meta property="og:url" content={`https://warrendeleon.com${currentPath}`} />
    {/* No og:image:width/height: the hero images vary in size and wrong
        declared dimensions make share-card crops worse than none. */}
    <meta property="og:image" content={ogImage ? `https://warrendeleon.com${ogImage}` : "https://warrendeleon.com/images/warren-deleon-headshot.webp"} />
    <meta property="og:locale" content={locale} />
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:site" content="@warren_deleon" />
    <meta name="twitter:creator" content="@warren_deleon" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage ? `https://warrendeleon.com${ogImage}` : "https://warrendeleon.com/images/warren-deleon-headshot.webp"} />

    {altLocales.map(loc => (
      <link
        rel="alternate"
        hreflang={loc === 'en' ? 'en' : loc}
        href={`${siteUrl}${getLocalePath(loc, cleanPath)}`}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${cleanPath}`} />

    <link rel="alternate" type="application/rss+xml" title="Warren de Leon" href="/rss.xml" />

    {/* Inter is self-hosted (see @font-face in global.css). Preload the two
        display-critical weights — body (400) and headings (800) — so the
        above-the-fold text swaps in fast without a third-party request. */}
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin-400-normal.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin-800-normal.woff2" crossorigin />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- Google Analytics with Consent Mode v2 (production only).
         Blocking the tag until someone clicks Accept cost us ~96% of sessions
         when the banner shipped on 26 June: GA went from ~25/day to 7 across
         four days, then zero. Consent Mode is Google's answer to that — the tag
         always loads, but the default state denies storage, so pre-consent
         visits send cookieless pings with no identifiers. Accepting upgrades
         the same page to full measurement without a reload.
         The owner opt-out (umami.disabled) still suppresses GA outright. -->
    <script is:inline>
      if (location.hostname === 'warrendeleon.com') {
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = gtag;

        var ccOk = false;
        try {
          var ccRaw = localStorage.getItem('cc-analytics');
          if (ccRaw) {
            var cc = JSON.parse(ccRaw);
            if (cc && cc.v === 'on' && cc.ts && (Date.now() - cc.ts) < 1000 * 60 * 60 * 24 * 183) ccOk = true;
          }
        } catch (e) {}

        // The owner opt-out is absolute — no tag, no pings.
        if (localStorage.getItem('umami.disabled')) {
          window['ga-disable-G-8FWR6HT36Y'] = true;
        } else {
          // Default state must be set before the tag loads, or the first hit
          // escapes ungoverned.
          gtag('consent', 'default', {
            ad_storage: 'denied',
            ad_user_data: 'denied',
            ad_personalization: 'denied',
            analytics_storage: ccOk ? 'granted' : 'denied',
            wait_for_update: 500
          });
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-8FWR6HT36Y';
          document.head.appendChild(s);
          gtag('js', new Date());
          gtag('config', 'G-8FWR6HT36Y');
        }
      }
    </script>

    <!-- Umami Analytics (production only, first-party proxy) -->
    <script is:inline async defer src="/a/s.js" data-website-id="b0b688d0-04ce-4773-a8d1-86d9980ed27e" data-host-url="/a" data-domains="warrendeleon.com"></script>

    <!-- Event tracking helper (fires both GA + Umami) -->
    <script is:inline>
      function t(e, d) {
        if (location.hostname === 'localhost' || location.hostname === '127.0.0.1') return;
        if (window.umami) umami.track(e, d);
        if (window.gtag) gtag('event', e, d);
      }
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">{t(locale).a11y.skipToContent}</a>
    <Nav locale={locale} currentPath={currentPath} availableLocales={altLocales} mobileBack={mobileBack} />
    <main id="main-content">
      <slot />
    </main>
    <Footer locale={locale} />
    <TabBar locale={locale} currentPath={currentPath} />
    <CookieConsent locale={locale} />

    <script is:inline>
      (function() {
        if (window.location.pathname === '/' && !localStorage.getItem('lang-detected')) {
          localStorage.setItem('lang-detected', '1');
          var lang = (navigator.language || '').toLowerCase();
          var redirect = '';
          if (lang === 'ca' || lang.indexOf('ca-') === 0) {
            redirect = '/ca/';
          } else if (lang === 'tl' || lang === 'fil' || lang.indexOf('tl-') === 0 || lang.indexOf('fil-') === 0) {
            redirect = '/tl/';
          } else if (lang === 'es' || lang.indexOf('es-') === 0) {
            redirect = '/es/';
          }
          if (redirect) window.location.replace(redirect);
        }
      })();
    </script>
    <script>
      function updateThemeToggleLabel() {
        const toggle = document.getElementById('theme-toggle');
        if (!toggle) return;
        const theme = document.documentElement.getAttribute('data-theme') || 'light';
        const label = theme === 'dark' ? toggle.dataset.labelLight : toggle.dataset.labelDark;
        if (label) toggle.setAttribute('aria-label', label);
      }

      const toggle = document.getElementById('theme-toggle');
      toggle?.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        updateThemeToggleLabel();
        t('theme_toggle', { theme: next });
      });

      updateThemeToggleLabel();

      document.querySelectorAll<HTMLElement>('[data-track-social]').forEach(function(link) {
        link.addEventListener('click', function() {
          t('social_click', { platform: link.dataset.trackSocial });
        });
      });
    </script>
  </body>
</html>
