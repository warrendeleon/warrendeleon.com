---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { locales, getLocalePath, type Locale } from '../i18n/index';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  currentPath: string;
  canonicalPath?: string;
  jsonLd?: object;
  ogImage?: string;
  ogType?: string;
  preloadImage?: string;
}

const { title, description, locale, currentPath, canonicalPath, jsonLd, ogImage, ogType, preloadImage } = Astro.props;

const siteUrl = 'https://warrendeleon.com';
const canonical = `${siteUrl}${canonicalPath || currentPath}`;

function getCleanPath(path: string): string {
  for (const loc of locales) {
    if (loc !== 'en' && path.startsWith(`/${loc}/`)) {
      return path.slice(loc.length + 1);
    }
    if (loc !== 'en' && path === `/${loc}`) {
      return '/';
    }
  }
  return path;
}

const cleanPath = getCleanPath(currentPath);
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="alternate" type="application/rss+xml" title="Warren de Leon | Blog" href="/rss.xml" />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} type="image/webp" />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType || "website"} />
    <meta property="og:url" content={`https://warrendeleon.com${currentPath}`} />
    <meta property="og:image" content={ogImage ? `https://warrendeleon.com${ogImage}` : "https://warrendeleon.com/images/warren-deleon-headshot.webp"} />
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    <meta property="og:locale" content={locale} />
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:site" content="@warren_deleon" />
    <meta name="twitter:creator" content="@warren_deleon" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage ? `https://warrendeleon.com${ogImage}` : "https://warrendeleon.com/images/warren-deleon-headshot.webp"} />

    {locales.map(loc => (
      <link
        rel="alternate"
        hreflang={loc === 'en' ? 'en' : loc}
        href={`${siteUrl}${getLocalePath(loc, cleanPath)}`}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${cleanPath}`} />

    <link rel="alternate" type="application/rss+xml" title="Warren de Leon" href="/rss.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- Google Analytics (production only) -->
    <script is:inline>
      if (location.hostname === 'warrendeleon.com') {
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-8FWR6HT36Y';
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-8FWR6HT36Y');
      }
    </script>

    <!-- Umami Analytics (production only, first-party proxy) -->
    <script is:inline async defer src="/a/s.js" data-website-id="b0b688d0-04ce-4773-a8d1-86d9980ed27e" data-host-url="/a" data-domains="warrendeleon.com"></script>

    <!-- Event tracking helper (fires both GA + Umami) -->
    <script is:inline>
      function t(e, d) {
        if (location.hostname === 'localhost' || location.hostname === '127.0.0.1') return;
        if (window.umami) umami.track(e, d);
        if (window.gtag) gtag('event', e, d);
      }
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Nav locale={locale} currentPath={currentPath} />
    <main id="main-content">
      <slot />
    </main>
    <Footer locale={locale} />

    <script is:inline>
      (function() {
        var stored = localStorage.getItem('theme');
        if (stored) {
          document.documentElement.setAttribute('data-theme', stored);
        } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.documentElement.setAttribute('data-theme', 'light');
        }

        if (window.location.pathname === '/' && !localStorage.getItem('lang-detected')) {
          localStorage.setItem('lang-detected', '1');
          var lang = (navigator.language || '').toLowerCase();
          var redirect = '';
          if (lang === 'ca' || lang.indexOf('ca-') === 0) {
            redirect = '/ca/';
          } else if (lang === 'tl' || lang === 'fil' || lang.indexOf('tl-') === 0 || lang.indexOf('fil-') === 0) {
            redirect = '/tl/';
          } else if (lang === 'es' || lang.indexOf('es-') === 0) {
            redirect = '/es/';
          }
          if (redirect) window.location.replace(redirect);
        }
      })();
    </script>
    <script>
      function updateThemeToggleLabel() {
        const toggle = document.getElementById('theme-toggle');
        const theme = document.documentElement.getAttribute('data-theme') || 'light';
        toggle?.setAttribute('aria-label', theme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme');
      }

      const toggle = document.getElementById('theme-toggle');
      toggle?.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        updateThemeToggleLabel();
        t('theme_toggle', { theme: next });
      });

      updateThemeToggleLabel();

      document.querySelectorAll('[data-track-social]').forEach(function(link) {
        link.addEventListener('click', function() {
          t('social_click', { platform: link.dataset.trackSocial });
        });
      });
    </script>
  </body>
</html>
